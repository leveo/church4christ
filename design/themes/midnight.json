{
  "$comment": "Theme: Midnight — modern and bold. Teal + gold on near-black. Dark-first (defaultMode: dark).",
  "version": 1,
  "name": "midnight",
  "label": "Midnight",
  "defaultMode": "dark",
  "fonts": {
    "display": {
      "family": "Space Grotesk Variable",
      "fallback": "system-ui, -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
      "fontsource": "@fontsource-variable/space-grotesk"
    },
    "body": {
      "family": "Inter Variable",
      "fallback": "system-ui, -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
      "fontsource": "@fontsource-variable/inter"
    },
    "mono": {
      "family": "ui-monospace",
      "fallback": "SFMono-Regular, Menlo, Consolas, monospace",
      "fontsource": null
    }
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "12px",
    "xl": "20px",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0, 0, 0, 0.4)",
    "md": "0 6px 16px rgba(0, 0, 0, 0.45)",
    "lg": "0 16px 40px rgba(0, 0, 0, 0.5)"
  },
  "modes": {
    "dark": {
      "surface": "#0E1116",
      "surface-raised": "#161B22",
      "surface-sunken": "#0A0D11",
      "surface-inverse": "#F2F5F8",
      "ink": "#E6EAF0",
      "ink-muted": "#A2ABB8",
      "ink-subtle": "#6F7987",
      "ink-inverse": "#12161C",
      "primary": "#45C4B3",
      "primary-hover": "#5AD1C0",
      "primary-active": "#38B0A0",
      "on-primary": "#04231E",
      "primary-soft": "#143430",
      "on-primary-soft": "#9FE5DB",
      "accent": "#E3B341",
      "accent-hover": "#ECC15C",
      "on-accent": "#2A2004",
      "accent-soft": "#37301A",
      "on-accent-soft": "#F2DA9E",
      "success": "#56C271",
      "on-success": "#052613",
      "success-soft": "#173327",
      "warn": "#E0A63E",
      "on-warn": "#2A1E03",
      "warn-soft": "#362B14",
      "danger": "#F07A6E",
