{
  "$comment": "Theme: Sanctuary — quiet confidence. Deep indigo + warm gold on warm paper. Default theme.",
  "version": 1,
  "name": "sanctuary",
  "label": "Sanctuary",
  "defaultMode": "light",
  "fonts": {
    "display": {
      "family": "Fraunces Variable",
      "fallback": "Georgia, 'Songti SC', 'Noto Serif SC', 'SimSun', serif",
      "fontsource": "@fontsource-variable/fraunces"
    },
    "body": {
      "family": "Inter Variable",
      "fallback": "system-ui, -apple-system, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans SC', sans-serif",
      "fontsource": "@fontsource-variable/inter"
    },
    "mono": {
      "family": "ui-monospace",
      "fallback": "SFMono-Regular, Menlo, Consolas, monospace",
      "fontsource": null
    }
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "24px",
    "full": "9999px"
  },
