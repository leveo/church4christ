---
// Prayer & Care landing: a prayer-meeting info card, the latest published
// prayer sheet, and a year-grouped archive. Reads fail soft to empty.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import PrayerSheetView from '../../../components/PrayerSheetView.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { formatDate } from '../../../lib/dates';
import { getSiteIdentity } from '../../../lib/settings';
import { latestPrayerSheet, listPrayerSheetDates, type PrayerSheetRow } from '../../../lib/publicDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

let sheet: PrayerSheetRow | null = null;
let dates: string[] = [];
let email = '';
try {
  const db = (env as { DB: D1Database }).DB;
  const [s, d, identity] = await Promise.all([
    latestPrayerSheet(db),
    listPrayerSheetDates(db),
    getSiteIdentity(db, locale),
  ]);
  sheet = s;
  dates = d;
  email = identity.email;
} catch (err) {
  console.error('prayer index: load failed', err);
}

const byYear = new Map<string, string[]>();
for (const d of dates) {
  const year = d.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(d);
}
const currentYear = new Date().getFullYear().toString();
---

<Base title={t(locale, 'prayer.title')} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <h1 class="font-display text-display-lg font-bold">{t(locale, 'prayer.title')}</h1>
      <p class="mt-3 text-lg">{t(locale, 'prayer.intro')}</p>
    </div>
  </div>

  <div class="container-content max-w-content py-10">
    <section class="rounded-lg border border-border bg-surface-sunken p-6">
      <h2 class="font-display text-heading-sm font-bold">{t(locale, 'prayer.meetingTitle')}</h2>
      <p class="mt-2 text-ink-muted">{t(locale, 'prayer.meetingBody')}</p>
      {
        email && (
          <p class="mt-2 text-sm text-ink-muted">
            {t(locale, 'prayer.contact')}{' '}
            <a href={`mailto:${email}`} class="font-semibold text-accent underline hover:text-accent-hover">
              {email}
            </a>
          </p>
        )
      }
    </section>

    {
      sheet ? (
        <div class="mt-10">
          <PrayerSheetView sheet={sheet} locale={locale} />
        </div>
      ) : (
        <p class="mt-10 py-8 text-center text-ink-muted">{t(locale, 'prayer.empty')}</p>
      )
    }

    {
      byYear.size > 0 && (
        <nav class="mt-14 border-t border-border pt-6" aria-label={t(locale, 'prayer.archive')}>
          <h2 class="mb-3 font-display font-bold">{t(locale, 'prayer.archive')}</h2>
          {[...byYear.entries()].map(([year, rows]) => (
            <details open={year === currentYear} class="mb-2">
              <summary class="cursor-pointer py-1 font-medium">{t(locale, 'sermons.yearLabel', { year })}</summary>
              <ul class="mt-2 flex flex-wrap gap-2 text-sm">
                {rows.map((d) => (
                  <li>
                    <a
                      href={localePath(locale, `/prayer/${d}`)}
                      class="inline-flex rounded-full border border-border px-3 py-1.5 hover:border-border-strong hover:text-accent"
                    >
                      {formatDate(d, locale)}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </nav>
      )
    }
  </div>
</Base>
