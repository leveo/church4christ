---
// Public event registration page: event details + a form built dynamically from
// the event's questions (text→input, textarea→textarea, select→select,
// checkbox→checkbox group, yesno→two radios). A signed-in member's name/email are
// prefilled read-only (the submit endpoint uses their session identity anyway); an
// anonymous visitor fills both. When the event is at capacity the form is replaced
// by a Full notice; ?error= banners surface a bounced submit. A missing/closed
// event (getOpenEvent → null) renders the "registration closed" state. Owned by the
// `registration` module — the middleware 404s this route when the module is off.
import Base from '../../../layouts/Base.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { formatDate } from '../../../lib/dates';
import { getOpenEvent, listQuestions } from '../../../lib/regDb';
import { btn, lab, tin, noticeErr, badge, badgeInactive } from '../../../lib/adminUi';
import {
  isCheckoutRequestId,
  ownsRecoverableRegistrationCheckoutRequest,
  registrationCheckoutRenderPolicy,
} from '../../../lib/stripeCheckoutRequests';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const eventId = Number(Astro.params.id);
const event =
  Number.isInteger(eventId) && eventId > 0 ? await getOpenEvent(Astro.locals.db, locale, eventId) : null;
const questions = event ? await listQuestions(Astro.locals.db, locale, eventId) : [];

const user = Astro.locals.user;
const errParam = Astro.url.searchParams.get('error');
const paid = !!event && event.price_cents !== null && event.price_cents > 0;
const requestedCheckoutId = errParam === 'waiting' ? Astro.url.searchParams.get('checkoutRequestId') : null;
const ownsWaitingSeat = !!event
  && paid
  && isCheckoutRequestId(requestedCheckoutId)
  && await ownsRecoverableRegistrationCheckoutRequest(Astro.locals.db, requestedCheckoutId, event.id);
const { checkoutRequestId, isFull } = registrationCheckoutRenderPolicy({
  paid,
  capacity: event?.capacity ?? null,
  takenCount: event?.taken_count ?? 0,
  error: errParam,
  checkoutRequestId: requestedCheckoutId,
  ownsWaitingSeat,
});
const errorKey =
  errParam === 'full'
    ? 'register.error.full'
    : errParam === 'invalid' || errParam === 'waiting'
      ? 'register.error.invalid'
      : null;

const priceLabel = paid ? `$${(event!.price_cents! / 100).toFixed(2)}` : t(locale, 'register.free');
const when = event ? `${formatDate(event.starts_at.slice(0, 10), locale)} ${event.starts_at.slice(11, 16)}` : '';
---

{
  !event ? (
    <Base title={t(locale, 'register.title')} locale={locale}>
      <div class="container-content max-w-xl py-16 text-center">
        <p class={noticeErr}>{t(locale, 'register.error.closed')}</p>
        <a href={localePath(locale, '/register')} class="mt-6 inline-block underline">
          {t(locale, 'register.back')}
        </a>
      </div>
    </Base>
  ) : (
    <Base title={event.title} locale={locale}>
      <div class="container-content max-w-xl py-12">
        <a href={localePath(locale, '/register')} class="text-sm text-ink-muted hover:underline">
          {t(locale, 'register.back')}
        </a>
        <h1 class="mt-3 font-display text-heading-md font-bold">{event.title}</h1>
        <p class="mt-2 text-sm text-ink-muted">{when}</p>
        {event.location && <p class="text-sm text-ink-muted">{event.location}</p>}
        <p class="mt-2 text-sm">
          <span class="font-semibold">{t(locale, 'register.price')}:</span> {priceLabel}
        </p>
        {event.description && <p class="mt-4 whitespace-pre-line">{event.description}</p>}

        {errorKey && <p class={`${noticeErr} mt-6`}>{t(locale, errorKey)}</p>}

        {isFull ? (
          <p class={`${badge} ${badgeInactive} mt-6`}>{t(locale, 'register.full')}</p>
        ) : (
          <form method="post" action="/api/register/submit" class="mt-6 space-y-4">
            <input type="hidden" name="locale" value={locale} />
            <input type="hidden" name="event_id" value={event.id} />
            <input type="hidden" name="checkoutRequestId" value={checkoutRequestId} />

            {/* Honeypot: hidden from humans, tempting for bots. */}
            <div aria-hidden="true" style="position:absolute;left:-9999px" tabindex="-1">
              <label>
                Website
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>
            </div>

            <label class="block">
              <span class={lab}>{t(locale, 'register.name')}</span>
              <input name="name" required class={tin} value={user ? user.displayName : ''} readonly={!!user} />
            </label>
            <label class="block">
              <span class={lab}>{t(locale, 'register.email')}</span>
              <input type="email" name="email" required class={tin} value={user ? user.email : ''} readonly={!!user} />
            </label>

            {questions.map((q) => (
              <fieldset class="block">
                <span class={lab}>{q.label}</span>
                {q.type === 'text' && <input name={String(q.id)} required={q.required === 1} class={tin} />}
                {q.type === 'textarea' && (
                  <textarea name={String(q.id)} required={q.required === 1} rows="4" class={tin} />
                )}
                {q.type === 'select' && (
                  <select name={String(q.id)} required={q.required === 1} class={tin}>
                    <option value="">—</option>
                    {(q.options ?? []).map((o) => (
                      <option value={o}>{o}</option>
                    ))}
                  </select>
                )}
                {q.type === 'checkbox' && (
                  <div class="space-y-1">
                    {(q.options ?? []).map((o) => (
                      <label class="flex items-center gap-2 text-sm">
                        <input type="checkbox" name={String(q.id)} value={o} />
                        <span>{o}</span>
                      </label>
                    ))}
                  </div>
                )}
                {q.type === 'yesno' && (
                  <div class="flex gap-4">
                    <label class="flex items-center gap-2 text-sm">
                      <input type="radio" name={String(q.id)} value="yes" required={q.required === 1} />
                      <span>{t(locale, 'register.yes')}</span>
                    </label>
                    <label class="flex items-center gap-2 text-sm">
                      <input type="radio" name={String(q.id)} value="no" required={q.required === 1} />
                      <span>{t(locale, 'register.no')}</span>
                    </label>
                  </div>
                )}
              </fieldset>
            ))}

            <button type="submit" class={btn}>
              {t(locale, paid ? 'register.submit.paid' : 'register.submit.free')}
            </button>
          </form>
        )}
      </div>
    </Base>
  )
}
