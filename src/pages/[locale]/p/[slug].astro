---
// Public route for admin-authored custom pages (src/pages/admin/pages/index.astro
// is the editor). Renders through ContentPage exactly like privacy.astro. An
// unpublished page 404s for anonymous visitors but is previewable (with a draft
// banner) for an editor/admin session; title and body each fall back to the en
// i18n row independently when the requested locale's value is empty.
import ContentPage from '../../../components/ContentPage.astro';
import { parseLocale } from '../../../lib/locales';
import { getCustomPageBySlug } from '../../../lib/pagesDb';
import { renderMarkdown } from '../../../lib/markdown';
import { t } from '../../../lib/i18n';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const page = await getCustomPageBySlug(Astro.locals.db, Astro.params.slug ?? '');
const user = Astro.locals.user;
const canPreview = !!user && (user.isEditor || user.isAdmin);
if (!page || (!page.published && !canPreview)) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const loc = page.i18n[locale];
const fallback = page.i18n.en;
const title = loc.title || fallback.title;
const bodyMd = loc.body_md || fallback.body_md;
const html = renderMarkdown(bodyMd);
---

<ContentPage title={title} locale={locale}>
  {
    !page.published && (
      <div slot="before" class="rounded-md border border-border bg-info-soft text-info px-4 py-3 text-sm">
        {t(locale, 'pages.draftNotice')}
      </div>
    )
  }
  <Fragment set:html={html} />
</ContentPage>
