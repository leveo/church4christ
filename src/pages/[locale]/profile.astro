---
// Own profile (authed via route policy): edit display/first/last name, phone and
// preferred language; team chips; latest gifts-quiz summary; the ministry
// interests checklist (replace semantics); and the ServingHistory block.
// Ported from the reference stack's src/pages/profile.astro.
//
// Self-service hardening: email, role, and active are NOT self-editable. The
// POST overwrites those three fields with the CURRENT row's values before
// parsePersonForm runs, so a crafted `role=admin` / `active` / `email=` field
// in the body is discarded server-side and the row keeps its current values.
import Base from '../../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import AvatarInitials from '../../components/AvatarInitials.astro';
import ServingHistory from '../../components/ServingHistory.astro';
import GroupActivity from '../../components/GroupActivity.astro';
import { localePath, parseLocale, LOCALES } from '../../lib/locales';
import { t } from '../../lib/i18n';
import { getPerson, savePerson, setPersonAvatar } from '../../lib/adminDb';
import { listPersonGroupActivity, type PersonGroupActivity } from '../../lib/groupDb';
import { listRegistrationsForPerson, type PersonRegistration } from '../../lib/groupRegDb';
import { saveImageUpload, uploadErrorKey, type MediaBucket } from '../../lib/mediaUpload';
import { normalizeAvatarUrl } from '../../lib/mediaRef';
import {
  getLatestGiftResult,
  listBlockouts,
  listPersonInterests,
  listPersonServingHistory,
  listPersonTeams,
  setPersonInterests,
} from '../../lib/myDb';
import { MINISTRY_CATEGORIES } from '../../lib/ministryMeta';
import { giftLabel } from '../../lib/giftQuiz';
import { parsePersonForm, parseHouseholdForm, parseDependentForm } from '../../lib/validate';
import {
  getLiveHouseholdForPerson,
  createHousehold,
  updateHousehold,
  addDependent,
  removeDependent,
  leaveHousehold,
  type HouseholdWithMembers,
} from '../../lib/householdDb';
import { btn, btnDanger, lab, noticeErr, noticeOk, tin } from '../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const user = Astro.locals.user!;
const db = Astro.locals.db;
const media = (env as unknown as { MEDIA: MediaBucket }).MEDIA;
// People module gates the membership-profile depth (birthday/address) and the
// household card; the auth basics (name/phone/lang, teams, gifts, interests,
// history) always render.
const hasPeople = Astro.locals.modules.has('people');
// Soft-degrade cross-module links: `/my` is serve-owned and `/serve/gifts` is
// gifts-owned, so both 404 when their module is off. Gate the links (not the
// whole page — /profile is core auth surface) to avoid dead-ends.
const hasServe = Astro.locals.modules.has('serve');
const hasGifts = Astro.locals.modules.has('gifts');
// Groups module: "my groups" + attendance history, plus registrations when the
// registration module is also on (Supabase-only reader — never called on D1).
const hasGroups = Astro.locals.modules.has('groups');

const categoryLabel = (c: string) => (MINISTRY_CATEGORIES.includes(c) ? t(locale, `ministries.category.${c}`) : c);

// Household actions (self-service). All lib mutations pass the signed-in
// person's id with isAdmin=false, so the lib re-verifies the actor is an adult
// member of the target household — a crafted household_id can never touch a
// household the user isn't in.
const HOUSEHOLD_ACTIONS = new Set(['createHousehold', 'updateHousehold', 'addDependent', 'removeDependent', 'leaveHousehold']);
const HH_ERR: Record<string, string> = {
  already_in_household: 'profile.household.errAlreadyIn',
  not_authorized: 'profile.household.errNotAuthorized',
  not_a_dependent: 'profile.household.errNotDependent',
};
const mapHouseholdError = (e: unknown): string =>
  HH_ERR[e instanceof Error ? e.message : ''] ?? 'profile.household.errGeneric';
const idOf = (v: FormDataEntryValue | null): number | null => (/^\d+$/.test(String(v ?? '')) ? Number(v) : null);

let errorKeys: string[] = [];
let householdErrorKeys: string[] = [];
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = String(fd.get('_action') ?? '');

  if (action === 'saveInterests') {
    const chosen = fd
      .getAll('interest')
      .map((v) => String(v))
      .filter((c) => MINISTRY_CATEGORIES.includes(c));
    await setPersonInterests(db, user.id, chosen);
    return Astro.redirect(localePath(locale, '/profile?interests=1'), 303);
  }

  // Household card mutations (gated by the people module — the forms only render
  // when it is on, and a crafted POST while off is a silent no-op).
  if (hasPeople && HOUSEHOLD_ACTIONS.has(action)) {
    const done = () => Astro.redirect(localePath(locale, '/profile?household=1'), 303);
    try {
      if (action === 'createHousehold') {
        const parsed = parseHouseholdForm(fd);
        if (!parsed.ok) householdErrorKeys = [...new Set(Object.values(parsed.errors))];
        else {
          await createHousehold(db, parsed.data, user.id);
          return done();
        }
      } else if (action === 'leaveHousehold') {
        await leaveHousehold(db, user.id);
        return done();
      } else if (action === 'removeDependent') {
        const memberId = idOf(fd.get('member_id'));
        if (memberId !== null) await removeDependent(db, memberId, user.id, false);
        return done();
      } else {
        // update / addDependent both need the caller's current household.
        const hh = await getLiveHouseholdForPerson(db, user.id);
        if (!hh) householdErrorKeys = ['profile.household.errGeneric'];
        else if (action === 'updateHousehold') {
          const parsed = parseHouseholdForm(fd);
          if (!parsed.ok) householdErrorKeys = [...new Set(Object.values(parsed.errors))];
          else {
            await updateHousehold(db, hh.id, parsed.data, user.id, false);
            return done();
          }
        } else if (action === 'addDependent') {
          const parsed = parseDependentForm(fd);
          if (!parsed.ok) householdErrorKeys = [...new Set(Object.values(parsed.errors))];
          else {
            await addDependent(db, hh.id, parsed.data.displayName, parsed.data.role, user.id, false);
            return done();
          }
        }
      }
    } catch (e) {
      householdErrorKeys = [mapHouseholdError(e)];
    }
  } else if (action === '') {
    // Identity form (no _action). Strip the privileged fields: whatever the form
    // posted, the row keeps its current email/role/active. Volunteers edit names,
    // phone, and language only.
    const current = await getPerson(db, user.id);
    if (!current) return new Response(null, { status: 404 });
    fd.set('email', current.email);
    fd.set('role', current.role);
    if (current.active === 1) fd.set('active', 'on');
    else fd.delete('active');

    const parsed = parsePersonForm(fd);
    if (parsed.ok) {
      const avatarFile = fd.get('avatar');
      let avatarKey: string | null = null;
      if (avatarFile instanceof File && avatarFile.size > 0) {
        try {
          avatarKey = await saveImageUpload({ db, media, file: avatarFile, uploadedBy: user.email });
        } catch (e) {
          errorKeys = [uploadErrorKey(e)];
        }
      }
      if (errorKeys.length === 0) {
        const result = await savePerson(db, { id: user.id, ...parsed.data }, user.email);
        if (result.ok) {
          // birthday/address are self-service membership fields that savePerson does
          // not touch (membership_status/joined_on are admin-only and never parsed
          // here). Persist just these two columns, scoped to the signed-in person,
          // only while the people module is on.
          if (hasPeople) {
            await db
              .prepare(`UPDATE people SET birthday = ?, address = ?, updated_at = datetime('now') WHERE id = ?`)
              .bind(parsed.data.birthday, parsed.data.address, user.id)
              .run();
          }
          if (avatarKey) await setPersonAvatar(db, user.id, `/media/${avatarKey}`);
          else if (fd.get('remove_avatar')) await setPersonAvatar(db, user.id, null);
          return Astro.redirect(localePath(locale, '/profile?saved=1'), 303);
        }
        errorKeys = [...new Set(Object.values(result.errors))];
      }
    } else {
      errorKeys = [...new Set(Object.values(parsed.errors))];
    }
  }
}

const saved = Astro.url.searchParams.has('saved');
const interestsSaved = Astro.url.searchParams.has('interests');
const householdSaved = Astro.url.searchParams.has('household');

const [person, teams, history, blockouts, gift, myInterests] = await Promise.all([
  getPerson(db, user.id),
  listPersonTeams(db, user.id, locale),
  listPersonServingHistory(db, user.id, locale),
  listBlockouts(db, user.id, '2000-01-01'),
  getLatestGiftResult(db, user.id),
  listPersonInterests(db, user.id),
]);
if (!person) return new Response(null, { status: 404 });
const interestSet = new Set(myInterests);
const avatarUrl = normalizeAvatarUrl(person.avatar_url);

// Membership-profile depth + household card (people module only).
let household: HouseholdWithMembers | null = null;
let personExtra = { birthday: '', address: '' };
if (hasPeople) {
  const [hh, extra] = await Promise.all([
    getLiveHouseholdForPerson(db, user.id),
    db.prepare(`SELECT birthday, address FROM people WHERE id = ?`).bind(user.id).first<{ birthday: string | null; address: string | null }>(),
  ]);
  household = hh;
  personExtra = { birthday: extra?.birthday ?? '', address: extra?.address ?? '' };
}
// Adults (real members) may edit the shared card / manage dependents; the lib
// re-verifies this, but hiding the forms for a child-role member keeps the UI honest.
const iAmAdult = household?.members.some((m) => m.person_id === user.id && m.role === 'adult') ?? false;

// Groups module: own memberships + attendance, and (registration module on)
// own event registrations — the Supabase-only reader is never reached on D1.
let groupActivity: PersonGroupActivity = { memberships: [], attendance: [] };
let registrations: PersonRegistration[] = [];
if (hasGroups) {
  groupActivity = await listPersonGroupActivity(db, user.id);
  if (Astro.locals.modules.has('registration')) {
    registrations = await listRegistrationsForPerson(db, user.id, locale);
  }
}
---

<Base title={t(locale, 'profile.title')} locale={locale} noindex>
  <div class="container-content max-w-content py-12">
    {hasServe && (
      <a href={localePath(locale, '/my')} class="text-sm text-ink-muted hover:text-primary">← {t(locale, 'my.title')}</a>
    )}
    <h1 class="mt-2 font-display text-heading-md font-bold">{t(locale, 'profile.title')}</h1>

    {saved && <p class={`mt-4 ${noticeOk}`}>{t(locale, 'profile.saved')}</p>}
    {interestsSaved && <p class={`mt-4 ${noticeOk}`}>{t(locale, 'profile.interestsSaved')}</p>}
    {householdSaved && <p class={`mt-4 ${noticeOk}`}>{t(locale, 'profile.household.saved')}</p>}
    {errorKeys.map((key) => <p class={`mt-4 ${noticeErr}`}>{t(locale, key)}</p>)}

    <form method="post" enctype="multipart/form-data" class="mt-6 grid gap-4 rounded-lg border border-border bg-surface-raised p-6 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <span class={lab}>{t(locale, 'profile.avatar')}</span>
        <div class="mt-2 flex flex-wrap items-center gap-4">
          {avatarUrl && (
            <img
              src={avatarUrl}
              alt={t(locale, 'profile.currentAvatar')}
              class="h-20 w-20 rounded-full border border-border object-cover"
            />
          )}
          {!avatarUrl && <AvatarInitials name={person.display_name} sizeClass="h-20 w-20 text-2xl" />}
          <div class="min-w-56 flex-1">
            <label class="block">
              <span class={lab}>{t(locale, 'profile.changeAvatar')}</span>
              <input type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif" class={`${tin} file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1.5 file:text-sm file:font-semibold file:text-on-primary`} />
            </label>
            {avatarUrl && (
              <label class="mt-2 flex items-center gap-2 text-sm">
                <input type="checkbox" name="remove_avatar" />
                <span>{t(locale, 'profile.removeAvatar')}</span>
              </label>
            )}
          </div>
        </div>
      </div>
      <label class="block sm:col-span-2">
        <span class={lab}>{t(locale, 'profile.name')}</span>
        <input name="display_name" required value={person.display_name} class={tin} />
      </label>
      <label class="block">
        <span class={lab}>{t(locale, 'profile.firstName')}</span>
        <input name="first_name" value={person.first_name} class={tin} />
      </label>
      <label class="block">
        <span class={lab}>{t(locale, 'profile.lastName')}</span>
        <input name="last_name" value={person.last_name} class={tin} />
      </label>
      <label class="block">
        <span class={lab}>{t(locale, 'profile.email')}</span>
        <input value={person.email} disabled class={`${tin} bg-surface-sunken text-ink-muted`} />
      </label>
      <label class="block">
        <span class={lab}>{t(locale, 'profile.phone')}</span>
        <input name="phone" value={person.phone ?? ''} class={tin} />
      </label>
      <label class="block">
        <span class={lab}>{t(locale, 'profile.lang')}</span>
        <select name="lang" class={tin}>
          <option value="" selected={person.lang === null}>{t(locale, 'profile.langNone')}</option>
          {LOCALES.map((l) => (
            <option value={l} selected={person.lang === l}>{t(locale, `admin.settings.locale${l === 'en' ? 'En' : 'Zh'}`)}</option>
          ))}
        </select>
      </label>
      {
        hasPeople && (
          <>
            <label class="block">
              <span class={lab}>{t(locale, 'profile.birthday')}</span>
              <input type="date" name="birthday" value={personExtra.birthday} class={tin} />
            </label>
            <label class="block">
              <span class={lab}>{t(locale, 'profile.address')}</span>
              <input name="address" value={personExtra.address} class={tin} />
            </label>
          </>
        )
      }
      <div class="sm:col-span-2">
        <button type="submit" class={btn}>{t(locale, 'profile.save')}</button>
      </div>
    </form>

    {
      hasPeople && (
        <section class="mt-8 rounded-lg border border-border bg-surface-raised p-6">
          <h2 class="font-display text-lg font-semibold">{t(locale, 'profile.household.title')}</h2>
          {householdErrorKeys.map((key) => (
            <p class={`mt-3 ${noticeErr}`}>{t(locale, key)}</p>
          ))}

          {!household ? (
            <div class="mt-3">
              <p class="text-sm text-ink-muted">{t(locale, 'profile.household.none')}</p>
              <form method="post" class="mt-4 grid gap-3 sm:grid-cols-2">
                <input type="hidden" name="_action" value="createHousehold" />
                <p class="text-sm font-semibold sm:col-span-2">{t(locale, 'profile.household.createTitle')}</p>
                <p class="text-sm text-ink-muted sm:col-span-2">{t(locale, 'profile.household.createHint')}</p>
                <label class="block sm:col-span-2">
                  <span class={lab}>{t(locale, 'profile.household.name')}</span>
                  <input name="name" required class={tin} />
                </label>
                <label class="block">
                  <span class={lab}>{t(locale, 'profile.household.address')}</span>
                  <input name="address" class={tin} />
                </label>
                <label class="block">
                  <span class={lab}>{t(locale, 'profile.household.phone')}</span>
                  <input name="phone" class={tin} />
                </label>
                <div class="sm:col-span-2">
                  <button type="submit" class={btn}>
                    {t(locale, 'profile.household.create')}
                  </button>
                </div>
              </form>
            </div>
          ) : (
            <div class="mt-3 flex flex-col gap-6">
              <div>
                <p class="font-semibold">{household.name}</p>
                {household.address && <p class="mt-0.5 text-sm text-ink-muted">{household.address}</p>}
                {household.phone && <p class="text-sm text-ink-muted">{household.phone}</p>}
              </div>

              <div>
                <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">
                  {t(locale, 'profile.household.members')}
                </p>
                <ul class="mt-2 flex flex-col gap-1.5">
                  {household.members.map((m) => (
                    <li class="flex flex-wrap items-center gap-2 text-sm">
                      <span class="font-medium">{m.display_name}</span>
                      <span class="rounded-full bg-surface-sunken px-2 py-0.5 text-xs text-ink-muted">
                        {t(locale, m.role === 'child' ? 'profile.household.roleChild' : 'profile.household.roleAdult')}
                      </span>
                      {m.is_primary === 1 && (
                        <span class="rounded-full bg-primary-soft px-2 py-0.5 text-xs font-semibold text-on-primary-soft">
                          {t(locale, 'profile.household.primary')}
                        </span>
                      )}
                      {m.person_id === user.id && (
                        <span class="rounded-full bg-accent-soft px-2 py-0.5 text-xs font-semibold text-on-accent-soft">
                          {t(locale, 'profile.household.you')}
                        </span>
                      )}
                      {iAmAdult && m.person_id === null && (
                        <form
                          method="post"
                          class="inline"
                          onsubmit={`return confirm(${JSON.stringify(t(locale, 'profile.household.removeConfirm'))})`}
                        >
                          <input type="hidden" name="_action" value="removeDependent" />
                          <input type="hidden" name="member_id" value={m.id} />
                          <button type="submit" class="text-xs font-semibold text-danger hover:underline">
                            {t(locale, 'profile.household.remove')}
                          </button>
                        </form>
                      )}
                    </li>
                  ))}
                </ul>
              </div>

              {iAmAdult && (
                <>
                  <form method="post" class="grid gap-3 border-t border-border pt-5 sm:grid-cols-2">
                    <input type="hidden" name="_action" value="updateHousehold" />
                    <p class="text-sm font-semibold sm:col-span-2">{t(locale, 'profile.household.editTitle')}</p>
                    <label class="block sm:col-span-2">
                      <span class={lab}>{t(locale, 'profile.household.name')}</span>
                      <input name="name" required value={household.name} class={tin} />
                    </label>
                    <label class="block">
                      <span class={lab}>{t(locale, 'profile.household.address')}</span>
                      <input name="address" value={household.address ?? ''} class={tin} />
                    </label>
                    <label class="block">
                      <span class={lab}>{t(locale, 'profile.household.phone')}</span>
                      <input name="phone" value={household.phone ?? ''} class={tin} />
                    </label>
                    <div class="sm:col-span-2">
                      <button type="submit" class={btn}>
                        {t(locale, 'profile.household.save')}
                      </button>
                    </div>
                  </form>

                  <form method="post" class="grid gap-3 border-t border-border pt-5 sm:grid-cols-2">
                    <input type="hidden" name="_action" value="addDependent" />
                    <p class="text-sm font-semibold sm:col-span-2">{t(locale, 'profile.household.addTitle')}</p>
                    <p class="text-sm text-ink-muted sm:col-span-2">{t(locale, 'profile.household.addHint')}</p>
                    <label class="block">
                      <span class={lab}>{t(locale, 'profile.household.dependentName')}</span>
                      <input name="display_name" required class={tin} />
                    </label>
                    <label class="block">
                      <span class={lab}>{t(locale, 'profile.household.role')}</span>
                      <select name="role" class={tin}>
                        <option value="adult">{t(locale, 'profile.household.roleAdult')}</option>
                        <option value="child">{t(locale, 'profile.household.roleChild')}</option>
                      </select>
                    </label>
                    <div class="sm:col-span-2">
                      <button type="submit" class={btn}>
                        {t(locale, 'profile.household.add')}
                      </button>
                    </div>
                  </form>
                </>
              )}

              <form
                method="post"
                class="border-t border-border pt-5"
                onsubmit={`return confirm(${JSON.stringify(t(locale, 'profile.household.leaveConfirm'))})`}
              >
                <input type="hidden" name="_action" value="leaveHousehold" />
                <p class="text-sm text-ink-muted">{t(locale, 'profile.household.leaveHint')}</p>
                <button type="submit" class={`mt-3 ${btnDanger}`}>
                  {t(locale, 'profile.household.leave')}
                </button>
              </form>
            </div>
          )}
        </section>
      )
    }

    <section class="mt-8">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'profile.myTeams')}</h2>
      {
        teams.length === 0 ? (
          <p class="mt-2 text-sm text-ink-muted">{t(locale, 'profile.noTeams')}</p>
        ) : (
          <ul class="mt-2 flex flex-wrap gap-2">
            {teams.map((tm) => (
              <li class="inline-flex items-center rounded-full bg-primary-soft px-3 py-1 text-sm text-on-primary-soft">
                {tm.name}
                {tm.is_leader === 1 && <span class="ml-1 text-xs font-bold text-accent">· {t(locale, 'profile.leaderTag')}</span>}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <section class="mt-8 rounded-lg border border-border bg-surface-raised p-6">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'profile.giftResult')}</h2>
      {
        gift ? (
          <div class="mt-2">
            {gift.top_gifts.length > 0 && (
              <div>
                <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">{t(locale, 'profile.giftTop')}</p>
                <ul class="mt-1.5 flex flex-wrap gap-1.5">
                  {gift.top_gifts.map((c) => (
                    <li class="inline-flex items-center rounded-full bg-accent-soft px-2.5 py-1 text-xs font-semibold text-on-accent-soft">
                      {giftLabel(c, locale)}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {gift.recommended.length > 0 && (
              <div class="mt-3">
                <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">{t(locale, 'profile.giftRecommended')}</p>
                <ul class="mt-1.5 flex flex-wrap gap-1.5">
                  {gift.recommended.map((c) => (
                    <li class="inline-flex items-center rounded-full bg-primary-soft px-2.5 py-1 text-xs font-semibold text-on-primary-soft">
                      {categoryLabel(c)}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ) : (
          <p class="mt-2 text-sm text-ink-muted">
            {t(locale, 'profile.noGift')}
            {hasGifts && (
              <a href={localePath(locale, '/serve/gifts')} class="ml-1 font-semibold text-primary hover:underline">
                {t(locale, 'profile.takeTest')} →
              </a>
            )}
          </p>
        )
      }
    </section>

    <section class="mt-8 rounded-lg border border-border bg-surface-raised p-6">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'profile.interests')}</h2>
      <p class="mt-1 text-sm text-ink-muted">{t(locale, 'profile.interestsHint')}</p>
      <form method="post" class="mt-3">
        <input type="hidden" name="_action" value="saveInterests" />
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          {
            MINISTRY_CATEGORIES.map((c) => (
              <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" name="interest" value={c} checked={interestSet.has(c)} class="h-4 w-4" />
                {categoryLabel(c)}
              </label>
            ))
          }
        </div>
        <button type="submit" class={`mt-4 ${btn}`}>{t(locale, 'profile.saveInterests')}</button>
      </form>
    </section>

    <div class="mt-10">
      <ServingHistory locale={locale} history={history} blockouts={blockouts} />
    </div>

    {
      hasGroups && (
        <div class="mt-10">
          <GroupActivity
            locale={locale}
            memberships={groupActivity.memberships}
            attendance={groupActivity.attendance}
            registrations={registrations}
          />
        </div>
      )
    }
  </div>
</Base>
