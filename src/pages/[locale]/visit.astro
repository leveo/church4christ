---
// Plan-a-visit page: renders the `pages/visit` content entry (en-fallback aware).
import { render } from 'astro:content';
import ContentPage from '../../components/ContentPage.astro';
import { parseLocale } from '../../lib/locales';
import { getLocalized } from '../../lib/content';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const found = await getLocalized('pages', 'visit', locale);
if (!found) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const { entry, translated } = found;
const { Content } = await render(entry);
---

<ContentPage
  title={entry.data.title}
  description={entry.data.description}
  locale={locale}
  translated={translated}
>
  <Content />
</ContentPage>
