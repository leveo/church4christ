---
// Give page. With the `giving` module ON (Supabase-only), this renders the
// interactive checkout form that POSTs to /api/giving/checkout. With it OFF (the
// D1 default, and any church that hasn't enabled it) it keeps the original
// external-link stewardship page: content from the `pages/give` entry plus a
// prominent CTA driven by the site's giving URL setting, failing soft (a note,
// no button) when the setting is unset or the read fails.
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ContentPage from '../../components/ContentPage.astro';
import { localePath, parseLocale } from '../../lib/locales';
import { t } from '../../lib/i18n';
import { getLocalized } from '../../lib/content';
import { getSiteIdentity } from '../../lib/settings';
import { listFunds } from '../../lib/fundDb';
import { btn, lab, noticeErr, tin } from '../../lib/adminUi';
import { checkoutRequestIdForRender } from '../../lib/stripeCheckoutRequests';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const givingOn = Astro.locals.modules.has('giving');

// ── Module ON: interactive giving form ──────────────────────────────────────
// Active funds, sorted (listFunds orders by sort). An anonymous visitor can only
// give once — recurring needs a person to attach the subscription to — so the
// weekly/monthly radios are disabled and a sign-in link is offered. The checkout
// endpoint bounces validation failures back here as ?error=<code>; every code but
// the portal-specific `noportal` reads as a generic "check the form" message.
const user = Astro.locals.user;
const funds = givingOn ? await listFunds(Astro.locals.db, locale, { activeOnly: true }) : [];
const errParam = givingOn ? Astro.url.searchParams.get('error') : null;
const checkoutRequestId = checkoutRequestIdForRender(
  errParam === 'stripe' ? Astro.url.searchParams.get('checkoutRequestId') : null,
);
const errorKey = errParam ? (errParam === 'noportal' ? 'give.error.noportal' : 'give.error.invalid') : null;
const frequencies = [
  { value: 'once', label: 'give.once', guestOk: true },
  { value: 'week', label: 'give.weekly', guestOk: false },
  { value: 'month', label: 'give.monthly', guestOk: false },
];
const signinHref = localePath(locale, `/signin?next=${encodeURIComponent(localePath(locale, '/give'))}`);

// ── Module OFF: the existing external-link stewardship page ──────────────────
const found = await getLocalized('pages', 'give', locale);
if (!found) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const { entry, translated } = found;
const { Content } = await render(entry);

// Giving link is a public setting; fail soft to '' so a DB hiccup never 500s.
let givingUrl = '';
try {
  const db = Astro.locals.db;
  givingUrl = (await getSiteIdentity(db, locale)).givingUrl;
} catch (e) {
  console.error('give page: getSiteIdentity failed', e);
}
---

{
  givingOn ? (
    <Base title={t(locale, 'give.title')} locale={locale}>
      <div class="container-content max-w-xl py-12">
        <h1 class="font-display text-heading-md font-bold">{t(locale, 'give.title')}</h1>

        <form method="post" action="/api/giving/checkout" class="mt-6 space-y-4">
          <input type="hidden" name="locale" value={locale} />
          <input type="hidden" name="checkoutRequestId" value={checkoutRequestId} />

          {errorKey && <p class={noticeErr}>{t(locale, errorKey)}</p>}

          <label class="block">
            <span class={lab}>{t(locale, 'give.fund')}</span>
            <select name="fund_id" required class={tin}>
              {funds.map((f) => (
                <option value={f.id}>{f.name}</option>
              ))}
            </select>
          </label>

          <label class="block">
            <span class={lab}>{t(locale, 'give.amount')}</span>
            <input type="number" name="amount" step="0.01" min="1" required class={tin} />
          </label>

          <fieldset class="space-y-2">
            <legend class={lab}>{t(locale, 'give.frequency')}</legend>
            {frequencies.map((f) => (
              <label class="flex items-center gap-2 text-sm">
                <input
                  type="radio"
                  name="frequency"
                  value={f.value}
                  checked={f.value === 'once'}
                  disabled={!user && !f.guestOk}
                />
                <span>{t(locale, f.label)}</span>
              </label>
            ))}
          </fieldset>

          {!user && (
            <>
              <p class="text-sm text-ink-muted">
                <a href={signinHref} class="underline">
                  {t(locale, 'give.recurringNeedsSignin')}
                </a>
              </p>

              <label class="block">
                <span class={lab}>{t(locale, 'give.name')}</span>
                <input name="name" required class={tin} />
              </label>
              <label class="block">
                <span class={lab}>{t(locale, 'give.email')}</span>
                <input type="email" name="email" required class={tin} />
              </label>
            </>
          )}

          <button type="submit" class={btn}>
            {t(locale, 'give.submit')}
          </button>
        </form>
      </div>
    </Base>
  ) : (
    <ContentPage
      title={entry.data.title}
      description={entry.data.description}
      locale={locale}
      translated={translated}
    >
      <Content />
      <Fragment slot="after">
        {givingUrl ? (
          <div>
            <a
              href={givingUrl}
              target="_blank"
              rel="noopener"
              class="inline-block px-6 py-3 rounded-full bg-accent text-on-accent font-semibold hover:bg-accent-hover"
            >
              {t(locale, 'give.ctaButton')}
            </a>
            <p class="mt-3 text-sm text-ink-muted">{t(locale, 'give.ctaNote')}</p>
          </div>
        ) : (
          <p class="rounded-md border border-border bg-surface-sunken px-4 py-3 text-sm text-ink-muted">
            {t(locale, 'give.unavailable')}
          </p>
        )}
      </Fragment>
    </ContentPage>
  )
}
