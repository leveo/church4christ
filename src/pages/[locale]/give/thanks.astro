---
// Giving thank-you page. Reached after a Stripe Checkout redirect. Deliberately
// static: the Stripe webhook is the source of truth for the gift, so this page
// makes no session/Stripe lookup — it just confirms the gift is processing and
// that a receipt arrives by email. Links home and, for a signed-in giver, to
// their giving history. Not module-gated (core /give/thanks path), so it renders
// on any backend; noindex since it's a post-payment landing page.
import Base from '../../../layouts/Base.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { btn, btnSecondary } from '../../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const user = Astro.locals.user;
---

<Base title={t(locale, 'give.thanks.title')} locale={locale} noindex={true}>
  <div class="container-content max-w-xl py-16 text-center">
    <h1 class="font-display text-heading-md font-bold">{t(locale, 'give.thanks.title')}</h1>
    <p class="mt-4 text-ink-muted">{t(locale, 'give.thanks.body')}</p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={localePath(locale, '/')} class={btn}>{t(locale, 'notFound.home')}</a>
      {user && (
        <a href={localePath(locale, '/my/giving')} class={btnSecondary}>
          {t(locale, 'modules.giving.label')}
        </a>
      )}
    </div>
  </div>
</Base>
