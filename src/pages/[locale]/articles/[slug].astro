---
// Single article: title band + author/date byline, prose body, back link.
import { render } from 'astro:content';
import ContentPage from '../../../components/ContentPage.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { formatDate } from '../../../lib/dates';
import { getLocalized } from '../../../lib/content';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const slug = Astro.params.slug ?? '';
const found = await getLocalized('articles', slug, locale);
if (!found) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const { entry, translated } = found;
const { Content } = await render(entry);
---

<ContentPage
  title={entry.data.title}
  description={entry.data.excerpt}
  locale={locale}
  translated={translated}
>
  <span slot="subtitle">
    {t(locale, 'articles.byline', { author: entry.data.author, date: formatDate(entry.data.date, locale) })}
  </span>

  <Content />

  <Fragment slot="after">
    <a
      href={localePath(locale, '/articles')}
      class="text-ink-muted underline decoration-accent underline-offset-2 hover:text-accent"
    >
      {t(locale, 'articles.back')}
    </a>
  </Fragment>
</ContentPage>
