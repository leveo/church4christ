---
// Single fellowship: meeting-info block, then the full description as prose
// paragraphs. DB-driven (member_groups) — replaces the old astro:content
// collection. No members/leaders here (not available on D1; the member portal
// has its own group-roster surface). Unknown/inactive slugs 404.
import Base from '../../../layouts/Base.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { getGroupBySlug, type MemberGroup } from '../../../lib/groupDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const slug = Astro.params.slug ?? '';
let group: MemberGroup | null = null;
try {
  group = await getGroupBySlug(Astro.locals.db, slug, locale);
} catch (err) {
  console.error('fellowship detail: load failed', err);
}
if (!group) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const paragraphs = group.description ? group.description.split(/\n{2,}/) : [];

const meetingParts: string[] = [];
if (group.meeting_weekday !== null) meetingParts.push(t(locale, `admin.children.weekday.${group.meeting_weekday}`));
if (group.meeting_time) meetingParts.push(group.meeting_time);
if (group.meeting_frequency) meetingParts.push(t(locale, `admin.groups.freq.${group.meeting_frequency}`));
if (group.meeting_location) meetingParts.push(group.meeting_location);
const meetingLine = meetingParts.join(' · ');
---

<Base title={group.name} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <a href={localePath(locale, '/fellowships')} class="text-sm font-semibold hover:underline">
        {t(locale, 'fellowships.back')}
      </a>
      <h1 class="mt-4 font-display text-display-lg font-bold">{group.name}</h1>
      {
        meetingParts.length > 0 && (
          <p class="mt-4 text-sm font-semibold uppercase tracking-caps">
            {t(locale, 'fellowships.meets')}: <span class="font-normal">{meetingLine}</span>
          </p>
        )
      }
    </div>
  </div>

  <div class="container-content py-10">
    <article class="prose">
      {paragraphs.map((p) => <p>{p}</p>)}
    </article>
  </div>
</Base>
