---
// Fellowships listing: cards showing name, description excerpt, and a meeting
// line (weekday/time/frequency/location), ordered by sort. DB-driven (member_groups,
// kind='fellowship') — replaces the old astro:content collection.
import Base from '../../../layouts/Base.astro';
import { localePath, parseLocale, type Locale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { listGroups, type MemberGroup } from '../../../lib/groupDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

let fellowships: MemberGroup[] = [];
try {
  fellowships = await listGroups(Astro.locals.db, locale, { kind: 'fellowship' });
} catch (err) {
  console.error('fellowships index: load failed', err);
}

const EXCERPT_LEN = 160;

/** First paragraph of a plain-text description, truncated for the card. */
function excerpt(description: string | null): string | null {
  if (!description) return null;
  const first = description.split(/\n{2,}/)[0].trim();
  return first.length > EXCERPT_LEN ? `${first.slice(0, EXCERPT_LEN).trimEnd()}…` : first;
}

/** "Thursday · 7:00 PM · Weekly · Room 203"-style line, omitting missing fields. */
function meetingLine(g: MemberGroup, loc: Locale): string | null {
  const parts: string[] = [];
  if (g.meeting_weekday !== null) parts.push(t(loc, `admin.children.weekday.${g.meeting_weekday}`));
  if (g.meeting_time) parts.push(g.meeting_time);
  if (g.meeting_frequency) parts.push(t(loc, `admin.groups.freq.${g.meeting_frequency}`));
  if (g.meeting_location) parts.push(g.meeting_location);
  return parts.length > 0 ? parts.join(' · ') : null;
}
---

<Base title={t(locale, 'fellowships.title')} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <h1 class="font-display text-display-lg font-bold">{t(locale, 'fellowships.title')}</h1>
      <p class="mt-3 text-lg">{t(locale, 'fellowships.intro')}</p>
    </div>
  </div>

  <div class="container-content py-10">
    {
      fellowships.length === 0 ? (
        <p class="text-ink-muted">{t(locale, 'fellowships.empty')}</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2">
          {fellowships.map((g) => (
            <a
              href={localePath(locale, `/fellowships/${g.slug}`)}
              class="block bg-surface-raised border border-border rounded-lg p-6 hover:shadow-md hover:border-border-strong transition-shadow"
            >
              <h2 class="font-display text-heading-sm font-semibold">{g.name}</h2>
              {excerpt(g.description) && <p class="mt-2 text-sm text-ink-muted">{excerpt(g.description)}</p>}
              {
                meetingLine(g, locale) && (
                  <p class="mt-4 text-sm">
                    <span class="font-semibold">{t(locale, 'fellowships.meets')}:</span>{' '}
                    <span class="text-ink-muted">{meetingLine(g, locale)}</span>
                  </p>
                )
              }
            </a>
          ))}
        </div>
      )
    }
  </div>
</Base>
