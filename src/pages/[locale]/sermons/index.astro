---
// Sermons archive landing: the latest year's published sermons grouped by month,
// with year-nav pills into /sermons/[year]. DB reads fail soft to empty so a
// database hiccup degrades to the "coming soon" state instead of a 500.
import Base from '../../../layouts/Base.astro';
import SermonMonthGrid from '../../../components/SermonMonthGrid.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { listSermonYears, listSermonsByYear, type SermonRow } from '../../../lib/publicDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

let years: number[] = [];
let sermons: SermonRow[] = [];
try {
  const db = Astro.locals.db;
  years = await listSermonYears(db);
  sermons = years.length ? await listSermonsByYear(db, years[0], locale) : [];
} catch (err) {
  console.error('sermons index: load failed', err);
}
---

<Base title={t(locale, 'sermons.title')} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <h1 class="font-display text-display-lg font-bold">{t(locale, 'sermons.title')}</h1>
      <p class="mt-3 text-lg">{t(locale, 'sermons.intro')}</p>
    </div>
  </div>

  <div class="container-content py-10">
    {
      sermons.length > 0 ? (
        <SermonMonthGrid sermons={sermons} locale={locale} />
      ) : (
        <p class="py-12 text-center text-ink-muted">{t(locale, 'sermons.empty')}</p>
      )
    }
    {
      years.length > 1 && (
        <nav class="mt-8 border-t border-border pt-6" aria-label={t(locale, 'sermons.archive')}>
          <h2 class="mb-3 font-display font-bold">{t(locale, 'sermons.archive')}</h2>
          <div class="flex flex-wrap gap-3">
            {years.slice(1).map((y) => (
              <a
                href={localePath(locale, `/sermons/${y}`)}
                class="inline-flex min-h-11 items-center rounded-full border border-border px-4 py-2 text-sm font-semibold hover:border-border-strong hover:bg-surface-raised"
              >
                {t(locale, 'sermons.yearLabel', { year: y })}
              </a>
            ))}
          </div>
        </nav>
      )
    }
  </div>
</Base>
