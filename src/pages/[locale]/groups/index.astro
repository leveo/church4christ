---
// Public groups directory: every live PUBLIC group (name, description excerpt,
// member count), plus — when signed in — a "My groups" section first, which
// includes PRIVATE memberships too (listGroupsForPerson never filters on
// visibility, only on the viewer's own membership) with an admin badge and a
// link straight to the manage console for groups the viewer administers.
// Owned by the `groups` module — the middleware 404s this route when it's off.
import Base from '../../../layouts/Base.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { listGroupsForPerson, listPublicGroups, type GroupSummary, type PersonGroupRow } from '../../../lib/groupDb';
import { badge, badgeRole, badgeScheduled } from '../../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const db = Astro.locals.db;
const user = Astro.locals.user;

let publicGroups: GroupSummary[] = [];
let myGroups: PersonGroupRow[] = [];
try {
  publicGroups = await listPublicGroups(db);
  if (user) myGroups = await listGroupsForPerson(db, user.id);
} catch (err) {
  console.error('groups index: load failed', err);
}

// A short, plain-text excerpt for the directory card (descriptions are
// member-entered free text, sometimes long).
function excerpt(text: string, max = 140): string {
  const trimmed = text.trim();
  return trimmed.length > max ? `${trimmed.slice(0, max).trimEnd()}…` : trimmed;
}
---

<Base title={t(locale, 'groups.title')} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <h1 class="font-display text-display-lg font-bold">{t(locale, 'groups.title')}</h1>
      <p class="mt-3 text-lg">{t(locale, 'groups.intro')}</p>
    </div>
  </div>

  <div class="container-content py-10">
    {
      user && (
        <section class="mb-10">
          <h2 class="font-display text-heading-sm font-semibold">{t(locale, 'groups.myGroups')}</h2>
          {myGroups.length === 0 ? (
            <p class="mt-2 text-ink-muted">{t(locale, 'groups.myGroupsEmpty')}</p>
          ) : (
            <ul class="mt-4 grid gap-4 sm:grid-cols-2">
              {myGroups.map((g) => (
                <li class="rounded-xl border border-border bg-surface-raised p-5 shadow-sm">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="font-display text-lg font-bold">
                      <a href={localePath(locale, `/groups/${g.id}`)} class="hover:underline">
                        {g.name}
                      </a>
                    </h3>
                    {g.is_admin === 1 && <span class={`${badge} ${badgeRole.admin}`}>{t(locale, 'groups.admin')}</span>}
                  </div>
                  <p class="mt-2 text-sm text-ink-muted">{t(locale, 'groups.memberCount', { n: g.member_count })}</p>
                  {g.is_admin === 1 && (
                    <a
                      href={localePath(locale, `/groups/${g.id}/manage`)}
                      class="mt-3 inline-block text-sm font-semibold text-primary hover:underline"
                    >
                      {t(locale, 'groups.manageLink')} →
                    </a>
                  )}
                </li>
              ))}
            </ul>
          )}
        </section>
      )
    }

    <section>
      <h2 class="font-display text-heading-sm font-semibold">{t(locale, 'groups.directory')}</h2>
      {
        publicGroups.length === 0 ? (
          <p class="mt-2 text-ink-muted">{t(locale, 'groups.empty')}</p>
        ) : (
          <div class="mt-4 grid gap-6 sm:grid-cols-2">
            {publicGroups.map((g) => (
              <a
                href={localePath(locale, `/groups/${g.id}`)}
                class="block rounded-lg border border-border bg-surface-raised p-6 hover:shadow-md hover:border-border-strong transition-shadow"
              >
                <h3 class="font-display text-heading-sm font-semibold">{g.name}</h3>
                {(g.kind === 'sunday_school' || g.term_label) && (
                  <div class="mt-2 flex flex-wrap items-center gap-2">
                    {g.kind === 'sunday_school' && (
                      <span class={`${badge} ${badgeScheduled}`}>{t(locale, 'groups.kind.sunday_school')}</span>
                    )}
                    {g.term_label && <span class="text-xs text-ink-subtle">{g.term_label}</span>}
                  </div>
                )}
                {g.description && <p class="mt-2 text-sm text-ink-muted">{excerpt(g.description)}</p>}
                <p class="mt-4 text-sm font-semibold text-ink-subtle">
                  {t(locale, 'groups.memberCount', { n: g.member_count })}
                </p>
              </a>
            ))}
          </div>
        )
      }
    </section>
  </div>
</Base>
