---
// /my/serving: the member-facing serving hub (Member Portal Phase 3, Task 2).
// Recomposes /my (src/pages/[locale]/my/index.astro)'s pending/upcoming/open-slots
// sections — including its POST handler — under the portal chrome, and adds three
// read-only sections /my doesn't have: my teams (listPersonTeams), full serving
// history (listPersonServingHistory, capped to 20 rows), and my applications
// (listApplicationsByPerson, unconditional here — /my only shows it when it's
// most likely to matter to a space-constrained dashboard).
//
// The accept/decline/claim POST handler is DELIBERATELY duplicated from
// my/index.astro rather than shared: /my must stay self-sufficient (it also runs
// standalone on the D1 backend, without the `portal` module), so its handler
// can't depend on this portal-only page or vice versa. Keep the two in sync by
// hand if the response/claim semantics ever change.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import PortalNav from '../../../components/PortalNav.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { claimOpenSlot, listOpenSlotsForPerson, respondToAssignment } from '../../../lib/planDb';
import { listApplicationsByPerson, listPersonAssignments, listPersonServingHistory, listPersonTeams } from '../../../lib/myDb';
import { formatDate, todayInTz } from '../../../lib/dates';
import { sendDeclineNotice } from '../../../lib/notify';
import { type EmailEnv } from '../../../lib/email';
import { badge, badgeScheduled, btn, btnSecondary, noticeErr, noticeOk, tin } from '../../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const user = Astro.locals.user!;
const db = Astro.locals.db;

const idOf = (v: FormDataEntryValue | null): number | null =>
  /^\d+$/.test(String(v ?? '')) ? Number(v) : null;

let flashKey: string | null = null;
if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('_action');

  if (action === 'accept' || action === 'decline') {
    const assignmentId = idOf(fd.get('assignment_id'));
    if (assignmentId) {
      const reason = String(fd.get('reason') ?? '').trim() || null;
      const result = await respondToAssignment(db, assignmentId, user.id, action, reason);
      if (result.ok && action === 'decline') {
        // Best-effort: notify the team's leaders of the decline.
        await sendDeclineNotice(env as unknown as EmailEnv, db, assignmentId, reason);
      }
    }
    return Astro.redirect(localePath(locale, '/my/serving'), 303);
  }
  if (action === 'claim') {
    const planId = idOf(fd.get('plan_id'));
    const positionId = idOf(fd.get('position_id'));
    if (planId && positionId) {
      const result = await claimOpenSlot(db, { planId, positionId, personId: user.id });
      if (result === 'ok') return Astro.redirect(localePath(locale, '/my/serving?claimed=1'), 303);
      flashKey = {
        not_member: 'serve.plans.claimNotMember',
        closed: 'serve.plans.claimClosed',
        full: 'serve.plans.slotFull',
        taken: 'serve.plans.claimTaken',
        conflict: 'serve.plans.claimConflict',
      }[result];
    }
  }
}

const claimed = Astro.url.searchParams.get('claimed') === '1';
const today = todayInTz();
const [assignments, openSlots, teams, history, applications] = await Promise.all([
  listPersonAssignments(db, user.id, today, locale),
  listOpenSlotsForPerson(db, user.id, locale),
  listPersonTeams(db, user.id, locale),
  listPersonServingHistory(db, user.id, locale),
  listApplicationsByPerson(db, user.id, locale),
]);
const pending = assignments.filter((a) => a.status === 'U');
const upcoming = assignments.filter((a) => a.status === 'C');
const historyRows = history.slice(0, 20);
const appBadge: Record<'P' | 'A' | 'R', string> = {
  P: 'bg-warn-soft text-warn',
  A: 'bg-success-soft text-success',
  R: 'bg-surface-sunken text-ink-muted',
};
---

<Base title={t(locale, 'portal.serving.title')} locale={locale} noindex>
  <div class="container-content max-w-content py-12">
    <h1 class="font-display text-heading-md font-bold">{t(locale, 'portal.serving.title')}</h1>
    <PortalNav locale={locale} active="serving" />

    {claimed && <p class={`mt-4 ${noticeOk}`}>{t(locale, 'serve.plans.claimed')}</p>}
    {flashKey && <p class={`mt-4 ${noticeErr}`}>{t(locale, flashKey)}</p>}

    {
      pending.length > 0 && (
        <section class="mt-8 rounded-lg border border-warn bg-warn-soft p-6">
          <h2 class="font-display text-lg font-semibold text-warn">
            {t(locale, 'my.pending')} ({pending.length})
          </h2>
          <ul class="mt-3 space-y-4">
            {pending.map((a) => (
              <li class="rounded-md border border-border bg-surface-raised p-4">
                <div class="flex flex-wrap items-center gap-2 text-sm">
                  <span class="font-bold tabular-nums">{formatDate(a.plan_date, locale)}</span>
                  <span class="font-medium">{a.position_name}</span>
                  <span class="text-ink-muted">
                    {a.team_name} · {a.service_type_name}
                  </span>
                </div>
                <form method="post" class="mt-3 flex flex-wrap items-center gap-2">
                  <input type="hidden" name="assignment_id" value={a.id} />
                  <button type="submit" name="_action" value="accept" class={btn}>
                    {t(locale, 'my.accept')}
                  </button>
                  <input
                    name="reason"
                    placeholder={t(locale, 'my.declineReason')}
                    aria-label={t(locale, 'my.declineReason')}
                    class={`${tin} max-w-56`}
                  />
                  <button type="submit" name="_action" value="decline" class={btnSecondary}>
                    {t(locale, 'my.decline')}
                  </button>
                </form>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mt-8">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'my.upcoming')}</h2>
      {
        upcoming.length === 0 ? (
          <p class="mt-2 text-sm text-ink-muted">{t(locale, 'my.noUpcoming')}</p>
        ) : (
          <ul class="mt-3 divide-y divide-border rounded-lg border border-border bg-surface-raised">
            {upcoming.map((a) => (
              <li class="flex flex-wrap items-center gap-3 px-4 py-3 text-sm">
                <span class="font-semibold tabular-nums">{formatDate(a.plan_date, locale)}</span>
                <span class="font-medium">{a.position_name}</span>
                <span class="text-ink-muted">
                  {a.team_name} · {a.service_type_name}
                </span>
                <span class="ml-auto">
                  <StatusBadge status={a.status} locale={locale} />
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    {
      openSlots.length > 0 && (
        <section class="mt-8">
          <h2 class="font-display text-lg font-semibold">{t(locale, 'my.openSlots')}</h2>
          <ul class="mt-3 divide-y divide-border rounded-lg border border-border bg-surface-raised">
            {openSlots.map((s) => (
              <li class="flex flex-wrap items-center gap-3 px-4 py-3 text-sm">
                <span class="font-semibold tabular-nums">{formatDate(s.plan_date, locale)}</span>
                <span class="font-medium">{s.position_name}</span>
                <span class="text-ink-muted">
                  {s.team_name} · {s.service_type_name}
                </span>
                <span class="text-xs text-ink-subtle">
                  {s.taken}/{s.needed}
                </span>
                <form method="post" class="ml-auto">
                  <input type="hidden" name="_action" value="claim" />
                  <input type="hidden" name="plan_id" value={s.plan_id} />
                  <input type="hidden" name="position_id" value={s.position_id} />
                  <button type="submit" class={btn}>{t(locale, 'serve.plans.claim')}</button>
                </form>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mt-8">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'portal.serving.myTeams')}</h2>
      {
        teams.length === 0 ? (
          <p class="mt-2 text-sm text-ink-muted">{t(locale, 'portal.serving.myTeamsEmpty')}</p>
        ) : (
          <ul class="mt-3 flex flex-wrap gap-2">
            {teams.map((tm) => (
              <li class="flex items-center gap-1">
                <span class={`${badge} bg-surface-sunken text-ink-muted`}>{tm.name}</span>
                {tm.is_leader === 1 && <span class={`${badge} ${badgeScheduled}`}>{t(locale, 'portal.groups.leader')}</span>}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <section class="mt-8">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'portal.serving.history')}</h2>
      {
        historyRows.length === 0 ? (
          <p class="mt-2 text-sm text-ink-muted">{t(locale, 'portal.serving.historyEmpty')}</p>
        ) : (
          <ul class="mt-3 divide-y divide-border rounded-lg border border-border bg-surface-raised">
            {historyRows.map((h) => (
              <li class="flex flex-wrap items-center gap-3 px-4 py-3 text-sm">
                <span class="font-semibold tabular-nums">{formatDate(h.plan_date, locale)}</span>
                <span class="font-medium">{h.position_name}</span>
                <span class="text-ink-muted">
                  {h.team_name} · {h.service_type_name}
                  {h.ministry_name && ` · ${h.ministry_name}`}
                </span>
                <span class="ml-auto">
                  <StatusBadge status={h.status} locale={locale} />
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <section class="mt-8">
      <h2 class="font-display text-lg font-semibold">{t(locale, 'my.applications')}</h2>
      {
        applications.length === 0 ? (
          <p class="mt-2 text-sm text-ink-muted">{t(locale, 'portal.serving.applicationsEmpty')}</p>
        ) : (
          <ul class="mt-3 space-y-2 text-sm">
            {applications.map((a) => (
              <li class="flex flex-wrap items-center gap-2 rounded-lg border border-border bg-surface-raised px-4 py-3">
                <span class="font-medium">{a.team_name}</span>
                {a.position_name && <span class="text-ink-muted">· {a.position_name}</span>}
                <span class={`ml-auto inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ${appBadge[a.status]}`}>
                  {t(locale, `my.appStatus.${a.status}`)}
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </div>
</Base>
