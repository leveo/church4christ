---
// My Household (member portal, authed + portal module via route policy /
// middleware module gating): the shared family card, per-member profile edit
// (self always; owner for everyone), owner promote/demote, and the signed-in
// member's own email-change flow. Household create/leave/add-dependent stay on
// /profile (spec overlap decision) — this page only links there.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import PortalNav from '../../../components/PortalNav.astro';
import AvatarInitials from '../../../components/AvatarInitials.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { getPortalHousehold, setOwner, updateMemberProfile, type MemberProfilePatch } from '../../../lib/portalDb';
import { requestEmailChange } from '../../../lib/emailChange';
import { sendEmailChangeLink } from '../../../lib/notify';
import { setPersonAvatar } from '../../../lib/adminDb';
import { saveImageUpload, type MediaBucket } from '../../../lib/mediaUpload';
import { normalizeAvatarUrl } from '../../../lib/mediaRef';
import { type EmailEnv } from '../../../lib/email';
import { badge, badgeScheduled, btn, btnSecondary, lab, noticeErr, noticeOk, tin } from '../../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const user = Astro.locals.user!;
const db = Astro.locals.db;
const media = (env as unknown as { MEDIA: MediaBucket }).MEDIA;

const str = (v: FormDataEntryValue | null): string => String(v ?? '').trim();
const idOf = (v: FormDataEntryValue | null): number | null => (/^\d+$/.test(String(v ?? '')) ? Number(v) : null);

// setOwner/updateMemberProfile throw one of a fixed set of error codes; map the
// two a member can realistically hit here to a short ?err= code, everything
// else (not_found/not_authorized/cannot_demote_self — none reachable through
// this page's own UI gating) to a generic fallback. Codes are resolved back
// to i18n keys on GET via ERR_MSG below, symmetric with OK_MSG/?ok=.
const mapMutationErrCode = (e: unknown): string => {
  const msg = e instanceof Error ? e.message : '';
  return msg === 'owner_limit' || msg === 'not_eligible' ? msg : 'generic';
};
const mapUploadErrCode = (e: unknown): string => {
  if (e instanceof Error && e.message === 'image_type') return 'upload_type';
  if (e instanceof Error && e.message === 'image_too_large') return 'upload_too_large';
  return 'upload_bad_request';
};

let household = await getPortalHousehold(db, user.id);

if (Astro.request.method === 'POST' && household) {
  const fd = await Astro.request.formData();
  const action = str(fd.get('_action'));
  const done = (ok: string) => Astro.redirect(localePath(locale, `/my/household?ok=${ok}`), 303);
  const fail = (err: string) => Astro.redirect(localePath(locale, `/my/household?err=${err}`), 303);

  if (action === 'updateProfile') {
    const memberId = idOf(fd.get('member_id'));
    if (memberId !== null) {
      const patch: MemberProfilePatch = {
        first_name: str(fd.get('first_name')),
        last_name: str(fd.get('last_name')),
        display_name: str(fd.get('display_name')),
        phone: str(fd.get('phone')) || null,
        birthday: str(fd.get('birthday')) || null,
        address: str(fd.get('address')) || null,
      };
      const roleRaw = fd.get('dependent_role');
      const dependentRole = roleRaw === 'child' ? 'child' : roleRaw === 'adult' ? 'adult' : undefined;
      try {
        await updateMemberProfile(db, { actorPersonId: user.id, isAdmin: false, memberId, patch, dependentRole });
        return done('profile');
      } catch (e) {
        return fail(mapMutationErrCode(e));
      }
    }
  } else if (action === 'setOwner' || action === 'unsetOwner') {
    const memberId = idOf(fd.get('member_id'));
    if (memberId !== null) {
      try {
        await setOwner(db, {
          householdId: household.id,
          memberId,
          isOwner: action === 'setOwner',
          actorPersonId: user.id,
          isAdmin: false,
        });
        return done('owner');
      } catch (e) {
        return fail(mapMutationErrCode(e));
      }
    }
  } else if (action === 'requestEmailChange') {
    const result = await requestEmailChange(db, user.id, str(fd.get('new_email')));
    if ('error' in result) {
      return fail(
        { invalid: 'email_invalid', taken: 'email_taken', rate_limited: 'email_rate_limited' }[result.error] ?? 'generic',
      );
    } else {
      await sendEmailChangeLink(
        env as unknown as EmailEnv,
        db,
        { id: user.id, email: user.email, display_name: user.displayName, lang: user.lang },
        result.raw,
        result.newEmail,
        locale,
      );
      return done('emailChange');
    }
  } else if (action === 'avatar') {
    const memberId = idOf(fd.get('member_id'));
    const target = household.members.find((m) => m.id === memberId);
    const targetPersonId = target?.person_id ?? null;
    const authorized = targetPersonId !== null && (targetPersonId === user.id || household.viewerIsOwner);
    if (!authorized || targetPersonId === null) {
      return fail('generic');
    }
    const avatarFile = fd.get('avatar');
    let avatarKey: string | null = null;
    if (avatarFile instanceof File && avatarFile.size > 0) {
      try {
        avatarKey = await saveImageUpload({ db, media, file: avatarFile, uploadedBy: user.email });
      } catch (e) {
        return fail(mapUploadErrCode(e));
      }
    }
    if (avatarKey) {
      await setPersonAvatar(db, targetPersonId, `/media/${avatarKey}`);
      return done('avatar');
    }
    if (fd.get('remove_avatar')) {
      await setPersonAvatar(db, targetPersonId, null);
      return done('avatar');
    }
    // No file chosen and no removal requested: a no-op, not a save.
    return Astro.redirect(localePath(locale, '/my/household'), 303);
  }

  // Invalid/missing member_id on updateProfile/setOwner (unreachable through
  // this page's own UI) falls through and re-renders the current, unchanged
  // household state.
  household = await getPortalHousehold(db, user.id);
}

// Extra people-row fields (name/contact/email) for every LINKED member, keyed
// by person_id — getPortalHousehold's members only carry display_name/role/
// owner flags, and the self card additionally needs email + pending_email.
interface MemberProfileRow {
  id: number;
  first_name: string;
  last_name: string;
  phone: string | null;
  birthday: string | null;
  address: string | null;
  email: string;
  pending_email: string | null;
  avatar_url: string | null;
}
const profileByPersonId = new Map<number, MemberProfileRow>();
if (household) {
  const linkedIds = household.members.filter((m) => m.person_id !== null).map((m) => m.person_id as number);
  if (linkedIds.length > 0) {
    const { results } = await db
      .prepare(
        `SELECT id, first_name, last_name, phone, birthday, address, email, pending_email, avatar_url
         FROM people WHERE id IN (${linkedIds.map(() => '?').join(', ')}) AND deleted_at IS NULL`,
      )
      .bind(...linkedIds)
      .all<MemberProfileRow>();
    for (const row of results) profileByPersonId.set(row.id, row);
  }
}
const selfProfile = profileByPersonId.get(user.id) ?? null;
const ownerCount = household?.members.filter((m) => m.is_owner === 1).length ?? 0;

const okParam = Astro.url.searchParams.get('ok');
const OK_MSG: Record<string, string> = {
  profile: 'portal.household.profileSaved',
  owner: 'portal.household.ownerUpdated',
  avatar: 'portal.household.avatarSaved',
  emailChange: 'portal.household.emailChangeSent',
};
const okKey = okParam ? (OK_MSG[okParam] ?? null) : null;

const errParam = Astro.url.searchParams.get('err');
const ERR_MSG: Record<string, string> = {
  owner_limit: 'portal.owner.errLimit',
  not_eligible: 'portal.owner.errNotEligible',
  email_invalid: 'errors.emailInvalid',
  email_taken: 'errors.emailTaken',
  email_rate_limited: 'portal.household.emailChangeErrRateLimited',
  upload_type: 'errors.imageType',
  upload_too_large: 'errors.imageTooLarge',
  upload_bad_request: 'admin.form.badRequest',
  generic: 'portal.household.errGeneric',
};
const errKey = errParam ? (ERR_MSG[errParam] ?? null) : null;
---

<Base title={t(locale, 'portal.household.title')} locale={locale} noindex>
  <div class="container-content max-w-content py-12">
    <h1 class="font-display text-heading-md font-bold">{t(locale, 'portal.household.title')}</h1>
    <PortalNav locale={locale} active="household" />

    {okKey && <p class={`mt-6 ${noticeOk}`}>{t(locale, okKey)}</p>}
    {errKey && <p class={`mt-6 ${noticeErr}`}>{t(locale, errKey)}</p>}

    {
      !household ? (
        <div class="mt-6 rounded-lg border border-border bg-surface-raised p-6 text-center">
          <p class="text-sm text-ink-muted">{t(locale, 'portal.household.emptyBody')}</p>
          <a href={localePath(locale, '/profile')} class={`mt-4 inline-flex ${btn}`}>
            {t(locale, 'portal.household.manageLink')}
          </a>
        </div>
      ) : (
        <>
          <section class="mt-6 rounded-lg border border-border bg-surface-raised p-6">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="font-semibold">{household.name}</p>
                {household.address && <p class="mt-0.5 text-sm text-ink-muted">{household.address}</p>}
                {household.phone && <p class="text-sm text-ink-muted">{household.phone}</p>}
              </div>
              <a href={localePath(locale, '/profile')} class="text-sm font-semibold text-primary hover:underline">
                {t(locale, 'portal.household.manageLink')}
              </a>
            </div>

            {ownerCount === 0 && <p class={`mt-4 ${noticeErr}`}>{t(locale, 'portal.household.ownerless')}</p>}

            <div class="mt-6">
              <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">{t(locale, 'profile.household.members')}</p>
              <ul class="mt-3 flex flex-col gap-3">
                {household.members.map((m) => {
                  const canEdit = m.person_id === user.id || household!.viewerIsOwner;
                  const mp = m.person_id !== null ? profileByPersonId.get(m.person_id) ?? null : null;
                  const canPromote = household!.viewerIsOwner && m.role === 'adult' && m.person_id !== null && m.is_owner !== 1;
                  const canDemote = household!.viewerIsOwner && m.is_owner === 1 && m.person_id !== user.id;
                  return (
                    <li class="rounded-md border border-border p-4">
                      <div class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="font-medium">{m.display_name}</span>
                        <span class="rounded-full bg-surface-sunken px-2 py-0.5 text-xs text-ink-muted">
                          {t(locale, m.role === 'child' ? 'profile.household.roleChild' : 'profile.household.roleAdult')}
                        </span>
                        {m.is_owner === 1 && <span class={`${badge} ${badgeScheduled}`}>{t(locale, 'portal.owner')}</span>}
                        {m.person_id === user.id && (
                          <span class="rounded-full bg-accent-soft px-2 py-0.5 text-xs font-semibold text-on-accent-soft">
                            {t(locale, 'profile.household.you')}
                          </span>
                        )}
                        <span class="ml-auto flex items-center gap-2">
                          {canPromote && (
                            <form method="post">
                              <input type="hidden" name="_action" value="setOwner" />
                              <input type="hidden" name="member_id" value={m.id} />
                              <button type="submit" class="text-xs font-semibold text-primary hover:underline">
                                {t(locale, 'portal.owner.set')}
                              </button>
                            </form>
                          )}
                          {canDemote && (
                            <form method="post">
                              <input type="hidden" name="_action" value="unsetOwner" />
                              <input type="hidden" name="member_id" value={m.id} />
                              <button type="submit" class="text-xs font-semibold text-primary hover:underline">
                                {t(locale, 'portal.owner.unset')}
                              </button>
                            </form>
                          )}
                        </span>
                      </div>

                      {canEdit && (
                        <details class="mt-3">
                          <summary class="cursor-pointer text-xs font-semibold text-primary">
                            {t(locale, 'portal.household.editProfile')}
                          </summary>
                          <div class="mt-3 flex flex-col gap-4">
                            {m.person_id !== null && (
                              <form method="post" enctype="multipart/form-data" class="flex flex-wrap items-center gap-3">
                                <input type="hidden" name="_action" value="avatar" />
                                <input type="hidden" name="member_id" value={m.id} />
                                {mp?.avatar_url ? (
                                  <img
                                    src={normalizeAvatarUrl(mp.avatar_url) ?? ''}
                                    alt=""
                                    class="h-12 w-12 rounded-full border border-border object-cover"
                                  />
                                ) : (
                                  <AvatarInitials name={m.display_name} sizeClass="h-12 w-12 text-sm" />
                                )}
                                <input
                                  type="file"
                                  name="avatar"
                                  accept="image/png,image/jpeg,image/webp,image/gif"
                                  class={`${tin} max-w-64 text-xs file:mr-2 file:rounded-md file:border-0 file:bg-primary file:px-2 file:py-1 file:text-xs file:font-semibold file:text-on-primary`}
                                />
                                {mp?.avatar_url && (
                                  <label class="flex items-center gap-1 text-xs">
                                    <input type="checkbox" name="remove_avatar" />
                                    {t(locale, 'profile.removeAvatar')}
                                  </label>
                                )}
                                <button type="submit" class={btnSecondary}>
                                  {t(locale, 'profile.changeAvatar')}
                                </button>
                              </form>
                            )}

                            <form method="post" class="grid gap-3 sm:grid-cols-2">
                              <input type="hidden" name="_action" value="updateProfile" />
                              <input type="hidden" name="member_id" value={m.id} />
                              {m.person_id !== null ? (
                                <>
                                  <label class="block sm:col-span-2">
                                    <span class={lab}>{t(locale, 'profile.name')}</span>
                                    <input name="display_name" required value={m.display_name} class={tin} />
                                  </label>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.firstName')}</span>
                                    <input name="first_name" value={mp?.first_name ?? ''} class={tin} />
                                  </label>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.lastName')}</span>
                                    <input name="last_name" value={mp?.last_name ?? ''} class={tin} />
                                  </label>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.phone')}</span>
                                    <input name="phone" value={mp?.phone ?? ''} class={tin} />
                                  </label>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.birthday')}</span>
                                    <input type="date" name="birthday" value={mp?.birthday ?? ''} class={tin} />
                                  </label>
                                  <label class="block sm:col-span-2">
                                    <span class={lab}>{t(locale, 'profile.address')}</span>
                                    <input name="address" value={mp?.address ?? ''} class={tin} />
                                  </label>
                                </>
                              ) : (
                                <>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.household.dependentName')}</span>
                                    <input name="display_name" required value={m.display_name} class={tin} />
                                  </label>
                                  <label class="block">
                                    <span class={lab}>{t(locale, 'profile.household.role')}</span>
                                    <select name="dependent_role" class={tin}>
                                      <option value="adult" selected={m.role === 'adult'}>
                                        {t(locale, 'profile.household.roleAdult')}
                                      </option>
                                      <option value="child" selected={m.role === 'child'}>
                                        {t(locale, 'profile.household.roleChild')}
                                      </option>
                                    </select>
                                  </label>
                                </>
                              )}
                              <div class="sm:col-span-2">
                                <button type="submit" class={btn}>
                                  {t(locale, 'profile.save')}
                                </button>
                              </div>
                            </form>
                          </div>
                        </details>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          </section>

          <section class="mt-8 rounded-lg border border-border bg-surface-raised p-6">
            <h2 class="font-display text-lg font-semibold">{t(locale, 'portal.household.selfTitle')}</h2>
            <p class="mt-3 text-sm">
              <span class={lab}>{t(locale, 'profile.email')}</span>
              {selfProfile?.email}
            </p>
            {selfProfile?.pending_email && (
              <p class={`mt-2 ${noticeOk}`}>
                {t(locale, 'portal.household.pendingEmail', { email: selfProfile.pending_email })}
              </p>
            )}
            <form method="post" class="mt-4 flex flex-wrap items-end gap-3">
              <input type="hidden" name="_action" value="requestEmailChange" />
              <label class="block">
                <span class={lab}>{t(locale, 'portal.household.newEmail')}</span>
                <input type="email" name="new_email" required class={tin} />
              </label>
              <button type="submit" class={btn}>
                {t(locale, 'portal.household.emailChangeSubmit')}
              </button>
            </form>
            <p class="mt-2 text-xs text-ink-muted">{t(locale, 'portal.household.emailChangeHint')}</p>
          </section>
        </>
      )
    }
  </div>
</Base>
