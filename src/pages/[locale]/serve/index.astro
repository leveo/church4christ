---
// Volunteer landing: hero, a three-step "how it works", the full ministry grid
// (with open-role badges), a published-testimonies strip, and a closing CTA
// band. Every DB read fails soft to empty so the page degrades gracefully (empty
// grid, hidden testimonies strip) instead of 500ing; all copy is dictionary-driven.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import SectionTitle from '../../../components/SectionTitle.astro';
import MinistryCard from '../../../components/MinistryCard.astro';
import AvatarInitials from '../../../components/AvatarInitials.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { listMinistries } from '../../../lib/db';
import { listPublishedTestimonies, type TestimonyCardRow } from '../../../lib/ministryDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

let ministries: Awaited<ReturnType<typeof listMinistries>> = [];
let testimonies: TestimonyCardRow[] = [];
try {
  const db = (env as { DB: D1Database }).DB;
  [ministries, testimonies] = await Promise.all([
    listMinistries(db, locale),
    listPublishedTestimonies(db, locale, 3),
  ]);
} catch (err) {
  console.error('serve landing: load failed', err);
}

const steps = [1, 2, 3].map((n) => ({
  n,
  title: t(locale, `serve.step${n}Title`),
  body: t(locale, `serve.step${n}Body`),
}));
---

<Base title={t(locale, 'serve.title')} locale={locale}>
  <section class="bg-primary text-on-primary">
    <div class="container-content py-20 text-center">
      <p class="text-sm font-semibold uppercase tracking-caps text-accent">{t(locale, 'serve.heroEyebrow')}</p>
      <h1 class="mx-auto mt-3 max-w-narrow font-display text-display-2xl font-bold">{t(locale, 'serve.heroTitle')}</h1>
      <p class="mx-auto mt-5 max-w-narrow text-lg">{t(locale, 'serve.heroBody')}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href={localePath(locale, '/serve/apply')}
          class="inline-flex min-h-11 items-center rounded-full bg-accent px-6 py-2.5 text-sm font-semibold text-on-accent hover:bg-accent-hover"
        >
          {t(locale, 'serve.ctaApply')}
        </a>
        <a
          href={localePath(locale, '/serve/gifts')}
          class="inline-flex min-h-11 items-center rounded-full border border-on-primary px-6 py-2.5 text-sm font-semibold hover:bg-primary-hover"
        >
          {t(locale, 'serve.ctaGifts')}
        </a>
      </div>
    </div>
  </section>

  <section class="bg-surface-sunken py-16">
    <div class="container-content">
      <SectionTitle eyebrow={t(locale, 'serve.howEyebrow')} title={t(locale, 'serve.howTitle')} align="center" />
      <div class="mx-auto mt-10 grid max-w-content gap-8 sm:grid-cols-3">
        {
          steps.map((s) => (
            <div class="text-center">
              <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary font-display text-lg font-bold text-on-primary">
                {s.n}
              </span>
              <h3 class="mt-4 font-display text-lg font-semibold">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">{s.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-content py-16">
    <SectionTitle
      eyebrow={t(locale, 'serve.ministriesEyebrow')}
      title={t(locale, 'serve.ministriesTitle')}
      subtitle={t(locale, 'serve.ministriesSub')}
    />
    {
      ministries.length > 0 && (
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {ministries.map((m) => (
            <MinistryCard
              icon={m.icon}
              name={m.name}
              intro={m.intro}
              slug={m.slug}
              locale={locale}
              openSlots={m.openSignupSlots}
            />
          ))}
        </div>
      )
    }
    <div class="mt-8">
      <a
        href={localePath(locale, '/ministries')}
        class="text-sm font-semibold text-accent hover:text-accent-hover"
      >
        {t(locale, 'ministries.title')} →
      </a>
    </div>
  </section>

  {
    testimonies.length > 0 && (
      <section class="bg-surface-sunken py-16">
        <div class="container-content">
          <SectionTitle
            eyebrow={t(locale, 'serve.testimoniesEyebrow')}
            title={t(locale, 'serve.testimoniesTitle')}
            align="center"
          />
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            {testimonies.map((ti) => (
              <article class="flex flex-col rounded-lg border border-border bg-surface-raised p-6">
                {ti.locale !== locale && (
                  <span class="self-start rounded-full bg-info-soft px-2 py-0.5 text-xs font-semibold text-info">
                    {t(locale, `locale.${ti.locale}`)}
                  </span>
                )}
                <h3 class="mt-2 font-display text-lg font-semibold">{ti.title}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-muted">{ti.body}</p>
                <div class="mt-4 flex items-center gap-3">
                  <AvatarInitials name={ti.authorName} sizeClass="w-9 h-9 text-sm" />
                  <p class="text-sm font-semibold">{ti.authorName}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="container-content py-16">
    <div class="rounded-lg bg-primary p-10 text-center text-on-primary">
      <h2 class="font-display text-heading-md font-bold">{t(locale, 'serve.bandTitle')}</h2>
      <p class="mx-auto mt-3 max-w-narrow">{t(locale, 'serve.bandBody')}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={localePath(locale, '/serve/apply')}
          class="inline-flex min-h-11 items-center rounded-full bg-accent px-6 py-2.5 text-sm font-semibold text-on-accent hover:bg-accent-hover"
        >
          {t(locale, 'serve.ctaApply')}
        </a>
        <a
          href={localePath(locale, '/signin')}
          class="inline-flex min-h-11 items-center rounded-full border border-on-primary px-6 py-2.5 text-sm font-semibold hover:bg-primary-hover"
        >
          {t(locale, 'serve.ctaSignin')}
        </a>
      </div>
    </div>
  </section>
</Base>
