---
// Testimonies — PUBLIC (route policy exact match). Shows approved testimonies
// (locale-first, other-locale rows badged) with full bodies (long ones fold into
// a <details>), and a submit form that files a PENDING testimony for review. A
// name is optional (blank → "Anonymous 匿名"); title + body are required. The
// row's locale is the current page locale. A honeypot field silently absorbs
// bots. Signed-in visitors get their name prefilled and their person_id linked.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import AvatarInitials from '../../../components/AvatarInitials.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import { listPublishedTestimonies, type TestimonyCardRow } from '../../../lib/ministryDb';
import { submitTestimony } from '../../../lib/testimonyDb';
import { btn, lab, tin } from '../../../lib/adminUi';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}
const user = Astro.locals.user;
const db = (env as { DB: D1Database }).DB;
const ANON = 'Anonymous 匿名';
const MAX_BODY = 5000;

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  // Honeypot: bots fill the hidden field; land on the same success state, do nothing.
  if (String(fd.get('website') ?? '') !== '') {
    return Astro.redirect(localePath(locale, '/serve/testimonies?sent=1'), 303);
  }
  const title = String(fd.get('title') ?? '').trim().slice(0, 200);
  const body = String(fd.get('body') ?? '').trim().slice(0, MAX_BODY);
  const name = (user?.displayName ?? String(fd.get('name') ?? '')).trim().slice(0, 120) || ANON;
  if (title && body) {
    await submitTestimony(db, {
      person_id: user?.id ?? null,
      author_name: name,
      locale,
      title,
      body,
      category: null,
    });
    return Astro.redirect(localePath(locale, '/serve/testimonies?sent=1'), 303);
  }
}

const sent = Astro.url.searchParams.has('sent');
let published: TestimonyCardRow[] = [];
try {
  published = await listPublishedTestimonies(db, locale, 100);
} catch (err) {
  console.error('testimonies: load failed', err);
}
const isLong = (s: string) => [...s].length > 320;
const preview = (s: string) => [...s].slice(0, 200).join('') + '…';
const dateOf = (t: TestimonyCardRow) => (t.publishedAt ?? '').slice(0, 10);
---

<Base title={t(locale, 'serve.testimonies.title')} locale={locale}>
  <section class="bg-primary text-on-primary">
    <div class="container-content max-w-content py-14 text-center">
      <p class="text-sm font-semibold uppercase tracking-caps text-accent">{t(locale, 'serve.testimonies.eyebrow')}</p>
      <h1 class="mt-3 font-display text-display-xl font-bold">{t(locale, 'serve.testimonies.title')}</h1>
      <p class="mx-auto mt-4 max-w-narrow">{t(locale, 'serve.testimonies.intro')}</p>
    </div>
  </section>

  <div class="container-content max-w-content py-12">
    {
      published.length === 0 ? (
        <p class="rounded-md border border-border bg-surface-raised px-4 py-10 text-center text-ink-muted">
          {t(locale, 'serve.testimonies.none')}
        </p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2">
          {published.map((ti) => (
            <article class="flex flex-col rounded-lg border border-border bg-surface-raised p-6">
              {ti.locale !== locale && (
                <span class="mb-2 self-start rounded-full bg-info-soft px-2 py-0.5 text-xs font-semibold text-info">
                  {t(locale, `locale.${ti.locale}`)}
                </span>
              )}
              <h2 class="font-display text-lg font-semibold">{ti.title}</h2>
              {isLong(ti.body) ? (
                <details class="group mt-2">
                  <summary class="cursor-pointer list-none text-sm leading-relaxed text-ink-muted">
                    <span class="group-open:hidden">{preview(ti.body)} </span>
                    <span class="text-xs font-semibold text-primary group-open:hidden">
                      {t(locale, 'serve.testimonies.readMore')}
                    </span>
                    <span class="hidden whitespace-pre-wrap group-open:inline">{ti.body}</span>
                  </summary>
                </details>
              ) : (
                <p class="mt-2 whitespace-pre-wrap text-sm leading-relaxed text-ink-muted">{ti.body}</p>
              )}
              <div class="mt-4 flex items-center gap-3">
                <AvatarInitials name={ti.authorName} sizeClass="w-9 h-9 text-sm" />
                <div>
                  <p class="text-sm font-semibold">{ti.authorName}</p>
                  {dateOf(ti) && <p class="text-xs text-ink-subtle">{dateOf(ti)}</p>}
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }

    <section class="mx-auto mt-14 max-w-xl rounded-lg border border-border bg-surface-raised p-8">
      <h2 class="font-display text-heading-sm font-bold">{t(locale, 'serve.testimonies.shareTitle')}</h2>
      {
        sent ? (
          <p class="mt-4 rounded-md border border-success bg-success-soft p-4 text-success">
            {t(locale, 'serve.testimonies.sent')}
          </p>
        ) : (
          <>
            <p class="mt-1.5 text-sm text-ink-muted">{t(locale, 'serve.testimonies.shareIntro')}</p>
            <form method="post" class="mt-5 space-y-4">
              {/* Honeypot: hidden from humans, tempting for bots. */}
              <div aria-hidden="true" style="position:absolute;left:-9999px" tabindex="-1">
                <label>
                  Website
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <label class="block">
                <span class={lab}>
                  {t(locale, 'serve.testimonies.name')} ({t(locale, 'my.optional')})
                </span>
                <input name="name" value={user?.displayName ?? ''} class={tin} />
              </label>
              <label class="block">
                <span class={lab}>{t(locale, 'serve.testimonies.titleField')} *</span>
                <input name="title" required class={tin} />
              </label>
              <label class="block">
                <span class={lab}>{t(locale, 'serve.testimonies.body')} *</span>
                <textarea name="body" rows="6" required maxlength={MAX_BODY} class={`${tin} leading-relaxed`} />
              </label>
              <button type="submit" class={btn}>{t(locale, 'serve.testimonies.submit')}</button>
            </form>
          </>
        )
      }
    </section>
  </div>
</Base>
