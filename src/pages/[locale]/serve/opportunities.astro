---
// Opportunity board — PUBLIC, gated by the `serve` module (owned by the /serve
// route prefix, so the middleware 404s it when serve is off). Two sections
// (spec addendum §B.2): (a) teams accepting applications, and (b) upcoming open
// self-signup dates. Both link to the existing /serve/apply?team=<id> flow.
// Every DB read fails soft to empty so a database hiccup degrades to the
// localized empty states instead of 500ing.
import { env } from 'cloudflare:workers';
import Base from '../../../layouts/Base.astro';
import SectionTitle from '../../../components/SectionTitle.astro';
import { localePath, parseLocale } from '../../../lib/locales';
import { t } from '../../../lib/i18n';
import {
  listApplicationTeams,
  listOpportunitySlots,
  type ApplicationTeam,
  type OpportunityTeam,
} from '../../../lib/opportunityDb';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

let teams: ApplicationTeam[] = [];
let slots: OpportunityTeam[] = [];
try {
  const db = (env as { DB: D1Database }).DB;
  [teams, slots] = await Promise.all([listApplicationTeams(db, locale), listOpportunitySlots(db, locale)]);
} catch (err) {
  console.error('opportunity board: load failed', err);
}

const applyHref = (teamId: number) => localePath(locale, `/serve/apply?team=${teamId}`);
const chip = 'inline-flex items-center rounded-full bg-primary-soft px-2.5 py-1 text-xs font-semibold text-on-primary-soft';
const applyBtn =
  'inline-flex min-h-11 items-center rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-on-accent hover:bg-accent-hover';
---

<Base title={t(locale, 'opportunities.title')} locale={locale}>
  <div class="bg-primary-soft text-on-primary-soft">
    <div class="container-content py-12">
      <h1 class="font-display text-display-lg font-bold">{t(locale, 'opportunities.title')}</h1>
      <p class="mt-3 max-w-narrow text-lg">{t(locale, 'opportunities.intro')}</p>
    </div>
  </div>

  <div class="container-content py-12">
    <section>
      <SectionTitle title={t(locale, 'opportunities.teamsTitle')} subtitle={t(locale, 'opportunities.teamsIntro')} />
      {
        teams.length === 0 ? (
          <p class="mt-8 rounded-md border border-border bg-surface-raised px-4 py-10 text-center text-ink-muted">
            {t(locale, 'opportunities.teamsEmpty')}
          </p>
        ) : (
          <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {teams.map((tm) => (
              <article class="flex flex-col rounded-lg border border-border bg-surface-raised p-6">
                {tm.ministry_name && (
                  <p class="text-sm font-semibold text-ink-muted">
                    {tm.ministry_icon && <span class="mr-1.5">{tm.ministry_icon}</span>}
                    {tm.ministry_name}
                  </p>
                )}
                <h3 class="mt-1 font-display text-lg font-semibold">{tm.team_name}</h3>
                {tm.positions.length > 0 && (
                  <div class="mt-3">
                    <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">
                      {t(locale, 'opportunities.positions')}
                    </p>
                    <ul class="mt-1.5 flex flex-wrap gap-1.5">
                      {tm.positions.map((p) => (
                        <li class={chip}>{p}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {tm.leader_count > 0 && (
                  <p class="mt-3 text-sm text-ink-muted">
                    {t(locale, 'opportunities.leaders').replace('{count}', String(tm.leader_count))}
                  </p>
                )}
                <div class="mt-4 flex-1" />
                <a href={applyHref(tm.team_id)} class={applyBtn}>
                  {t(locale, 'opportunities.apply')}
                </a>
              </article>
            ))}
          </div>
        )
      }
    </section>

    <section class="mt-16">
      <SectionTitle title={t(locale, 'opportunities.slotsTitle')} subtitle={t(locale, 'opportunities.slotsIntro')} />
      {
        slots.length === 0 ? (
          <p class="mt-8 rounded-md border border-border bg-surface-raised px-4 py-10 text-center text-ink-muted">
            {t(locale, 'opportunities.slotsEmpty')}
          </p>
        ) : (
          <div class="mt-8 flex flex-col gap-6">
            {slots.map((tm) => (
              <article class="rounded-lg border border-border bg-surface-raised p-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    {tm.ministry_name && (
                      <p class="text-sm font-semibold text-ink-muted">
                        {tm.ministry_icon && <span class="mr-1.5">{tm.ministry_icon}</span>}
                        {tm.ministry_name}
                      </p>
                    )}
                    <h3 class="mt-1 font-display text-lg font-semibold">{tm.team_name}</h3>
                  </div>
                  <a href={applyHref(tm.team_id)} class={applyBtn}>
                    {t(locale, 'opportunities.apply')}
                  </a>
                </div>
                <div class="mt-4 flex flex-col gap-3">
                  {tm.positions.map((pos) => (
                    <div>
                      <p class="text-sm font-semibold">{pos.position_name}</p>
                      <ul class="mt-1.5 flex flex-wrap gap-2">
                        {pos.dates.map((d) => (
                          <li class="inline-flex items-center gap-2 rounded-md border border-border bg-surface px-3 py-1.5 text-sm">
                            <span class="font-medium">{d.plan_date}</span>
                            <span class="text-ink-muted">· {d.service_type_name}</span>
                            <span class="rounded-full bg-accent-soft px-2 py-0.5 text-xs font-semibold text-on-accent-soft">
                              {t(locale, 'opportunities.spotsOpen').replace('{count}', String(d.remaining))}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        )
      }
    </section>

    <div class="mt-12">
      <a href={localePath(locale, '/serve')} class="text-sm font-semibold text-accent hover:text-accent-hover">
        ← {t(locale, 'opportunities.backToServe')}
      </a>
    </div>
  </div>
</Base>
