---
// Self-service sign-up (groups module): first/last name + email, honeypot copied
// from signin.astro. An existing (live) email just gets a fresh magic link; a new
// email creates a minimal people row (role 'member', active 1, membership_status
// 'visitor', display_name "First Last", lang = the locale they signed up in) then
// gets the same magic link. EVERY outcome — honeypot, existing account, brand new
// account, even a DB hiccup — renders the identical neutral "check your email"
// confirmation (anti-enumeration: a response can never reveal whether an email
// was already registered). Owned by the `groups` module — the middleware 404s
// this route when the module is off.
import { env } from 'cloudflare:workers';
import Base from '../../layouts/Base.astro';
import { t } from '../../lib/i18n';
import { localePath, parseLocale } from '../../lib/locales';
import { getPersonByEmail } from '../../lib/db';
import { sendMagicLink } from '../../lib/notify';
import { isUniqueViolation } from '../../lib/adminDb';
import { btn, lab, tin } from '../../lib/adminUi';
import type { EmailEnv } from '../../lib/email';

const locale = parseLocale(Astro.params.locale ?? '');
if (!locale) {
  Astro.response.status = 404;
  return Astro.rewrite('/404');
}

const vars = env as unknown as EmailEnv;
const db = Astro.locals.db;
let sent = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const honeypot = String(form.get('website') ?? '').trim();
  const firstName = String(form.get('first_name') ?? '').trim();
  const lastName = String(form.get('last_name') ?? '').trim();
  const email = String(form.get('email') ?? '').trim().toLowerCase();

  if (honeypot) {
    // A bot filled the hidden field. Pretend success; do nothing.
    sent = true;
  } else if (email && firstName) {
    try {
      let person = await getPersonByEmail(db, email);
      if (!person) {
        const displayName = [firstName, lastName].filter(Boolean).join(' ') || email;
        try {
          await db
            .prepare(
              `INSERT INTO people (first_name, last_name, display_name, email, role, active, membership_status, lang)
               VALUES (?1, ?2, ?3, ?4, 'member', 1, 'visitor', ?5)`,
            )
            .bind(firstName, lastName, displayName, email, locale)
            .run();
        } catch (e) {
          // Pre-check ↔ INSERT race on the UNIQUE(email) column: someone signed
          // up with this email concurrently — fall through to re-read their row.
          if (!isUniqueViolation(e)) throw e;
        }
        person = await getPersonByEmail(db, email);
      }
      if (person) await sendMagicLink(vars, db, person, locale);
    } catch (e) {
      console.error('signup failure', e);
    }
    sent = true;
  }
}
---

<Base title={t(locale, 'signup.title')} locale={locale} noindex>
  <section class="container-narrow py-16">
    {
      sent ? (
        <div class="bg-surface-raised border border-border rounded-lg p-6">
          <h1 class="font-display text-heading-sm font-semibold">{t(locale, 'signup.sentTitle')}</h1>
          <p class="mt-3 text-ink-muted">{t(locale, 'signup.sentBody')}</p>
        </div>
      ) : (
        <>
          <h1 class="font-display text-heading-md font-bold">{t(locale, 'signup.title')}</h1>
          <p class="mt-3 text-ink-muted">{t(locale, 'signup.intro')}</p>
          <form method="post" class="mt-6 space-y-4">
            {/* Honeypot: hidden from humans, tempting to bots. A filled value is
                treated as spam. Off-screen rather than display:none so more bots trip it. */}
            <div aria-hidden="true" style="position:absolute;left:-9999px" tabindex="-1">
              <label>
                Website
                <input type="text" name="website" tabindex="-1" autocomplete="off" />
              </label>
            </div>
            <label class="block">
              <span class={lab}>{t(locale, 'signup.firstName')}</span>
              <input name="first_name" required autocomplete="given-name" class={tin} />
            </label>
            <label class="block">
              <span class={lab}>{t(locale, 'signup.lastName')}</span>
              <input name="last_name" autocomplete="family-name" class={tin} />
            </label>
            <label class="block">
              <span class={lab}>{t(locale, 'signup.emailLabel')}</span>
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder={t(locale, 'signup.emailPlaceholder')}
                class={tin}
              />
            </label>
            <button type="submit" class={`${btn} w-full justify-center`}>
              {t(locale, 'signup.submit')}
            </button>
          </form>
          <p class="mt-4 text-sm text-ink-muted">
            {t(locale, 'signup.haveAccount')}{' '}
            <a href={localePath(locale, '/signin')} class="font-semibold text-primary hover:underline">
              {t(locale, 'signup.signIn')}
            </a>
          </p>
        </>
      )
    }
  </section>
</Base>
