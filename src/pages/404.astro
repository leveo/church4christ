---
// Localized not-found page. locals.locale is set by middleware (default 'en').
import Base from '../layouts/Base.astro';
import { localePath } from '../lib/locales';
import { t } from '../lib/i18n';

const locale = Astro.locals.locale;
---

<Base title={t(locale, 'notFound.title')} locale={locale} noindex>
  <section class="container-content py-24 text-center">
    <p class="font-display text-display-2xl font-bold text-primary">404</p>
    <h1 class="mt-4 font-display text-heading-md font-semibold">{t(locale, 'notFound.title')}</h1>
    <p class="mt-2 text-ink-muted">{t(locale, 'notFound.body')}</p>
    <a
      href={localePath(locale, '/')}
      class="mt-6 inline-block px-6 py-3 rounded-full bg-primary text-on-primary font-semibold hover:bg-primary-hover"
    >
      {t(locale, 'notFound.home')}
    </a>
  </section>
</Base>
