---
// Admin console landing (console class — editors, admins, and team leaders).
// For staff (editor∪admin) it shows real content counts, a "this week prep"
// checklist (next Sunday: bulletin + sermon per service type), and the most
// recent revisions. People count is admin-only. Every DB read fails soft so a
// hiccup never 500s the dashboard.
import Admin from '../../layouts/Admin.astro';
import { t } from '../../lib/i18n';
import {
  countPeople,
  countContentByStatus,
  countNewPrayerRequests,
  listWeekPrep,
  listRecentRevisions,
  type StatusCounts,
  type WeekPrepRow,
  type RecentRevisionRow,
} from '../../lib/adminDb';
import { countPendingTestimonies } from '../../lib/testimonyDb';
import { badge, badgeActive, badgeInactive, card, th, td, btn, btnSecondary } from '../../lib/adminUi';
import { todayInTz, nextWeekday, formatDate } from '../../lib/dates';
import type { Locale } from '../../lib/locales';
import { hasAreaAccess } from '../../lib/adminAreas';

const user = Astro.locals.user!;
const lang: Locale = user.lang ?? 'en';
const db = Astro.locals.db;
const isStaff = user.isEditor || user.isAdmin;
// Dashboard cards mirror the module gating AND (for admins) their per-admin area
// grants: a card renders only when its module is on and, for an admin, their
// grant covers the area — so the dashboard never links into a disabled (404ing)
// or forbidden (403ing) admin surface. Non-admin staff (editors) are unaffected.
const modules = Astro.locals.modules;
const areaOk = (a: Parameters<typeof hasAreaAccess>[1]) => !user.isAdmin || hasAreaAccess(user, a);
// The set of areas the recent-revisions table can surface (its entities span
// all of these); used only to scope that section for admins (see below).
const CONTENT_AREAS = ['bulletins', 'sermons', 'prayer-sheets', 'events', 'pages'] as const;
// Per-row area for the recent-revisions table, mirroring the map in
// src/pages/admin/revisions/[entity]/[id].astro — a bulletins-only admin must
// never see (and click into a 403 on) a sermon/page/event row just because the
// SECTION renders for them (spec §6: never link into a page they can't open).
const ENTITY_AREA: Record<string, Parameters<typeof hasAreaAccess>[1]> = {
  bulletin: 'bulletins',
  sermon: 'sermons',
  prayer_sheet: 'prayer-sheets',
  announcement: 'events',
  event: 'events',
  custom_page: 'pages',
};

const sunday = nextWeekday(todayInTz(), 0);

let peopleCount: number | null = null;
let bulletinCounts: StatusCounts = { published: 0, draft: 0 };
let sermonCounts: StatusCounts = { published: 0, draft: 0 };
let prayerCounts: StatusCounts = { published: 0, draft: 0 };
let weekPrep: WeekPrepRow[] = [];
let revisions: RecentRevisionRow[] = [];
let newPrayerCount = 0;
let pendingTestimonies = 0;

try {
  if (user.isAdmin) peopleCount = await countPeople(db);
  if (isStaff) {
    [bulletinCounts, sermonCounts, prayerCounts, weekPrep, revisions, newPrayerCount, pendingTestimonies] =
      await Promise.all([
        countContentByStatus(db, 'bulletins'),
        countContentByStatus(db, 'sermons'),
        countContentByStatus(db, 'prayer_sheets'),
        listWeekPrep(db, sunday, lang),
        listRecentRevisions(db, 5),
        countNewPrayerRequests(db),
        countPendingTestimonies(db),
      ]);
  }
} catch (e) {
  console.error('admin dashboard load failed', e);
}

// Volunteer-console entry: pending serving applications, scoped to the viewer
// (admin → church-wide; team leader → their teams). Best-effort.
const isLeader = user.leaderTeamIds.length > 0;
// `areaOk` reads true for non-admins (it only narrows admins), which is wrong
// here since this card is admin ∪ leader, not staff-wide — a plain editor must
// not see it. So this check is admin-scoped explicitly: false outright for a
// non-admin, deferring to their grant only when they are one.
const areaOkServe = user.isAdmin ? hasAreaAccess(user, 'serve') : false;
let pendingApps = 0;
try {
  if (user.isAdmin && areaOk('serve')) {
    pendingApps = (await db.prepare(`SELECT COUNT(*) AS n FROM team_applications WHERE status = 'P'`).first<{ n: number }>())?.n ?? 0;
  } else if (isLeader) {
    const ph = user.leaderTeamIds.map(() => '?').join(',');
    pendingApps = (await db.prepare(`SELECT COUNT(*) AS n FROM team_applications WHERE status = 'P' AND team_id IN (${ph})`).bind(...user.leaderTeamIds).first<{ n: number }>())?.n ?? 0;
  }
} catch (e) {
  console.error('pending applications count failed', e);
}

const stats = [
  ...(user.isAdmin && modules.has('people') ? [{ label: t(lang, 'admin.nav.people'), value: peopleCount === null ? '—' : String(peopleCount) }] : []),
  ...(isStaff && modules.has('bulletins') && areaOk('bulletins') ? [{ label: t(lang, 'admin.dashboard.bulletins'), value: `${bulletinCounts.published} / ${bulletinCounts.draft}` }] : []),
  ...(isStaff && modules.has('sermons') && areaOk('sermons') ? [{ label: t(lang, 'admin.dashboard.sermons'), value: `${sermonCounts.published} / ${sermonCounts.draft}` }] : []),
  ...(isStaff && modules.has('prayer-sheets') && areaOk('prayer-sheets') ? [{ label: t(lang, 'admin.dashboard.prayerSheets'), value: `${prayerCounts.published} / ${prayerCounts.draft}` }] : []),
];

// Revision entity → edit-page href (announcement/event/custom_page have no per-id editor).
const REV_BASE: Record<string, string> = {
  bulletin: '/admin/bulletins',
  sermon: '/admin/sermons',
  prayer_sheet: '/admin/prayer-sheets',
  announcement: '/admin/announcements',
  event: '/admin/events',
  custom_page: '/admin/pages',
};
function revHref(r: RecentRevisionRow): string {
  const base = REV_BASE[r.entity] ?? '/admin';
  const perId = r.entity === 'bulletin' || r.entity === 'sermon' || r.entity === 'prayer_sheet';
  return perId ? `${base}/${r.entity_id}` : base;
}

// listRecentRevisions is unfiltered across every content entity; narrow it here
// to the rows the viewer could actually open, same rule as revHref's callers —
// editors keep every row, an admin keeps only rows whose entity area they hold.
const visibleRevisions = revisions.filter((r) => user.isEditor || hasAreaAccess(user, ENTITY_AREA[r.entity]));
---

<Admin title={t(lang, 'admin.dashboard.title')}>
  <div class="flex items-baseline justify-between gap-4">
    <h1 class="font-display text-heading-md font-bold">{t(lang, 'admin.dashboard.title')}</h1>
    <p class="text-sm text-ink-muted">{formatDate(todayInTz(), lang)}</p>
  </div>
  <p class="mt-1 text-ink-muted">{t(lang, 'admin.dashboard.welcome', { name: user.displayName })}</p>

  {
    isStaff && modules.has('prayer-wall') && newPrayerCount > 0 && (
      <div class="mt-6 flex items-center justify-between gap-4 rounded-xl border border-warn bg-warn-soft px-4 py-3">
        <p class="text-sm text-warn">{t(lang, 'admin.dashboard.prayerAlert', { count: newPrayerCount })}</p>
        <a href="/admin/prayer-wall" class={btn}>{t(lang, 'admin.dashboard.prayerAlertCta')}</a>
      </div>
    )
  }

  {
    stats.length > 0 && (
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {stats.map((s) => (
          <div class={card}>
            <div class="text-xs font-semibold uppercase tracking-caps text-accent">{s.label}</div>
            <div class="mt-2 text-display-lg font-bold">{s.value}</div>
            <div class="mt-1 text-sm text-ink-subtle">
              {t(lang, 'admin.dashboard.published')} / {t(lang, 'admin.dashboard.drafts')}
            </div>
          </div>
        ))}
      </div>
    )
  }

  {
    (areaOkServe || isLeader) && modules.has('serve') && (
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <a href="/admin/ministries?tab=applications" class={`${card} flex items-center justify-between gap-4 hover:bg-surface-sunken`}>
          <span class="font-semibold text-ink">{t(lang, 'admin.dashboard.volunteerConsole')}</span>
          <span class={`${badge} ${pendingApps > 0 ? badgeActive : badgeInactive}`}>
            {t(lang, 'admin.dashboard.applicationsCount', { count: pendingApps })}
          </span>
        </a>
      </div>
    )
  }

  {
    user.isAdmin && areaOk('groups') && modules.has('groups') && (
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <a href="/admin/groups" class={`${card} flex items-center justify-between gap-4 hover:bg-surface-sunken`}>
          <span class="font-semibold text-ink">{t(lang, 'admin.dashboard.groups')}</span>
        </a>
      </div>
    )
  }

  {
    isStaff && (modules.has('prayer-wall') || (modules.has('testimonies') && areaOk('testimonies'))) && (
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {modules.has('prayer-wall') && (
          <a href="/admin/prayer-wall" class={`${card} flex items-center justify-between gap-4 hover:bg-surface-sunken`}>
            <span class="font-semibold text-ink">{t(lang, 'admin.dashboard.prayerWall')}</span>
            <span class={`${badge} ${newPrayerCount > 0 ? badgeActive : badgeInactive}`}>
              {t(lang, 'admin.dashboard.newRequests', { count: newPrayerCount })}
            </span>
          </a>
        )}
        {modules.has('testimonies') && areaOk('testimonies') && (
          <a href="/admin/testimonies" class={`${card} flex items-center justify-between gap-4 hover:bg-surface-sunken`}>
            <span class="font-semibold text-ink">{t(lang, 'admin.dashboard.testimonies')}</span>
            <span class={`${badge} ${pendingTestimonies > 0 ? badgeActive : badgeInactive}`}>
              {t(lang, 'admin.dashboard.pendingReview', { count: pendingTestimonies })}
            </span>
          </a>
        )}
      </div>
    )
  }

  {
    isStaff && (
      (modules.has('bulletins') && areaOk('bulletins')) || (modules.has('sermons') && areaOk('sermons'))
    ) && (
      <section class="mt-10">
        <h2 class="font-display text-heading-sm font-bold">{t(lang, 'admin.dashboard.weekPrepTitle')}</h2>
        <p class="mt-1 text-sm text-ink-muted">{t(lang, 'admin.dashboard.weekPrepIntro', { date: formatDate(sunday, lang) })}</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {weekPrep.map((row) => (
            <div class={card}>
              <h3 class="font-semibold">{row.name}</h3>
              <div class="mt-3 space-y-2 text-sm">
                {modules.has('bulletins') && areaOk('bulletins') && (
                  <div class="flex items-center justify-between gap-2">
                    <span>
                      {t(lang, 'admin.dashboard.bulletin')}{' '}
                      <span class={`${badge} ${row.bulletin_id ? badgeActive : badgeInactive}`}>
                        {row.bulletin_id ? t(lang, 'admin.dashboard.ready') : t(lang, 'admin.dashboard.missing')}
                      </span>
                    </span>
                    {row.bulletin_id ? (
                      <a href={`/admin/bulletins/${row.bulletin_id}`} class={btnSecondary}>{t(lang, 'admin.dashboard.edit')}</a>
                    ) : (
                      <a href={`/admin/bulletins/new?service=${row.service_type_id}`} class={btn}>{t(lang, 'admin.dashboard.create')}</a>
                    )}
                  </div>
                )}
                {modules.has('sermons') && areaOk('sermons') && (
                  <div class="flex items-center justify-between gap-2">
                    <span>
                      {t(lang, 'admin.dashboard.sermon')}{' '}
                      <span class={`${badge} ${row.sermon_id ? badgeActive : badgeInactive}`}>
                        {row.sermon_id ? t(lang, 'admin.dashboard.ready') : t(lang, 'admin.dashboard.missing')}
                      </span>
                    </span>
                    {row.sermon_id ? (
                      <a href={`/admin/sermons/${row.sermon_id}`} class={btnSecondary}>{t(lang, 'admin.dashboard.edit')}</a>
                    ) : (
                      <a href={`/admin/sermons/new?service=${row.service_type_id}`} class={btn}>{t(lang, 'admin.dashboard.create')}</a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    // Revisions span every content area, so show it for editors (unchanged) or
    // for an admin whose grants cover at least one content area — same
    // admin-scoping as areaOkServe above, since a bare team leader (no editor,
    // no admin) must keep NOT seeing this section, as before area grants existed.
    (user.isEditor || (user.isAdmin && CONTENT_AREAS.some((a) => hasAreaAccess(user, a)))) && (
      <section class="mt-10">
        <h2 class="font-display text-heading-sm font-bold">{t(lang, 'admin.dashboard.recentTitle')}</h2>
        {visibleRevisions.length === 0 ? (
          <p class="mt-3 text-sm text-ink-muted">{t(lang, 'admin.dashboard.recentEmpty')}</p>
        ) : (
          <div class="mt-4 overflow-x-auto rounded-xl border border-border bg-surface-raised">
            <table class="w-full border-collapse">
              <thead class="bg-surface-sunken">
                <tr>
                  <th class={th}>{t(lang, 'admin.dashboard.colContent')}</th>
                  <th class={th}>{t(lang, 'admin.dashboard.colEditor')}</th>
                  <th class={th}>{t(lang, 'admin.dashboard.colWhen')}</th>
                </tr>
              </thead>
              <tbody>
                {visibleRevisions.map((r) => (
                  <tr class="border-t border-border hover:bg-surface-sunken">
                    <td class={td}>
                      <a href={revHref(r)} class="font-medium text-primary hover:underline">
                        {t(lang, `admin.entity.${r.entity}`)} #{r.entity_id}
                      </a>
                    </td>
                    <td class={td}>{r.edited_by}</td>
                    <td class={`${td} text-ink-muted`}>{r.edited_at}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    )
  }
</Admin>
