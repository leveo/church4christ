---
// Create / edit a person (adminOnly). The identity form + role/active flags +
// delete predate the people module and always render. When the people module is
// ON the editor gains membership-profile depth (birthday/address/status/joined_on,
// parsed with the { admin: true } variant + persisted by savePerson) and four
// admin-only panels: household management, pastoral notes (NEVER shown on any
// other surface — privacy rule), the person's serving applications, and an
// invite-to-serve touchpoint. Every panel + the invite action is gated on
// locals.modules.has('people'); a crafted POST while off is ignored.
import Admin from '../../../layouts/Admin.astro';
import { env } from 'cloudflare:workers';
import AvatarInitials from '../../../components/AvatarInitials.astro';
import GroupActivity from '../../../components/GroupActivity.astro';
import { t } from '../../../lib/i18n';
import { listPersonGroupActivity, type PersonGroupActivity } from '../../../lib/groupDb';
import { listRegistrationsForPerson, type PersonRegistration } from '../../../lib/groupRegDb';
import { getPerson, savePerson, setPersonAvatar, setPersonFlags, softDeletePerson } from '../../../lib/adminDb';
import { hasAreaAccess, parseAdminAreas, GRANTABLE_AREAS, type GrantableArea } from '../../../lib/adminAreas';
import { parsePersonForm, MEMBERSHIP_STATUSES } from '../../../lib/validate';
import { saveImageUpload, uploadErrorKey, type MediaBucket } from '../../../lib/mediaUpload';
import { normalizeAvatarUrl } from '../../../lib/mediaRef';
import { listHouseholdGifts, householdYearTotals, type GiftRow } from '../../../lib/givingDb';
import { formatDate } from '../../../lib/dates';
import { formatCents } from '../../../lib/money';
import {
  getLiveHouseholdForPerson,
  createHousehold,
  linkPersonToHousehold,
  unlinkPerson,
  setMemberRole,
  setPrimary,
  listHouseholds,
  HOUSEHOLD_ROLES,
  type HouseholdWithMembers,
  type HouseholdSummary,
} from '../../../lib/householdDb';
import { listNotes, addNote, softDeleteNote, NOTE_MAX_LEN, type PersonNote } from '../../../lib/notesDb';
import {
  listApplicationsForPerson,
  listTeamSummaries,
  type PersonApplicationRow,
  type TeamSummary,
} from '../../../lib/teamDb';
import { sendServeInvite } from '../../../lib/notify';
import { type EmailEnv } from '../../../lib/email';
import { LOCALES, localePath, type Locale } from '../../../lib/locales';
import {
  tin,
  lab,
  card,
  errorText,
  btn,
  btnSecondary,
  btnDanger,
  noticeOk,
  noticeErr,
  badge,
  badgeRole,
  badgeActive,
  badgeInactive,
  badgeScheduled,
  th,
  td,
} from '../../../lib/adminUi';

const user = Astro.locals.user!;
const lang: Locale = user.lang ?? 'en';
const db = Astro.locals.db;
const media = (env as unknown as { MEDIA: MediaBucket }).MEDIA;
const hasPeople = Astro.locals.modules.has('people');
const hasGiving = Astro.locals.modules.has('giving');
// Group activity (memberships/attendance + registrations) is its own module
// gate, independent of the people module.
const hasGroups = Astro.locals.modules.has('groups');
const ROLES = ['member', 'editor', 'admin'] as const;
// Role/grant flags escalate privilege, so only a super admin may write them
// (the flags form is gated on this below); deleting a person is a lighter-weight
// action gated on the ordinary 'people' area grant instead.
const canManagePeople = hasAreaAccess(user, 'people');
const canGroups = hasAreaAccess(user, 'groups');
const canRegistration = hasAreaAccess(user, 'registration');
// hasGiving is module+backend gated (force-off on D1), so canGiving stays false
// there regardless of the area grant — no givingDb query ever runs on D1.
const canGiving = hasGiving && hasAreaAccess(user, 'giving');
const isSuper = user.isSuperAdmin;
// Per-module grant labels for the areas fieldset — reuses each area's existing
// nav/section title so there is no new translated string per area.
const AREA_LABEL_KEYS: Record<GrantableArea, string> = {
  bulletins: 'admin.nav.bulletins',
  sermons: 'admin.nav.sermons',
  'prayer-sheets': 'admin.nav.prayerSheets',
  testimonies: 'admin.nav.testimonies',
  pages: 'admin.nav.pages',
  events: 'admin.nav.news',
  people: 'admin.areas.people',
  groups: 'admin.nav.groups',
  children: 'admin.nav.children',
  giving: 'admin.giving.title',
  registration: 'admin.reg.title',
  serve: 'admin.areas.serve',
};

const rawId = Astro.params.id ?? '';
const isNew = rawId === 'new';
if (!isNew && !/^\d+$/.test(rawId)) return new Response(null, { status: 404 });
const id = isNew ? null : Number(rawId);
// /admin/people/new is member management too — creating a person requires the
// people grant on both GET and POST (people-basic, reachable by every admin,
// only covers viewing/editing the directory, not adding to it).
if (isNew && !canManagePeople) return new Response(null, { status: 403 });

const person = id !== null ? await getPerson(db, id) : null;
if (id !== null && !person) return new Response(null, { status: 404 });
const personAreas = parseAdminAreas(person?.admin_areas);

const idOf = (v: FormDataEntryValue | null): number | null => (/^\d+$/.test(String(v ?? '')) ? Number(v) : null);
const HH_ERR: Record<string, string> = {
  already_in_household: 'admin.person.household.errAlreadyIn',
  household_not_found: 'admin.person.household.errNotFound',
  person_not_found: 'admin.person.household.errGeneric',
};
const mapHh = (e: unknown): string => HH_ERR[e instanceof Error ? e.message : ''] ?? 'admin.person.household.errGeneric';

let errors: Record<string, string> = {};
let householdErrorKey: string | null = null;
let noteErrorKey: string | null = null;
let flagsErrorKey: string | null = null;
const values: Record<string, string> = {};

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = fd.get('action');

  if (action === 'delete' && id !== null) {
    // Deleting a person requires the 'people' area grant, not just reaching this
    // page (people-basic — GET only — is always-on for every admin).
    if (!canManagePeople) return new Response(null, { status: 403 });
    try {
      await softDeletePerson(db, id);
    } catch (e) {
      if (e instanceof Error && e.message === 'last_super_admin') {
        flagsErrorKey = 'admin.person.lastSuperErr';
      } else throw e;
    }
    if (!flagsErrorKey) return Astro.redirect('/admin/people/?deleted=1', 303);
  }

  if (action === 'flags' && id !== null) {
    // Only a super admin may touch roles / grants — closes the pre-permissions
    // hole where any admin could promote anyone to admin.
    if (!isSuper) return new Response(null, { status: 403 });
    const roleRaw = String(fd.get('role') ?? '');
    const role = ROLES.find((r) => r === roleRaw);
    const nextSuper = role === 'admin' && fd.get('super_admin') !== null;
    const areas = fd.getAll('areas').map(String);
    // The finance flag (giving admin access) is only shown — and only read — when
    // the giving module is on; a crafted POST while off is ignored, leaving it as set.
    try {
      await setPersonFlags(db, id, {
        role,
        active: fd.get('active') !== null,
        ...(hasGiving ? { finance: fd.get('finance') !== null } : {}),
        superAdmin: nextSuper,
        adminAreas: areas,
      });
      return Astro.redirect(`/admin/people/${id}?saved=1`, 303);
    } catch (e) {
      if (e instanceof Error && e.message === 'last_super_admin') {
        flagsErrorKey = 'admin.person.lastSuperErr';
      } else throw e;
    }
  }

  // People-module actions (household / notes / invite) — all require an existing
  // person, the module, and the people area grant. On success they redirect back
  // to this page; on error they set an error key and fall through to re-render.
  if (hasPeople && canManagePeople && id !== null) {
    const back = () => Astro.redirect(`/admin/people/${id}?saved=1`, 303);

    if (action === 'createHousehold') {
      const name = String(fd.get('name') ?? '').trim();
      if (!name) householdErrorKey = 'admin.person.household.errGeneric';
      else {
        try {
          await createHousehold(db, { name, address: null, phone: null }, id);
          return back();
        } catch (e) {
          householdErrorKey = mapHh(e);
        }
      }
    } else if (action === 'linkHousehold') {
      const householdId = idOf(fd.get('household_id'));
      if (householdId !== null) {
        try {
          await linkPersonToHousehold(db, householdId, id);
          return back();
        } catch (e) {
          householdErrorKey = mapHh(e);
        }
      }
    } else if (action === 'unlinkHousehold') {
      await unlinkPerson(db, id);
      return back();
    } else if (action === 'setMemberRole') {
      const memberId = idOf(fd.get('member_id'));
      const role = HOUSEHOLD_ROLES.find((r) => r === String(fd.get('role') ?? ''));
      if (memberId !== null && role) await setMemberRole(db, memberId, role);
      return back();
    } else if (action === 'setPrimary') {
      const memberId = idOf(fd.get('member_id'));
      const householdId = idOf(fd.get('household_id'));
      if (memberId !== null && householdId !== null) await setPrimary(db, householdId, memberId);
      return back();
    } else if (action === 'addNote') {
      try {
        await addNote(db, id, user.email, String(fd.get('body') ?? ''));
        return back();
      } catch (e) {
        noteErrorKey = (e instanceof Error && e.message === 'note_too_long')
          ? 'admin.person.notes.tooLong'
          : 'admin.person.notes.emptyErr';
      }
    } else if (action === 'deleteNote') {
      const noteId = idOf(fd.get('note_id'));
      if (noteId !== null) await softDeleteNote(db, noteId);
      return back();
    } else if (action === 'invite') {
      // Honest outcome: sendServeInvite returns false for an inactive/no-email
      // invitee (or a missing team) — surface that as ?invited=0, not a fake
      // success.
      const teamId = idOf(fd.get('team_id'));
      let sent = false;
      if (teamId !== null) {
        sent = await sendServeInvite(env as unknown as EmailEnv, db, { personId: id, teamId, invitedByEmail: user.email });
      }
      return Astro.redirect(`/admin/people/${id}?invited=${sent ? '1' : '0'}`, 303);
    }
  }

  if (action === 'save') {
    // Saving identity fields requires the people area grant, regardless of
    // whether this is a new person or an edit (isNew already 403s above).
    if (!canManagePeople) return new Response(null, { status: 403 });
    for (const [k, val] of fd.entries()) if (typeof val === 'string') values[k] = val;
    // The membership-depth fields only render (and are only parsed/persisted) when
    // the people module is on; while off, a core save leaves them untouched.
    const parsed = parsePersonForm(fd, { admin: hasPeople });
    if (parsed.ok) {
      // Role and active status are super-admin-only concerns, editable only via
      // the flags form (which carries the last-super-admin guard). The identity
      // save form must never change them — a crafted POST could otherwise demote
      // or deactivate a super admin (or promote a member) with no guard. Pin them
      // to the stored values on edit. (New people are created by the people grant
      // as-is; a super admin elevates them afterward via the flags form.)
      if (person) {
        parsed.data.role = person.role;
        parsed.data.active = person.active === 1;
      }
      const avatarFile = fd.get('avatar');
      let avatarKey: string | null = null;
      if (avatarFile instanceof File && avatarFile.size > 0) {
        try {
          avatarKey = await saveImageUpload({ db, media, file: avatarFile, uploadedBy: user.email });
        } catch (e) {
          errors.avatar = uploadErrorKey(e);
        }
      }
      if (Object.keys(errors).length === 0) {
        const result = await savePerson(db, { ...parsed.data, id }, user.email);
        if (result.ok) {
          if (avatarKey) await setPersonAvatar(db, result.id, `/media/${avatarKey}`);
          else if (fd.get('remove_avatar')) await setPersonAvatar(db, result.id, null);
          return Astro.redirect('/admin/people/?saved=1', 303);
        }
        errors = result.errors;
      }
    } else {
      errors = parsed.errors;
    }
  }
}

const saved = Astro.url.searchParams.get('saved') === '1';
const invited = Astro.url.searchParams.get('invited') === '1';
const inviteFailed = Astro.url.searchParams.get('invited') === '0';
const echoed = Object.keys(values).length > 0; // a failed save re-render

// Failed save echoes submitted values; otherwise the stored row (or blank/new).
const v = {
  first_name: values.first_name ?? person?.first_name ?? '',
  last_name: values.last_name ?? person?.last_name ?? '',
  display_name: values.display_name ?? person?.display_name ?? '',
  email: values.email ?? person?.email ?? '',
  phone: values.phone ?? person?.phone ?? '',
  role: values.role ?? person?.role ?? 'member',
  lang: values.lang ?? person?.lang ?? '',
  active: echoed ? 'active' in values : person ? person.active === 1 : true,
  birthday: values.birthday ?? person?.birthday ?? '',
  address: values.address ?? person?.address ?? '',
  membership_status: values.membership_status ?? person?.membership_status ?? 'visitor',
  joined_on: values.joined_on ?? person?.joined_on ?? '',
};
const avatarUrl = normalizeAvatarUrl(person?.avatar_url);

// People-module panel data (household / notes / applications / invite targets).
let household: HouseholdWithMembers | null = null;
let notes: PersonNote[] = [];
let applications: PersonApplicationRow[] = [];
let allTeams: TeamSummary[] = [];
let allHouseholds: HouseholdSummary[] = [];
if (hasPeople && canManagePeople && person) {
  [household, notes, applications, allTeams, allHouseholds] = await Promise.all([
    getLiveHouseholdForPerson(db, person.id),
    listNotes(db, person.id),
    listApplicationsForPerson(db, person.id, lang),
    listTeamSummaries(db, lang),
    listHouseholds(db),
  ]);
}

// Group activity panel data (independent of the people module; gated on its
// own area grant instead).
let groupActivity: PersonGroupActivity = { memberships: [], attendance: [] };
let personRegistrations: PersonRegistration[] = [];
if (hasGroups && canGroups && person) {
  groupActivity = await listPersonGroupActivity(db, person.id);
  if (Astro.locals.modules.has('registration') && canRegistration) {
    personRegistrations = await listRegistrationsForPerson(db, person.id, lang);
  }
}

// Giving history panel data — only fetched when the viewer has BOTH the giving
// module (Supabase-only, force-off on D1) and the giving area grant, so this
// givingDb query never runs on D1 and never leaks to an ungranted admin (spec
// requirement #4).
let giftRows: Array<GiftRow & { giver_name: string }> = [];
let givingYtd: Array<{ year: string; total_cents: number }> = [];
if (canGiving && person) {
  [giftRows, givingYtd] = await Promise.all([
    listHouseholdGifts(db, lang, person.id),
    householdYearTotals(db, person.id),
  ]);
}
// householdYearTotals returns one row per calendar year, newest first; the
// panel surfaces just the current year's total (0 when no gifts landed yet).
const currentYear = String(new Date().getFullYear());
const ytdCents = givingYtd.find((y) => y.year === currentYear)?.total_cents ?? 0;

const heading = isNew ? t(lang, 'admin.person.newTitle') : t(lang, 'admin.person.editTitle');
const avatarName = v.display_name || heading;

// Only display_name and email carry inline error slots; anything else the
// parser can reject (role/lang option errors) surfaces in one summary banner
// so a failed save is never silent. Field labels resolve via admin.person.*;
// the snake_case fields whose dictionary keys are camelCase map explicitly so a
// crafted POST (e.g. a bogus membership_status) never leaks a raw key.
const INLINE_ERROR_FIELDS = new Set(['display_name', 'email']);
const FIELD_LABEL_KEYS: Record<string, string> = {
  membership_status: 'admin.person.membershipStatus',
  joined_on: 'admin.person.joinedOn',
};
const summaryErrors = Object.entries(errors)
  .filter(([field]) => !INLINE_ERROR_FIELDS.has(field))
  .map(([field, key]) => `${t(lang, FIELD_LABEL_KEYS[field] ?? `admin.person.${field}`)}: ${t(lang, key)}`);
---

<Admin title={heading}>
  <div class="flex items-center justify-between gap-4">
    <h1 class="font-display text-heading-md font-bold">{heading}</h1>
    <a href="/admin/people/" class="text-sm text-primary hover:underline">&larr; {t(lang, 'admin.person.back')}</a>
  </div>

  {saved && <p class={`mt-4 ${noticeOk}`}>{t(lang, 'admin.people.saved')}</p>}
  {summaryErrors.length > 0 && <p class={`mt-4 max-w-2xl ${noticeErr}`}>{summaryErrors.join(' ')}</p>}

  <form method="post" enctype="multipart/form-data" class={`mt-6 ${card} grid max-w-2xl gap-4 sm:grid-cols-2`}>
    {/* Without the people grant this form is view-only: no action means a
        crafted submit is a no-op client-side, and the server independently
        403s any POST save regardless (defense in depth). */}
    {canManagePeople && <input type="hidden" name="action" value="save" />}
    {/* On edit, role/active live in the flags form; carry current values so the
        identity save validates and never clobbers them. */}
    {!isNew && <input type="hidden" name="role" value={v.role} />}
    {!isNew && v.active && <input type="hidden" name="active" value="1" />}

    <h2 class="font-semibold sm:col-span-2">{t(lang, 'admin.person.detailsTitle')}</h2>

    {/* class="contents" keeps the fieldset out of the grid layout (its children
        still lay out as direct grid items) while `disabled` makes every field
        inside it native-read-only for a viewer without the people grant. */}
    <fieldset class="contents" disabled={!canManagePeople}>
    <div class="sm:col-span-2">
      <span class={lab}>{t(lang, 'admin.person.avatar')}</span>
      <div class="mt-2 flex flex-wrap items-center gap-4">
        {avatarUrl && (
          <img
            src={avatarUrl}
            alt={t(lang, 'admin.person.currentAvatar')}
            class="h-20 w-20 rounded-full border border-border object-cover"
          />
        )}
        {!avatarUrl && <AvatarInitials name={avatarName} sizeClass="h-20 w-20 text-2xl" />}
        {canManagePeople && (
          <div class="min-w-56 flex-1">
            <label class="block">
              <span class="sr-only">{t(lang, 'admin.person.changeAvatar')}</span>
              <input type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif" class={`${tin} file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1.5 file:text-sm file:font-semibold file:text-on-primary`} />
            </label>
            {avatarUrl && (
              <label class="mt-2 flex items-center gap-2 text-sm">
                <input type="checkbox" name="remove_avatar" />
                <span>{t(lang, 'admin.person.removeAvatar')}</span>
              </label>
            )}
          </div>
        )}
      </div>
    </div>

    <label class="block sm:col-span-2">
      <span class={lab}>{t(lang, 'admin.person.displayName')} *</span>
      <input type="text" name="display_name" value={v.display_name} class={tin} />
      {errors.display_name && <span class={errorText}>{t(lang, errors.display_name)}</span>}
    </label>

    <label class="block">
      <span class={lab}>{t(lang, 'admin.person.firstName')}</span>
      <input type="text" name="first_name" value={v.first_name} class={tin} />
    </label>
    <label class="block">
      <span class={lab}>{t(lang, 'admin.person.lastName')}</span>
      <input type="text" name="last_name" value={v.last_name} class={tin} />
    </label>

    <label class="block">
      <span class={lab}>{t(lang, 'admin.person.email')} *</span>
      <input type="email" name="email" value={v.email} class={tin} />
      {errors.email && <span class={errorText}>{t(lang, errors.email)}</span>}
    </label>
    <label class="block">
      <span class={lab}>{t(lang, 'admin.person.phone')}</span>
      <input type="text" name="phone" value={v.phone} class={tin} />
    </label>

    <label class="block">
      <span class={lab}>{t(lang, 'admin.person.lang')}</span>
      <select name="lang" class={tin}>
        <option value="" selected={v.lang === ''}>{t(lang, 'admin.person.langNone')}</option>
        {LOCALES.map((loc) => (
          <option value={loc} selected={v.lang === loc}>{t(lang, `locale.${loc}`)}</option>
        ))}
      </select>
    </label>

    {
      hasPeople && (
        <>
          <label class="block">
            <span class={lab}>{t(lang, 'admin.person.birthday')}</span>
            <input type="date" name="birthday" value={v.birthday} class={tin} />
          </label>
          <label class="block">
            <span class={lab}>{t(lang, 'admin.person.address')}</span>
            <input type="text" name="address" value={v.address} class={tin} />
          </label>
          <label class="block">
            <span class={lab}>{t(lang, 'admin.person.membershipStatus')}</span>
            <select name="membership_status" class={tin}>
              {MEMBERSHIP_STATUSES.map((s) => (
                <option value={s} selected={v.membership_status === s}>{t(lang, `membership.${s}`)}</option>
              ))}
            </select>
          </label>
          <label class="block">
            <span class={lab}>{t(lang, 'admin.person.joinedOn')}</span>
            <input type="date" name="joined_on" value={v.joined_on} class={tin} />
          </label>
        </>
      )
    }

    {
      isNew && (
        <>
          <label class="block">
            <span class={lab}>{t(lang, 'admin.person.role')}</span>
            <select name="role" class={tin}>
              {ROLES.map((r) => (
                <option value={r} selected={v.role === r}>{t(lang, `admin.role.${r}`)}</option>
              ))}
            </select>
          </label>
          <label class="flex items-center gap-2 sm:col-span-2">
            <input type="checkbox" name="active" checked={v.active} />
            <span class="text-sm">{t(lang, 'admin.person.activeLabel')}</span>
          </label>
        </>
      )
    }
    </fieldset>

    {canManagePeople && (
      <div class="sm:col-span-2">
        <button type="submit" class={btn}>{t(lang, 'admin.person.save')}</button>
      </div>
    )}
  </form>

  {
    !isNew && person && (
      <>
        {flagsErrorKey && <p class={`mt-6 max-w-2xl ${noticeErr}`}>{t(lang, flagsErrorKey)}</p>}
        {/* Role / active / finance / super-admin / per-module grants all escalate
            privilege, so only a super admin gets a form for them — every other
            admin (this page is reachable by all of them via the always-on
            people-basic area) sees a read-only summary instead. */}
        {isSuper && (
          <form method="post" class={`mt-6 ${card} max-w-2xl space-y-4`}>
            <input type="hidden" name="action" value="flags" />
            <h2 class="font-semibold">{t(lang, 'admin.person.flagsTitle')}</h2>
            <label class="block max-w-xs">
              <span class={lab}>{t(lang, 'admin.person.role')}</span>
              <select name="role" class={tin}>
                {ROLES.map((r) => (
                  <option value={r} selected={person.role === r}>{t(lang, `admin.role.${r}`)}</option>
                ))}
              </select>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="active" checked={person.active === 1} />
              <span class="text-sm">{t(lang, 'admin.person.activeLabel')}</span>
            </label>
            {hasGiving && (
              <label class="flex items-center gap-2">
                <input type="checkbox" name="finance" checked={person.finance === 1} />
                <span class="text-sm">{t(lang, 'admin.people.finance')}</span>
              </label>
            )}
            {person.role === 'admin' && (
              <>
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="super_admin" checked={person.super_admin === 1} />
                  <span class="text-sm">{t(lang, 'admin.person.superAdmin')}</span>
                </label>
                <fieldset class="space-y-2">
                  <legend class={lab}>{t(lang, 'admin.person.areasTitle')}</legend>
                  <p class="text-xs text-ink-muted">{t(lang, 'admin.person.areasHint')}</p>
                  {GRANTABLE_AREAS.map((a) => (
                    <label class="flex items-center gap-2">
                      <input
                        type="checkbox"
                        name="areas"
                        value={a}
                        checked={personAreas.includes(a)}
                        disabled={(a === 'giving' || a === 'registration') && Astro.locals.dbBackend !== 'supabase'}
                      />
                      <span class="text-sm">{t(lang, AREA_LABEL_KEYS[a])}</span>
                    </label>
                  ))}
                </fieldset>
              </>
            )}
            <button type="submit" class={btn}>{t(lang, 'admin.person.updateFlags')}</button>
          </form>
        )}
        {!isSuper && (
          <div class={`mt-6 ${card} max-w-2xl`}>
            <h2 class="font-semibold">{t(lang, 'admin.person.flagsTitle')}</h2>
            <dl class="mt-3 flex flex-wrap gap-x-6 gap-y-3 text-sm">
              <div class="flex items-center gap-2">
                <dt class="text-ink-muted">{t(lang, 'admin.person.role')}</dt>
                <dd><span class={`${badge} ${badgeRole[person.role] ?? badgeInactive}`}>{t(lang, `admin.role.${person.role}`)}</span></dd>
              </div>
              <div class="flex items-center gap-2">
                <dt class="text-ink-muted">{t(lang, 'admin.person.activeLabel')}</dt>
                <dd><span class={`${badge} ${person.active === 1 ? badgeActive : badgeInactive}`}>{t(lang, person.active === 1 ? 'admin.people.active' : 'admin.people.inactive')}</span></dd>
              </div>
              {hasGiving && (
                <div class="flex items-center gap-2">
                  <dt class="text-ink-muted">{t(lang, 'admin.people.finance')}</dt>
                  <dd><span class={`${badge} ${person.finance === 1 ? badgeActive : badgeInactive}`}>{t(lang, person.finance === 1 ? 'admin.people.active' : 'admin.people.inactive')}</span></dd>
                </div>
              )}
            </dl>
          </div>
        )}

        {hasPeople && canManagePeople && (
          <>
            {/* (b) Household panel — admin household management for this person. */}
            <section class={`mt-6 ${card} max-w-2xl`}>
              <h2 class="font-semibold">{t(lang, 'admin.person.household.title')}</h2>
              {householdErrorKey && <p class={`mt-3 ${noticeErr}`}>{t(lang, householdErrorKey)}</p>}
              {household ? (
                <div class="mt-3 space-y-4">
                  <p class="font-medium">{household.name}</p>
                  <ul class="flex flex-col gap-2">
                    {household.members.map((m) => (
                      <li class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="font-medium">{m.display_name}</span>
                        <span class="rounded-full bg-surface-sunken px-2 py-0.5 text-xs text-ink-muted">
                          {t(lang, m.role === 'child' ? 'admin.person.household.roleChild' : 'admin.person.household.roleAdult')}
                        </span>
                        {m.is_primary === 1 && (
                          <span class="rounded-full bg-primary-soft px-2 py-0.5 text-xs font-semibold text-on-primary-soft">
                            {t(lang, 'admin.person.household.primary')}
                          </span>
                        )}
                        <span class="ml-auto flex flex-wrap items-center gap-2">
                          <form method="post" class="flex items-center gap-1">
                            <input type="hidden" name="action" value="setMemberRole" />
                            <input type="hidden" name="member_id" value={m.id} />
                            <select name="role" class={`${tin} py-1 text-xs`}>
                              <option value="adult" selected={m.role === 'adult'}>{t(lang, 'admin.person.household.roleAdult')}</option>
                              <option value="child" selected={m.role === 'child'}>{t(lang, 'admin.person.household.roleChild')}</option>
                            </select>
                            <button type="submit" class="text-xs text-primary hover:underline">{t(lang, 'admin.person.household.setRole')}</button>
                          </form>
                          {m.is_primary !== 1 && (
                            <form method="post">
                              <input type="hidden" name="action" value="setPrimary" />
                              <input type="hidden" name="member_id" value={m.id} />
                              <input type="hidden" name="household_id" value={household.id} />
                              <button type="submit" class="text-xs text-primary hover:underline">{t(lang, 'admin.person.household.makePrimary')}</button>
                            </form>
                          )}
                        </span>
                      </li>
                    ))}
                  </ul>
                  <form method="post" onsubmit={`return confirm(${JSON.stringify(t(lang, 'admin.person.household.unlinkConfirm'))})`}>
                    <input type="hidden" name="action" value="unlinkHousehold" />
                    <button type="submit" class="text-sm font-semibold text-danger hover:underline">{t(lang, 'admin.person.household.unlink')}</button>
                  </form>
                </div>
              ) : (
                <div class="mt-3 space-y-5">
                  <p class="text-sm text-ink-muted">{t(lang, 'admin.person.household.none')}</p>
                  <form method="post" class="flex flex-wrap items-end gap-2">
                    <input type="hidden" name="action" value="createHousehold" />
                    <label class="block">
                      <span class={lab}>{t(lang, 'admin.person.household.name')}</span>
                      <input name="name" required class={tin} />
                    </label>
                    <button type="submit" class={btn}>{t(lang, 'admin.person.household.create')}</button>
                  </form>
                  {allHouseholds.length > 0 && (
                    <form method="post" class="flex flex-wrap items-end gap-2">
                      <input type="hidden" name="action" value="linkHousehold" />
                      <label class="block">
                        <span class={lab}>{t(lang, 'admin.person.household.linkTitle')}</span>
                        <select name="household_id" class={tin}>
                          {allHouseholds.map((h) => (
                            <option value={h.id}>{h.name}</option>
                          ))}
                        </select>
                      </label>
                      <button type="submit" class={btnSecondary}>{t(lang, 'admin.person.household.link')}</button>
                    </form>
                  )}
                </div>
              )}
            </section>

            {/* (c) Pastoral notes — admin-only; NEVER rendered on any other surface. */}
            <section class={`mt-6 ${card} max-w-2xl`}>
              <h2 class="font-semibold">{t(lang, 'admin.person.notes.title')}</h2>
              <p class="mt-1 text-sm text-ink-muted">{t(lang, 'admin.person.notes.hint')}</p>
              {noteErrorKey && <p class={`mt-3 ${noticeErr}`}>{t(lang, noteErrorKey)}</p>}
              <form method="post" class="mt-3">
                <input type="hidden" name="action" value="addNote" />
                <textarea
                  name="body"
                  rows="3"
                  maxlength={NOTE_MAX_LEN}
                  placeholder={t(lang, 'admin.person.notes.placeholder')}
                  class={tin}
                />
                <button type="submit" class={`mt-2 ${btn}`}>{t(lang, 'admin.person.notes.add')}</button>
              </form>
              {notes.length === 0 ? (
                <p class="mt-4 text-sm text-ink-muted">{t(lang, 'admin.person.notes.empty')}</p>
              ) : (
                <ul class="mt-4 space-y-3">
                  {notes.map((n) => (
                    <li class="rounded-md border border-border p-3">
                      <div class="flex items-center gap-2 text-xs text-ink-subtle">
                        <span class="font-semibold">{n.author_email}</span>
                        <span class="tabular-nums">{n.created_at.slice(0, 16)}</span>
                        <form
                          method="post"
                          class="ml-auto"
                          onsubmit={`return confirm(${JSON.stringify(t(lang, 'admin.person.notes.deleteConfirm'))})`}
                        >
                          <input type="hidden" name="action" value="deleteNote" />
                          <input type="hidden" name="note_id" value={n.id} />
                          <button type="submit" class="text-xs text-danger hover:underline">{t(lang, 'admin.person.notes.delete')}</button>
                        </form>
                      </div>
                      <p class="mt-1 whitespace-pre-wrap text-sm">{n.body}</p>
                    </li>
                  ))}
                </ul>
              )}
            </section>

            {/* (d) Serving applications for this person. */}
            <section class={`mt-6 ${card} max-w-2xl`}>
              <h2 class="font-semibold">{t(lang, 'admin.person.apps.title')}</h2>
              {applications.length === 0 ? (
                <p class="mt-3 text-sm text-ink-muted">{t(lang, 'admin.person.apps.empty')}</p>
              ) : (
                <ul class="mt-3 divide-y divide-border">
                  {applications.map((a) => (
                    <li class="flex flex-wrap items-center gap-2 py-2 text-sm">
                      <span class="font-medium">{a.team_name}</span>
                      {a.position_name && <span class="text-ink-muted">· {a.position_name}</span>}
                      <span class={`${badge} ${a.status === 'A' ? badgeActive : a.status === 'R' ? badgeInactive : badgeScheduled}`}>
                        {t(lang, `admin.person.apps.status${a.status}`)}
                      </span>
                      <span class="ml-auto text-xs text-ink-subtle tabular-nums">{a.created_at.slice(0, 10)}</span>
                      <a href={localePath(lang, `/serve/teams/${a.team_id}`)} class="text-xs text-primary hover:underline">
                        {t(lang, 'admin.person.apps.viewTeam')}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </section>

            {/* (e) Invite to serve — admin may pick ANY active team. */}
            <section class={`mt-6 ${card} max-w-2xl`}>
              <h2 class="font-semibold">{t(lang, 'invite.title')}</h2>
              <p class="mt-1 text-sm text-ink-muted">{t(lang, 'invite.hint')}</p>
              {invited && <p class={`mt-3 ${noticeOk}`}>{t(lang, 'invite.sent')}</p>}
              {inviteFailed && <p class={`mt-3 ${noticeErr}`}>{t(lang, 'invite.failed')}</p>}
              {allTeams.length > 0 && (
                <form method="post" class="mt-3 flex flex-wrap items-end gap-2">
                  <input type="hidden" name="action" value="invite" />
                  <label class="block">
                    <span class={lab}>{t(lang, 'invite.selectTeam')}</span>
                    <select name="team_id" class={tin}>
                      {allTeams.map((tm) => (
                        <option value={tm.id}>{tm.name}</option>
                      ))}
                    </select>
                  </label>
                  <button type="submit" class={btn}>{t(lang, 'invite.send')}</button>
                </form>
              )}
            </section>
          </>
        )}

        {hasGroups && canGroups && (
          /* Group activity — memberships, attendance history, and (registration
             module on) event registrations, for this person. Gated independent
             of the people module, on its own area grant. */
          <section class={`mt-6 ${card} max-w-2xl`}>
            <h2 class="font-semibold">{t(lang, 'admin.person.groups.title')}</h2>
            <div class="mt-3">
              <GroupActivity
                locale={lang}
                memberships={groupActivity.memberships}
                attendance={groupActivity.attendance}
                registrations={personRegistrations}
              />
            </div>
          </section>
        )}

        {canGiving && (
          /* Giving history — renders only for giving-granted admins (spec
             requirement #4): current-year total + the 10 most recent household
             gifts, mirroring the self-service /my/giving view but scoped to
             this person's household and kept compact for an admin side panel. */
          <section class={`mt-6 ${card} max-w-2xl`}>
            <h2 class="font-semibold">{t(lang, 'admin.person.giving.title')}</h2>
            <p class="mt-1 text-sm text-ink-muted">{t(lang, 'admin.person.giving.ytd', { amount: formatCents(ytdCents) })}</p>
            {giftRows.length === 0 ? (
              <p class="mt-3 text-sm text-ink-muted">{t(lang, 'admin.person.giving.empty')}</p>
            ) : (
              <div class="mt-3 overflow-x-auto rounded-lg border border-border">
                <table class="w-full">
                  <thead class="border-b border-border">
                    <tr>
                      <th class={th}>{t(lang, 'my.giving.date')}</th>
                      <th class={th}>{t(lang, 'my.giving.fund')}</th>
                      <th class={`${th} text-right`}>{t(lang, 'my.giving.amount')}</th>
                      <th class={th}>{t(lang, 'my.giving.method')}</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-border">
                    {giftRows.slice(0, 10).map((g) => (
                      <tr>
                        <td class={`${td} whitespace-nowrap tabular-nums`}>
                          {formatDate(g.received_on ?? g.created_at.slice(0, 10), lang)}
                        </td>
                        <td class={td}>{g.fund_name}</td>
                        <td class={`${td} whitespace-nowrap text-right tabular-nums`}>{formatCents(g.amount_cents, g.currency)}</td>
                        <td class={td}>{t(lang, `giving.method.${g.method}`)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
            <a href="/admin/giving" class="mt-3 inline-block text-sm text-primary hover:underline">
              {t(lang, 'admin.person.giving.viewAll')}
            </a>
          </section>
        )}

        {canManagePeople && (
          <form
            method="post"
            class="mt-6 max-w-2xl"
            onsubmit={`return confirm(${JSON.stringify(t(lang, 'admin.person.deleteConfirm'))})`}
          >
            <input type="hidden" name="action" value="delete" />
            <button type="submit" class={btnDanger}>{t(lang, 'admin.person.delete')}</button>
          </form>
        )}
      </>
    )
  }
</Admin>
