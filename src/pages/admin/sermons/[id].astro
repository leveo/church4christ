---
// Create / edit a sermon (console class — re-checks editor∪admin). `id='new'`
// creates; a numeric id edits. save → parseSermonForm (YouTube URL/id extracted
// in the parser) → saveSermon (upsert + revision snapshot in one db.batch;
// duplicate live date → errors.dateTaken); delete → soft delete.
import Admin from '../../../layouts/Admin.astro';
import { t } from '../../../lib/i18n';
import { parseSermonForm } from '../../../lib/validate';
import { getSermonForEdit, saveSermon, softDeleteSermon, listServiceTypeOptions } from '../../../lib/adminDb';
import { todayInTz, nextWeekday, addDays } from '../../../lib/dates';
import { localePath, type Locale } from '../../../lib/locales';
import { tin, lab, card, errorText, btn, btnDanger, noticeErr } from '../../../lib/adminUi';

const user = Astro.locals.user;
if (!user || !(user.isEditor || user.isAdmin)) return new Response(null, { status: 403 });
const lang: Locale = user.lang ?? 'en';
const db = Astro.locals.db;

const rawId = Astro.params.id ?? '';
const isNew = rawId === 'new';
if (!isNew && !/^\d+$/.test(rawId)) return new Response(null, { status: 404 });
const id = isNew ? null : Number(rawId);

const existing = id !== null ? await getSermonForEdit(db, id) : null;
if (id !== null && !existing) return new Response(null, { status: 404 });

const serviceTypes = await listServiceTypeOptions(db, lang);

let errors: Record<string, string> = {};
let fd: FormData | null = null;

if (Astro.request.method === 'POST') {
  fd = await Astro.request.formData();
  const action = fd.get('action');
  if (action === 'delete' && id !== null) {
    await softDeleteSermon(db, id, user.email);
    return Astro.redirect('/admin/sermons?deleted=1', 303);
  }
  if (action === 'save') {
    const parsed = parseSermonForm(fd);
    if (parsed.ok) {
      const result = await saveSermon(db, { ...parsed.data, id }, user.email);
      if (result.ok) return Astro.redirect('/admin/sermons?saved=1', 303);
      errors = result.errors;
    } else {
      errors = parsed.errors;
    }
  }
}

// New sermon prefills the most recent past-or-today Sunday.
const today = todayInTz();
const upcomingSunday = nextWeekday(today, 0);
const lastSunday = upcomingSunday === today ? today : addDays(upcomingSunday, -7);

let v: {
  serviceTypeId: string;
  sermonDate: string;
  title: string;
  speaker: string;
  scripture: string;
  youtube: string;
  series: string;
  status: string;
};
if (fd) {
  const g = (n: string) => String(fd!.get(n) ?? '');
  v = {
    serviceTypeId: g('service_type_id'),
    sermonDate: g('sermon_date'),
    title: g('title'),
    speaker: g('speaker'),
    scripture: g('scripture'),
    youtube: g('youtube'),
    series: g('series'),
    status: g('status') || 'draft',
  };
} else if (existing) {
  v = {
    serviceTypeId: String(existing.serviceTypeId),
    sermonDate: existing.sermonDate,
    title: existing.title,
    speaker: existing.speaker,
    scripture: existing.scripture ?? '',
    youtube: existing.youtubeId ?? '',
    series: existing.series ?? '',
    status: existing.status,
  };
} else {
  const svcParam = Astro.url.searchParams.get('service');
  const preService = svcParam && /^\d+$/.test(svcParam) ? svcParam : serviceTypes.length ? String(serviceTypes[0].id) : '';
  v = {
    serviceTypeId: preService,
    sermonDate: lastSunday,
    title: '',
    speaker: '',
    scripture: '',
    youtube: '',
    series: '',
    status: 'draft',
  };
}

const heading = isNew ? t(lang, 'admin.sermons.newTitle') : t(lang, 'admin.sermons.editTitle');
const hasErrors = Object.keys(errors).length > 0;
const h2 = 'font-display text-heading-sm font-bold';
const publishedNow = !isNew && existing?.status === 'published';
const viewHref = publishedNow ? localePath(lang, '/sermons') : null;
---

<Admin title={heading}>
  <div class="flex items-center justify-between gap-4">
    <h1 class="font-display text-heading-md font-bold">{heading}</h1>
    <div class="flex items-center gap-4 text-sm">
      {viewHref && <a href={viewHref} class="text-primary hover:underline">{t(lang, 'admin.form.viewOnSite')}</a>}
      {!isNew && <a href={`/admin/revisions/sermon/${id}`} class="text-primary hover:underline">{t(lang, 'admin.form.history')}</a>}
      <a href="/admin/sermons" class="text-primary hover:underline">&larr; {t(lang, 'admin.sermons.back')}</a>
    </div>
  </div>

  {hasErrors && <p class={`mt-4 max-w-2xl ${noticeErr}`}>{t(lang, 'admin.form.fixErrors')}</p>}

  <form method="post" class={`mt-6 ${card} grid max-w-2xl gap-4 sm:grid-cols-2`}>
    <input type="hidden" name="action" value="save" />

    <label class="block">
      <span class={lab}>{t(lang, 'admin.sermons.serviceType')} *</span>
      <select name="service_type_id" class={tin}>
        {serviceTypes.map((s) => (
          <option value={s.id} selected={String(s.id) === v.serviceTypeId}>{s.name}</option>
        ))}
      </select>
      {errors.service_type_id && <span class={errorText}>{t(lang, errors.service_type_id)}</span>}
    </label>
    <label class="block">
      <span class={lab}>{t(lang, 'admin.sermons.date')} *</span>
      <input type="date" name="sermon_date" value={v.sermonDate} class={tin} />
      {errors.sermon_date && <span class={errorText}>{t(lang, errors.sermon_date)}</span>}
    </label>

    <label class="block sm:col-span-2">
      <span class={lab}>{t(lang, 'admin.sermons.sermonTitle')} *</span>
      <input type="text" name="title" value={v.title} class={tin} />
      {errors.title && <span class={errorText}>{t(lang, errors.title)}</span>}
    </label>

    <label class="block">
      <span class={lab}>{t(lang, 'admin.sermons.speaker')}</span>
      <input type="text" name="speaker" value={v.speaker} class={tin} />
    </label>
    <label class="block">
      <span class={lab}>{t(lang, 'admin.sermons.scripture')}</span>
      <input type="text" name="scripture" value={v.scripture} class={tin} />
    </label>

    <label class="block sm:col-span-2">
      <span class={lab}>{t(lang, 'admin.sermons.youtube')}</span>
      <input type="text" name="youtube" value={v.youtube} placeholder={t(lang, 'admin.sermons.youtubePlaceholder')} class={tin} />
      {errors.youtube && <span class={errorText}>{t(lang, errors.youtube)}</span>}
    </label>

    <label class="block sm:col-span-2">
      <span class={lab}>{t(lang, 'admin.sermons.series')}</span>
      <input type="text" name="series" value={v.series} class={tin} />
    </label>

    <div class="sm:col-span-2">
      <h2 class={h2}>{t(lang, 'admin.form.publishTitle')}</h2>
      <div class="mt-2 flex gap-6 text-sm">
        <label class="flex items-center gap-2">
          <input type="radio" name="status" value="draft" checked={v.status !== 'published'} />
          {t(lang, 'admin.form.statusDraft')}
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="status" value="published" checked={v.status === 'published'} />
          {t(lang, 'admin.form.statusPublished')}
        </label>
      </div>
    </div>

    <div class="sm:col-span-2">
      <button type="submit" class={btn}>{t(lang, 'admin.form.save')}</button>
    </div>
  </form>

  {
    !isNew && (
      <form
        method="post"
        class="mt-6 max-w-2xl"
        onsubmit={`return confirm(${JSON.stringify(t(lang, 'admin.sermons.deleteConfirm'))})`}
      >
        <input type="hidden" name="action" value="delete" />
        <button type="submit" class={btnDanger}>{t(lang, 'admin.form.delete')}</button>
      </form>
    )
  }
</Admin>
