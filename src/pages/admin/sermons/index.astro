---
// Sermons list (console class — re-checks editor∪admin). Non-deleted sermons
// (drafts included), newest first, with an optional ?year= filter.
import Admin from '../../../layouts/Admin.astro';
import { t } from '../../../lib/i18n';
import { listSermons, listSermonYears, listServiceTypeOptions } from '../../../lib/adminDb';
import { badge, btn, tin, th, td, noticeOk, statusBadge } from '../../../lib/adminUi';
import type { Locale } from '../../../lib/locales';

const user = Astro.locals.user;
if (!user || !(user.isEditor || user.isAdmin)) return new Response(null, { status: 403 });
const lang: Locale = user.lang ?? 'en';
const db = Astro.locals.db;

const yearParam = Astro.url.searchParams.get('year');
const year = yearParam && /^\d{4}$/.test(yearParam) ? Number(yearParam) : undefined;
const saved = Astro.url.searchParams.get('saved') === '1';
const deleted = Astro.url.searchParams.get('deleted') === '1';

const [rows, years, serviceTypes] = await Promise.all([
  listSermons(db, { year }),
  listSermonYears(db),
  listServiceTypeOptions(db, lang),
]);
const serviceName = new Map(serviceTypes.map((s) => [s.id, s.name]));
const nowSql = new Date().toISOString().slice(0, 19).replace('T', ' ');
---

<Admin title={t(lang, 'admin.sermons.title')}>
  <div class="flex items-center justify-between gap-4">
    <h1 class="font-display text-heading-md font-bold">{t(lang, 'admin.sermons.title')}</h1>
    <a href="/admin/sermons/new" class={btn}>{t(lang, 'admin.sermons.new')}</a>
  </div>

  {saved && <p class={`mt-4 ${noticeOk}`}>{t(lang, 'admin.form.saved')}</p>}
  {deleted && <p class={`mt-4 ${noticeOk}`}>{t(lang, 'admin.form.deleted')}</p>}

  <form method="get" class="mt-6 flex max-w-md gap-2">
    <select name="year" class={tin}>
      <option value="">{t(lang, 'admin.sermons.filterAll')}</option>
      {years.map((y) => (
        <option value={y} selected={y === year}>{y}</option>
      ))}
    </select>
    <button type="submit" class={btn}>{t(lang, 'admin.sermons.filter')}</button>
  </form>

  <div class="mt-6 overflow-x-auto rounded-xl border border-border">
    <table class="w-full border-collapse">
      <thead class="bg-surface-sunken">
        <tr>
          <th class={th}>{t(lang, 'admin.sermons.colDate')}</th>
          <th class={th}>{t(lang, 'admin.sermons.colTitle')}</th>
          <th class={th}>{t(lang, 'admin.sermons.colService')}</th>
          <th class={th}>{t(lang, 'admin.sermons.colStatus')}</th>
          <th class={th}>{t(lang, 'admin.sermons.colUpdated')}</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.length === 0 ? (
            <tr>
              <td class={`${td} text-ink-muted`} colspan="5">
                {t(lang, 'admin.sermons.empty')}
              </td>
            </tr>
          ) : (
            rows.map((r) => {
              const b = statusBadge(r.status, null, nowSql);
              return (
                <tr class="border-t border-border hover:bg-surface-sunken">
                  <td class={td}>
                    <a href={`/admin/sermons/${r.id}`} class="font-medium text-primary hover:underline">
                      {r.sermon_date}
                    </a>
                  </td>
                  <td class={td}>{r.title}</td>
                  <td class={td}>{serviceName.get(r.service_type_id) ?? r.serviceTypeName}</td>
                  <td class={td}>
                    <span class={`${badge} ${b.cls}`}>{t(lang, b.key)}</span>
                  </td>
                  <td class={`${td} text-ink-muted`}>{r.updated_at}</td>
                </tr>
              );
            })
          )
        }
      </tbody>
    </table>
  </div>
</Admin>
