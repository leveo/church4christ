---
// Bulletins list (console class — the middleware admits editors, admins, and
// team leaders, so this page re-checks editor∪admin and 403s a bare leader
// before showing any content). Lists non-deleted bulletins (drafts included),
// newest first, with an optional ?service= filter. The "New bulletin" button
// opens the create form.
import Admin from '../../../layouts/Admin.astro';
import { env } from 'cloudflare:workers';
import { t } from '../../../lib/i18n';
import { listBulletins, listServiceTypeOptions } from '../../../lib/adminDb';
import { badge, btn, tin, th, td, noticeOk, statusBadge } from '../../../lib/adminUi';
import type { Locale } from '../../../lib/locales';

const user = Astro.locals.user;
if (!user || !(user.isEditor || user.isAdmin)) return new Response(null, { status: 403 });
const lang: Locale = user.lang ?? 'en';
const db = (env as { DB: D1Database }).DB;

const serviceParam = Astro.url.searchParams.get('service');
const serviceTypeId = serviceParam && /^\d+$/.test(serviceParam) ? Number(serviceParam) : undefined;
const saved = Astro.url.searchParams.get('saved') === '1';
const deleted = Astro.url.searchParams.get('deleted') === '1';

const [rows, serviceTypes] = await Promise.all([
  listBulletins(db, { serviceTypeId }),
  listServiceTypeOptions(db, lang),
]);
const serviceName = new Map(serviceTypes.map((s) => [s.id, s.name]));
const nowSql = new Date().toISOString().slice(0, 19).replace('T', ' ');
---

<Admin title={t(lang, 'admin.bulletins.title')}>
  <div class="flex items-center justify-between gap-4">
    <h1 class="font-display text-heading-md font-bold">{t(lang, 'admin.bulletins.title')}</h1>
    <a href="/admin/bulletins/new" class={btn}>{t(lang, 'admin.bulletins.new')}</a>
  </div>

  {saved && <p class={`mt-4 ${noticeOk}`}>{t(lang, 'admin.form.saved')}</p>}
  {deleted && <p class={`mt-4 ${noticeOk}`}>{t(lang, 'admin.form.deleted')}</p>}

  <form method="get" class="mt-6 flex max-w-md gap-2">
    <select name="service" class={tin}>
      <option value="">{t(lang, 'admin.bulletins.filterAll')}</option>
      {serviceTypes.map((s) => (
        <option value={s.id} selected={s.id === serviceTypeId}>{s.name}</option>
      ))}
    </select>
    <button type="submit" class={btn}>{t(lang, 'admin.bulletins.filter')}</button>
  </form>

  <div class="mt-6 overflow-x-auto rounded-xl border border-border">
    <table class="w-full border-collapse">
      <thead class="bg-surface-sunken">
        <tr>
          <th class={th}>{t(lang, 'admin.bulletins.colDate')}</th>
          <th class={th}>{t(lang, 'admin.bulletins.colService')}</th>
          <th class={th}>{t(lang, 'admin.bulletins.colStatus')}</th>
          <th class={th}>{t(lang, 'admin.bulletins.colUpdated')}</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.length === 0 ? (
            <tr>
              <td class={`${td} text-ink-muted`} colspan="4">
                {t(lang, 'admin.bulletins.empty')}
              </td>
            </tr>
          ) : (
            rows.map((r) => {
              const b = statusBadge(r.status, r.publish_at, nowSql);
              return (
                <tr class="border-t border-border hover:bg-surface-sunken">
                  <td class={td}>
                    <a href={`/admin/bulletins/${r.id}`} class="font-medium text-primary hover:underline">
                      {r.bulletin_date}
                    </a>
                  </td>
                  <td class={td}>{serviceName.get(r.service_type_id) ?? r.serviceTypeName}</td>
                  <td class={td}>
                    <span class={`${badge} ${b.cls}`}>{t(lang, b.key)}</span>
                  </td>
                  <td class={`${td} text-ink-muted`}>
                    {r.updated_at}
                    {r.updated_by ? ` · ${r.updated_by}` : ''}
                  </td>
                </tr>
              );
            })
          )
        }
      </tbody>
    </table>
  </div>
</Admin>
