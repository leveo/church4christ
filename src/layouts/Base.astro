---
// Public shell: full <head> (SEO + hreflang), theme/mode wiring, and the
// header/main/footer scaffold. Theme comes from Astro.locals.theme (settings in
// slice 5); the inline no-flash script reconciles data-mode with localStorage
// before first paint.
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/nunito';
import '@fontsource-variable/space-grotesk';
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localePath, pathWithoutLocale, type Locale } from '../lib/locales';
import { getActiveTheme, THEME_DEFAULT, THEME_DEFAULT_MODE, type Theme } from '../lib/theme';
import { getSiteIdentity } from '../lib/settings';
import { t } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  noindex?: boolean;
}

const { title, locale, noindex = false } = Astro.props;
const description = Astro.props.description ?? t(locale, 'site.tagline');

const theme = (Astro.locals.theme ?? THEME_DEFAULT) as Theme;
// Default color mode for the no-flash script comes from the `theme.default_mode`
// setting (cached per-isolate, warmed by middleware). Guarded so a DB hiccup
// falls back to the theme's intrinsic default rather than 500ing the page.
let defaultMode: 'light' | 'dark' = THEME_DEFAULT_MODE[theme] ?? 'light';
try {
  defaultMode = (await getActiveTheme(Astro.locals.db)).defaultMode;
} catch {
  /* keep the theme's intrinsic default mode */
}

// Site name comes from the admin-editable `site.name.<locale>` setting (with an
// `.en` fallback inside getSiteIdentity); an unset setting or a DB hiccup falls
// back to the built-in i18n default rather than blanking the title.
let siteName = t(locale, 'site.name');
try {
  const identity = await getSiteIdentity(Astro.locals.db, locale);
  if (identity.name) siteName = identity.name;
} catch {
  /* keep the i18n default when settings are unavailable */
}
const fullTitle = `${title} · ${siteName}`;

// Canonical + hreflang alternates: strip the locale prefix, then re-prefix each
// locale against the configured site origin. x-default points at English.
const site = Astro.site ?? new URL(Astro.url.origin);
const { rest } = pathWithoutLocale(Astro.url.pathname);
const canonical = new URL(localePath(locale, rest), site).href;
const alternates = [
  { hreflang: 'en', href: new URL(localePath('en', rest), site).href },
  { hreflang: 'zh-Hans', href: new URL(localePath('zh', rest), site).href },
  { hreflang: 'x-default', href: new URL(localePath('en', rest), site).href },
];
---

<!doctype html>
<html
  lang={locale === 'zh' ? 'zh-Hans' : 'en'}
  data-theme={theme}
  data-mode={defaultMode}
  data-mode-default={defaultMode}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      // No-flash mode: honor a saved choice, else fall back to the settings-driven
      // default carried in data-mode-default (rendered from theme.default_mode).
      (function () {
        var el = document.documentElement;
        var saved = null;
        try {
          saved = localStorage.getItem('c4c-mode');
        } catch (e) {
          /* private mode / storage disabled — use the theme default */
        }
        el.dataset.mode = saved === 'light' || saved === 'dark' ? saved : el.dataset.modeDefault || 'light';
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="skip-link">{t(locale, 'common.skipToContent')}</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      // 简/繁 toggle: cheap no-op on non-zh pages; the conversion table itself
      // is behind a dynamic import and only loads when the visitor enables
      // Traditional (see src/lib/zh-client.ts).
      import { initZhToggle } from '../lib/zh-client';
      initZhToggle();
    </script>
  </body>
</html>
