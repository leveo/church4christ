---
// Admin shell: shared theme/mode wiring, a role-gated dark sidebar nav (top bar
// + checkbox-hack disclosure on mobile), a repeat-row editor island
// (progressive enhancement for the content forms), and a sidebar-bottom block
// showing the signed-in email + a signout POST. Admin UI language follows
// the signed-in person's `lang` (falling back to English). Fonts are imported
// the same way Base.astro does so admin renders in the brand faces.
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/nunito';
import '@fontsource-variable/space-grotesk';
import '../styles/base.css';
import { getActiveTheme, THEME_DEFAULT, THEME_DEFAULT_MODE, type Theme } from '../lib/theme';
import { t } from '../lib/i18n';
import { getLogoImageKey } from '../lib/settings';
import { mediaPath } from '../lib/mediaRef';
import type { ModuleKey } from '../lib/modules';
import type { Locale } from '../lib/locales';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
const lang: Locale = user?.lang ?? 'en';
const theme = (Astro.locals.theme ?? THEME_DEFAULT) as Theme;
// Default color mode for the no-flash script comes from the `theme.default_mode`
// setting (cached per-isolate, warmed by middleware). Guarded so a DB hiccup
// falls back to the theme's intrinsic default rather than 500ing the page.
let defaultMode: 'light' | 'dark' = THEME_DEFAULT_MODE[theme] ?? 'light';
try {
  defaultMode = (await getActiveTheme(Astro.locals.db)).defaultMode;
} catch {
  /* keep the theme's intrinsic default mode */
}
const appName = t(lang, 'admin.title');
const fullTitle = title ? `${title} · ${appName}` : appName;

// Church logo mark for the sidebar/mobile-bar brand block, fetched the same
// guarded way Header.astro does — a settings hiccup renders no logo rather
// than 500ing the whole admin shell.
let logoSrc = '';
try {
  const logoKey = await getLogoImageKey(Astro.locals.db);
  logoSrc = logoKey ? (mediaPath(logoKey) ?? '') : '';
} catch {
  /* no logo when settings are unavailable */
}

// Nav renders by role. The dashboard shows for console-class users (admin ∪
// editor ∪ team leader); content (bulletins/sermons/prayer-sheets) + news
// (announcements/events) + the prayer wall need editor∪admin; people + settings
// are admin-only; giving is admin ∪ finance-flagged. Team leaders (no
// editor/admin) therefore see the dashboard only — their console lands in slice 6.
// Links to pages built later this slice (tasks 2–4) are intentionally live.
const isStaff = !!(user?.isEditor || user?.isAdmin);
const isAdmin = !!user?.isAdmin;
// Giving admin (finance route class): a finance-flagged member reaches it without
// full site-admin, so its nav link shows for admins AND finance-flagged members.
const isFinance = isAdmin || user?.finance === 1;
// /admin (the dashboard) is the 'console' route class — admin ∪ editor ∪ team
// leader (mirrors routePolicy.canAccess). A finance-only member renders this
// shell on /admin/giving but would 403 on /admin itself, so the Dashboard link
// must not show for them.
const isConsole = isStaff || (user?.leaderTeamIds.length ?? 0) > 0;

// A nav entry with a `module` hides when that module is off (settings itself has
// none — it is core). Groups drop out once every child is hidden.
const modules = Astro.locals.modules;
const modOn = (m?: ModuleKey) => !m || modules.has(m);

type NavItem = { label: string; href: string; module?: ModuleKey };
type NavSection = { label: string; href?: string; show: boolean; module?: ModuleKey; children?: NavItem[] };

const rawSections: NavSection[] = [
  { label: t(lang, 'admin.nav.dashboard'), href: '/admin', show: isConsole },
  {
    label: t(lang, 'admin.nav.content'),
    show: isStaff,
    children: [
      { label: t(lang, 'admin.nav.bulletins'), href: '/admin/bulletins', module: 'bulletins' },
      { label: t(lang, 'admin.nav.sermons'), href: '/admin/sermons', module: 'sermons' },
      { label: t(lang, 'admin.nav.prayerSheets'), href: '/admin/prayer-sheets', module: 'prayer-sheets' },
      { label: t(lang, 'admin.nav.testimonies'), href: '/admin/testimonies', module: 'testimonies' },
      { label: t(lang, 'admin.nav.pages'), href: '/admin/pages' },
    ],
  },
  {
    label: t(lang, 'admin.nav.news'),
    show: isStaff,
    module: 'events',
    children: [
      { label: t(lang, 'admin.nav.announcements'), href: '/admin/announcements' },
      { label: t(lang, 'admin.nav.events'), href: '/admin/events' },
    ],
  },
  { label: t(lang, 'admin.nav.prayerWall'), href: '/admin/prayer-wall', show: isStaff, module: 'prayer-wall' },
  { label: t(lang, 'admin.nav.people'), href: '/admin/people', show: isAdmin, module: 'people' },
  { label: t(lang, 'admin.nav.children'), href: '/admin/children', show: isAdmin, module: 'children' },
  { label: t(lang, 'admin.nav.groups'), href: '/admin/fellowships', show: isStaff, module: 'fellowships' },
  { label: t(lang, 'admin.giving.title'), href: '/admin/giving', show: isFinance, module: 'giving' },
  { label: t(lang, 'admin.reg.title'), href: '/admin/registration', show: isStaff, module: 'registration' },
  { label: t(lang, 'admin.nav.settings'), href: '/admin/settings', show: isAdmin },
  { label: t(lang, 'admin.nav.navigation'), href: '/admin/navigation', show: isAdmin },
];

const sections: NavSection[] = rawSections
  .filter((s) => s.show && modOn(s.module))
  .map((s) => (s.children ? { ...s, children: s.children.filter((c) => modOn(c.module)) } : s))
  .filter((s) => !s.children || s.children.length > 0);

const current = Astro.url.pathname.replace(/\/+$/, '') || '/admin';
const isActive = (href: string) => current === href || (href !== '/admin' && current.startsWith(href));
// Rounded nav row on the dark sidebar surface: active gets a lighter overlay +
// semibold, hover gets the same overlay at rest.
const itemClass = (href: string) =>
  `block rounded-md px-3 py-2 text-sm ${isActive(href) ? 'bg-footer-ink/10 font-semibold' : 'hover:bg-footer-ink/10'}`;
---

<!doctype html>
<html
  lang={lang === 'zh' ? 'zh-Hans' : 'en'}
  data-theme={theme}
  data-mode={defaultMode}
  data-mode-default={defaultMode}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="robots" content="noindex" />
    <script is:inline>
      // No-flash mode: honor a saved choice, else fall back to the settings-driven
      // default carried in data-mode-default (rendered from theme.default_mode).
      (function () {
        var el = document.documentElement;
        var saved = null;
        try {
          saved = localStorage.getItem('c4c-mode');
        } catch (e) {
          /* private mode / storage disabled — use the theme default */
        }
        el.dataset.mode = saved === 'light' || saved === 'dark' ? saved : el.dataset.modeDefault || 'light';
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col lg:flex-row bg-surface text-ink">
    {/* Mobile top bar (<lg): brand + a sr-only checkbox-hack disclosure, the
    same no-JS idiom Header.astro uses for its own mobile menu. */}
    <div class="lg:hidden bg-footer-bg text-footer-ink">
      {/* The checkbox must be a sibling of <nav> (not nested inside the bar
      row) for Tailwind's peer-checked sibling selector below to reach it —
      the sr-only input stays visually hidden regardless of DOM position. */}
      <input type="checkbox" id="c4c-admin-nav" class="peer sr-only" />
      <div class="h-14 px-4 flex items-center justify-between gap-4">
        <a href="/admin" class="flex items-center gap-2 font-display font-bold">
          {logoSrc && <img src={logoSrc} alt="" class="h-7 w-auto" />}
          <span>{appName}</span>
        </a>
        <label
          for="c4c-admin-nav"
          class="cursor-pointer p-2 min-w-11 min-h-11 flex flex-col items-center justify-center gap-1.5"
          aria-label={t(lang, 'admin.nav.label')}
        >
          <span class="block w-6 h-0.5 bg-current"></span>
          <span class="block w-6 h-0.5 bg-current"></span>
          <span class="block w-6 h-0.5 bg-current"></span>
        </label>
      </div>
      <nav
        class="hidden peer-checked:block border-t border-footer-ink/10 px-3 py-3 max-h-[80vh] overflow-y-auto"
        aria-label={t(lang, 'admin.nav.label')}
      >
        {
          sections.map((section) =>
            section.children ? (
              <div class="pt-3 first:pt-0">
                <p class="px-3 pb-1 text-xs font-semibold uppercase tracking-caps text-footer-ink/60">{section.label}</p>
                {section.children.map((c) => (
                  <a href={c.href} aria-current={isActive(c.href) ? 'page' : undefined} class={itemClass(c.href)}>
                    {c.label}
                  </a>
                ))}
              </div>
            ) : (
              <a href={section.href} aria-current={isActive(section.href!) ? 'page' : undefined} class={itemClass(section.href!)}>
                {section.label}
              </a>
            ),
          )
        }
        {
          user && (
            <div class="mt-3 border-t border-footer-ink/10 pt-3 space-y-2">
              <p class="px-3 text-xs text-footer-ink/70 truncate">{user.email}</p>
              <a href="/" class="block rounded-md px-3 py-2 text-sm hover:bg-footer-ink/10">
                {t(lang, 'admin.nav.viewSite')}
              </a>
              <form method="post" action="/signout" class="px-3">
                <button
                  type="submit"
                  class="w-full rounded-md border border-footer-ink/30 px-3 py-1.5 text-sm font-semibold hover:bg-footer-ink/10"
                >
                  {t(lang, 'common.signOut')}
                </button>
              </form>
            </div>
          )
        }
      </nav>
    </div>

    {/* Desktop sidebar (lg+): fixed width, dark surface, own scroll if the nav
    grows taller than the viewport. */}
    <aside class="hidden lg:flex lg:w-64 lg:shrink-0 lg:flex-col lg:sticky lg:top-0 lg:h-screen lg:overflow-y-auto bg-footer-bg text-footer-ink">
      <a href="/admin" class="flex items-center gap-2 px-4 py-5 font-display font-bold">
        {logoSrc && <img src={logoSrc} alt="" class="h-8 w-auto" />}
        <span>{appName}</span>
      </a>
      <nav class="flex-1 px-3 space-y-1" aria-label={t(lang, 'admin.nav.label')}>
        {
          sections.map((section) =>
            section.children ? (
              <div class="pt-4 first:pt-0">
                <p class="px-3 pb-1 text-xs font-semibold uppercase tracking-caps text-footer-ink/60">{section.label}</p>
                {section.children.map((c) => (
                  <a href={c.href} aria-current={isActive(c.href) ? 'page' : undefined} class={itemClass(c.href)}>
                    {c.label}
                  </a>
                ))}
              </div>
            ) : (
              <a href={section.href} aria-current={isActive(section.href!) ? 'page' : undefined} class={itemClass(section.href!)}>
                {section.label}
              </a>
            ),
          )
        }
      </nav>
      {
        user && (
          <div class="mt-auto border-t border-footer-ink/10 px-4 py-4 space-y-2">
            <p class="text-xs text-footer-ink/70 truncate">{user.email}</p>
            <a href="/" class="block text-sm hover:underline">
              {t(lang, 'admin.nav.viewSite')}
            </a>
            <form method="post" action="/signout">
              <button
                type="submit"
                class="w-full rounded-md border border-footer-ink/30 px-3 py-1.5 text-sm font-semibold hover:bg-footer-ink/10"
              >
                {t(lang, 'common.signOut')}
              </button>
            </form>
          </div>
        )
      }
    </aside>

    <main class="flex-1 min-w-0 bg-surface">
      <div class="mx-auto max-w-wide px-4 sm:px-6 lg:px-10 py-8">
        <slot />
      </div>
    </main>
    <script>
      // Repeat-rows editor island (ported from the reference stack): progressive
      // enhancement over a <template data-repeat-template> plus [data-repeat-row]
      // rows with add / remove / move-up / move-down controls. Add clones the
      // template before it; remove/move act on the closest row. Pure enhancement —
      // with JS off the form still posts every row and the server skips blanks.
      document.querySelectorAll<HTMLElement>('[data-repeat]').forEach((box) => {
        const tpl = box.querySelector<HTMLTemplateElement>('template[data-repeat-template]');
        box.querySelector('[data-repeat-add]')?.addEventListener('click', () => {
          if (tpl) box.insertBefore(tpl.content.cloneNode(true), tpl);
        });
        box.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const rm = target.closest('[data-repeat-remove]');
          if (rm && box.contains(rm)) {
            rm.closest('[data-repeat-row]')?.remove();
            return;
          }
          const mv = target.closest<HTMLElement>('[data-repeat-up], [data-repeat-down]');
          if (!mv || !box.contains(mv)) return;
          const row = mv.closest('[data-repeat-row]');
          if (!row || !row.parentElement) return;
          if (mv.matches('[data-repeat-up]') && row.previousElementSibling?.matches('[data-repeat-row]')) {
            row.parentElement.insertBefore(row, row.previousElementSibling);
          } else if (mv.matches('[data-repeat-down]') && row.nextElementSibling?.matches('[data-repeat-row]')) {
            row.parentElement.insertBefore(row.nextElementSibling, row);
          }
        });
      });
    </script>
  </body>
</html>
