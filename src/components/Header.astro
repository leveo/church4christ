---
// Sticky site header. Desktop nav + Give CTA + LocaleSwitch inline; on small
// screens a checkbox-hack disclosure menu (no JS required for open/close).
import { localePath } from '../lib/locales';
import { t } from '../lib/i18n';
import LocaleSwitch from './LocaleSwitch.astro';

const locale = Astro.locals.locale;
const home = localePath(locale, '/');
const give = localePath(locale, '/give');

const nav: { key: string; path: string }[] = [
  { key: 'nav.visit', path: '/visit' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.sermons', path: '/sermons' },
  { key: 'nav.bulletin', path: '/bulletin' },
  { key: 'nav.events', path: '/events' },
  { key: 'nav.ministries', path: '/ministries' },
  { key: 'nav.serve', path: '/serve' },
  { key: 'nav.fellowships', path: '/fellowships' },
  { key: 'nav.articles', path: '/articles' },
];
---

<header class="sticky top-0 z-40 bg-header-bg text-header-ink border-b border-border">
  <div class="container-wide flex items-center gap-4 h-16">
    <a href={home} class="font-display font-bold text-lg whitespace-nowrap shrink-0">
      {t(locale, 'site.name')}
    </a>

    <nav
      class="hidden lg:flex flex-1 items-center justify-center gap-1 text-sm"
      aria-label={t(locale, 'common.menu')}
    >
      {
        nav.map((item) => (
          <a href={localePath(locale, item.path)} class="px-3 py-2 rounded-md hover:bg-surface-raised">
            {t(locale, item.key)}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:flex items-center gap-3 shrink-0">
      <LocaleSwitch />
      <a
        href={give}
        class="px-4 py-2 rounded-full bg-accent text-on-accent font-semibold hover:bg-accent-hover"
      >
        {t(locale, 'nav.give')}
      </a>
    </div>

    {/* Mobile disclosure: checkbox toggles the panel, no framework needed. */}
    <input type="checkbox" id="c4c-nav" class="peer sr-only" />
    <label
      for="c4c-nav"
      class="lg:hidden ml-auto cursor-pointer p-2 min-w-11 min-h-11 flex flex-col items-center justify-center gap-1.5"
      aria-label={t(locale, 'common.menu')}
    >
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
    </label>
    <nav
      class="hidden peer-checked:block absolute top-16 inset-x-0 bg-header-bg text-header-ink border-b border-border shadow-lg lg:hidden max-h-[80vh] overflow-y-auto"
      aria-label={t(locale, 'common.menu')}
    >
      <div class="container-wide py-4 flex flex-col gap-1">
        {
          nav.map((item) => (
            <a href={localePath(locale, item.path)} class="block py-2.5">
              {t(locale, item.key)}
            </a>
          ))
        }
        <a
          href={give}
          class="block mt-3 px-4 py-2 rounded-full bg-accent text-on-accent text-center font-semibold"
        >
          {t(locale, 'nav.give')}
        </a>
        <div class="mt-3 flex justify-center">
          <LocaleSwitch />
        </div>
      </div>
    </nav>
  </div>
</header>
