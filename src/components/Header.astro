---
// Sticky site header. Desktop nav + Give CTA + LocaleSwitch inline; on small
// screens a checkbox-hack disclosure menu (no JS required for open/close).
import { localePath } from '../lib/locales';
import { t } from '../lib/i18n';
import { getSiteIdentity, getLogoImageKey } from '../lib/settings';
import { mediaPath } from '../lib/mediaRef';
import { resolveDefaultNav, resolveNav } from '../lib/nav';
import LocaleSwitch from './LocaleSwitch.astro';

const locale = Astro.locals.locale;
const home = localePath(locale, '/');
const give = localePath(locale, '/give');

const db = Astro.locals.db;
const modules = Astro.locals.modules;
// Site identity + logo + the nav menu come from admin-editable settings; a DB
// hiccup falls back to the pre-feature hardcoded name, no logo, and the
// module-gated default nav rather than 500ing the header on every public page
// (mirrors Base.astro's identity guard).
let siteName = t(locale, 'site.name');
let logoSrc = '';
let links = resolveDefaultNav(locale, modules);
try {
  const identity = await getSiteIdentity(db, locale);
  siteName = identity.name || t(locale, 'site.name');
  const logoKey = await getLogoImageKey(db);
  logoSrc = logoKey ? (mediaPath(logoKey) ?? '') : '';
  links = await resolveNav(db, locale, modules);
} catch {
  /* keep the hardcoded site name, no logo, and the default nav when settings are unavailable */
}
---

<header class="sticky top-0 z-40 bg-header-bg text-header-ink border-b border-border">
  <div class="container-wide flex items-center gap-4 h-16">
    <a href={home} class="font-display font-bold text-lg whitespace-nowrap shrink-0 flex items-center gap-2">
      {logoSrc && <img src={logoSrc} alt="" class="h-8 w-auto" />}
      <span>{siteName}</span>
    </a>

    <nav
      class="hidden lg:flex flex-1 items-center justify-center gap-1 text-sm"
      aria-label={t(locale, 'common.menu')}
    >
      {
        links.map((link) => (
          <a href={link.href} class="px-3 py-2 rounded-md hover:bg-surface-raised">
            {link.label}
          </a>
        ))
      }
      {
        Astro.locals.user && modules.has('portal') && (
          <a href={localePath(locale, '/my')} class="px-3 py-2 rounded-md hover:bg-surface-raised">
            {t(locale, 'portal.nav.myPortal')}
          </a>
        )
      }
    </nav>

    <div class="hidden lg:flex items-center gap-3 shrink-0">
      {
        locale === 'zh' && (
          <button
            type="button"
            data-zh-toggle
            data-no-convert
            class="px-2.5 py-1 rounded-md border border-border text-sm font-semibold hover:bg-surface-raised cursor-pointer"
            aria-label={t(locale, 'common.zhToggleAria')}
          >
            {t(locale, 'common.zhToggleToTrad')}
          </button>
        )
      }
      <LocaleSwitch />
      <a
        href={give}
        class="px-4 py-2 rounded-full bg-accent text-on-accent font-semibold hover:bg-accent-hover"
      >
        {t(locale, 'nav.give')}
      </a>
    </div>

    {/* Mobile disclosure: checkbox toggles the panel, no framework needed. */}
    <input type="checkbox" id="c4c-nav" class="peer sr-only" />
    <label
      for="c4c-nav"
      class="lg:hidden ml-auto cursor-pointer p-2 min-w-11 min-h-11 flex flex-col items-center justify-center gap-1.5"
      aria-label={t(locale, 'common.menu')}
    >
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
    </label>
    <nav
      class="hidden peer-checked:block absolute top-16 inset-x-0 bg-header-bg text-header-ink border-b border-border shadow-lg lg:hidden max-h-[80vh] overflow-y-auto"
      aria-label={t(locale, 'common.menu')}
    >
      <div class="container-wide py-4 flex flex-col gap-1">
        {
          links.map((link) => (
            <a href={link.href} class="block py-2.5">
              {link.label}
            </a>
          ))
        }
        {
          Astro.locals.user && modules.has('portal') && (
            <a href={localePath(locale, '/my')} class="block py-2.5">
              {t(locale, 'portal.nav.myPortal')}
            </a>
          )
        }
        <a
          href={give}
          class="block mt-3 px-4 py-2 rounded-full bg-accent text-on-accent text-center font-semibold"
        >
          {t(locale, 'nav.give')}
        </a>
        <div class="mt-3 flex justify-center items-center gap-4">
          {
            locale === 'zh' && (
              <button
                type="button"
                data-zh-toggle
                data-no-convert
                class="px-2.5 py-1 rounded-md border border-border text-sm font-semibold hover:bg-surface-raised cursor-pointer"
                aria-label={t(locale, 'common.zhToggleAria')}
              >
                {t(locale, 'common.zhToggleToTrad')}
              </button>
            )
          }
          <LocaleSwitch />
        </div>
      </div>
    </nav>
  </div>
</header>
