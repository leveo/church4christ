---
// Latest-sermon card for the home page: an optional series badge, the title,
// speaker + scripture, the formatted sermon date, and a link into the sermons
// archive (the per-sermon watch page lands with the sermons index in Task 3).
import { localePath, type Locale } from '../lib/locales';
import { formatDate } from '../lib/dates';
import { t } from '../lib/i18n';
import type { LatestSermonRow } from '../lib/publicDb';

interface Props {
  sermon: LatestSermonRow;
  locale: Locale;
}
const { sermon, locale } = Astro.props;
const meta = [sermon.speaker, sermon.scripture].filter(Boolean).join(' · ');
---

<a
  href={localePath(locale, '/sermons')}
  class="block rounded-lg border border-border bg-surface-raised p-6 shadow-sm transition-shadow hover:shadow-md"
>
  {
    sermon.series && (
      <span class="inline-block rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold uppercase tracking-caps text-on-accent-soft">
        {sermon.series}
      </span>
    )
  }
  <h3 class="mt-3 font-display text-heading-md font-bold">{sermon.title}</h3>
  {meta && <p class="mt-2 text-ink-muted">{meta}</p>}
  <p class="mt-1 text-sm text-ink-subtle">{formatDate(sermon.sermon_date, locale)}</p>
  <span class="mt-4 inline-block text-sm font-semibold text-accent">{t(locale, 'home.watchSermon')} →</span>
</a>
