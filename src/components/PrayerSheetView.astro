---
// A weekly prayer sheet: sections of headings each with a bullet list of items.
// sections_json is parsed defensively so malformed content degrades to nothing
// rather than throwing.
import { parseJsonArray } from '../lib/json';
import { formatDate } from '../lib/dates';
import { t } from '../lib/i18n';
import type { Locale } from '../lib/locales';
import type { PrayerSheetRow } from '../lib/publicDb';

interface Section { heading: string; items: string[] }

interface Props {
  sheet: PrayerSheetRow;
  locale: Locale;
}
const { sheet, locale } = Astro.props;
const sections = parseJsonArray<Section>(sheet.sections_json);
---

<article>
  <h2 class="font-display text-heading-md font-bold">
    {t(locale, 'prayer.sheetTitle')} · {formatDate(sheet.sheet_date, locale)}
  </h2>
  <div class="mt-6 space-y-6">
    {
      sections.map((sec) => (
        <section>
          <h3 class="mb-2 border-l-4 border-accent pl-3 font-display font-bold">{sec.heading}</h3>
          <ul class="list-disc space-y-1 pl-6 text-sm">
            {(sec.items ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </section>
      ))
    }
  </div>
</article>
