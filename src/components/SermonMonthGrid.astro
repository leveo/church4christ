---
// Sermon archive grid: the year's sermons grouped under month headings, each a
// YouTubeEmbed facade with title, speaker/scripture, and formatted date. Sermons
// arrive already ordered newest-first, so months and cards keep that order.
import YouTubeEmbed from './YouTubeEmbed.astro';
import ImagePlaceholder from './ImagePlaceholder.astro';
import { formatDate, formatMonth } from '../lib/dates';
import type { Locale } from '../lib/locales';
import type { SermonRow } from '../lib/publicDb';

interface Props {
  sermons: SermonRow[];
  locale: Locale;
}
const { sermons, locale } = Astro.props;

const byMonth = new Map<string, SermonRow[]>();
for (const s of sermons) {
  const key = s.sermon_date.slice(0, 7);
  if (!byMonth.has(key)) byMonth.set(key, []);
  byMonth.get(key)!.push(s);
}
---

{
  [...byMonth.entries()].map(([ym, list]) => (
    <section class="mb-14">
      <h3 class="mb-6 border-l-4 border-accent pl-3 font-display text-heading-sm font-bold">{formatMonth(ym, locale)}</h3>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {list.map((s) => (
          <article>
            {s.youtube_id ? (
              <YouTubeEmbed videoId={s.youtube_id} title={s.title} locale={locale} />
            ) : (
              <ImagePlaceholder seed={s.title} class="aspect-video w-full rounded-lg" />
            )}
            <h4 class="mt-3 font-display font-semibold">{s.title}</h4>
            {[s.speaker, s.scripture].filter(Boolean).length > 0 && (
              <p class="mt-1 text-sm text-ink-muted">{[s.speaker, s.scripture].filter(Boolean).join(' · ')}</p>
            )}
            <p class="text-sm text-ink-subtle">{[formatDate(s.sermon_date, locale), s.serviceTypeName].filter(Boolean).join(' · ')}</p>
          </article>
        ))}
      </div>
    </section>
  ))
}
