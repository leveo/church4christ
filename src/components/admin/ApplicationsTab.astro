---
// Applications tab: pending serving applications across the visible teams with a
// gift badge, approve / reject posting the same actions the team page uses.
import { t } from '../../lib/i18n';
import type { Locale } from '../../lib/locales';
import type { ApplicationRow } from '../../lib/teamDb';
import { card, badge, badgeScheduled } from '../../lib/adminUi';

interface Props {
  lang: Locale;
  applications: ApplicationRow[];
}
const { lang, applications } = Astro.props;
const initial = (name: string) => name.trim().charAt(0);
---
<div class={card}>
  <h2 class="font-display text-heading-sm font-bold">{t(lang, 'admin.console.applications')}</h2>
  {applications.length === 0 ? (
    <p class="mt-4 text-sm text-ink-muted">{t(lang, 'admin.console.noApps')}</p>
  ) : (
    <div class="mt-2 divide-y divide-border">
      {applications.map((a) => (
        <div class="py-4">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-primary text-on-primary font-bold text-sm shrink-0">{initial(a.person_name)}</span>
            <div class="flex-1 min-w-44">
              <div class="font-semibold text-ink">{a.person_name}</div>
              <div class="text-[0.8125rem] text-ink-muted">{a.team_name}{a.position_name ? ` · ${a.position_name}` : ''} · {a.created_at.slice(5, 10)}</div>
            </div>
            {a.has_gifts === 1 && (
              <span class={`${badge} ${badgeScheduled}`}>✦ {t(lang, 'admin.console.giftsBadge')}</span>
            )}
            <form method="post" class="flex gap-2">
              <input type="hidden" name="application_id" value={a.id} />
              <button name="_action" value="approveApp" class="rounded-md bg-primary px-4 py-1.5 text-sm font-semibold text-on-primary hover:bg-primary-hover">{t(lang, 'admin.console.approve')}</button>
              <button name="_action" value="rejectApp" class="rounded-md border border-border px-4 py-1.5 text-sm font-semibold text-ink hover:bg-surface-sunken">{t(lang, 'admin.console.reject')}</button>
            </form>
          </div>
          {a.message && <p class="mt-2 ml-12 text-sm text-ink-muted leading-relaxed">「{a.message}」</p>}
        </div>
      ))}
    </div>
  )}
</div>
