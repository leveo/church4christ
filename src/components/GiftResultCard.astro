---
// One of the top-3 spiritual gifts on the quiz results view: a ranked header,
// the gift's localized label + definition, and its recommended ministry areas
// as chips that link to the matching ministry page when one exists. Token-styled
// only. `links` are resolved by the page from the gift's ministry categories.
import { t } from '../lib/i18n';
import type { Locale } from '../lib/locales';
import type { GiftMeta } from '../lib/giftQuiz';

interface Props {
  gift: GiftMeta;
  rank: number;
  locale: Locale;
  links: { label: string; href: string | null }[];
}
const { gift, rank, locale, links } = Astro.props;
---

<article class="overflow-hidden rounded-lg border border-border bg-surface-raised">
  <div class="flex items-center gap-4 bg-primary px-6 py-4 text-on-primary">
    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-hover font-display text-lg font-bold">
      {rank}
    </span>
    <h3 class="font-display text-xl font-bold">{gift.label[locale]}</h3>
  </div>
  <div class="p-6">
    <p class="leading-relaxed text-ink-muted">{gift.definition[locale]}</p>
    {
      links.length > 0 && (
        <div class="mt-5">
          <p class="text-xs font-bold uppercase tracking-caps text-ink-subtle">
            {t(locale, 'serve.gifts.whereToServe')}
          </p>
          <ul class="mt-2 flex flex-wrap gap-2">
            {links.map((l) =>
              l.href ? (
                <li>
                  <a
                    href={l.href}
                    class="inline-flex items-center rounded-full bg-primary-soft px-3 py-1 text-xs font-semibold text-on-primary-soft hover:bg-accent-soft hover:text-on-accent-soft"
                  >
                    {l.label} →
                  </a>
                </li>
              ) : (
                <li class="inline-flex items-center rounded-full bg-surface-sunken px-3 py-1 text-xs font-semibold text-ink-muted">
                  {l.label}
                </li>
              ),
            )}
          </ul>
        </div>
      )
    }
  </div>
</article>
