---
// Site footer: identity + address, service times, quick links, and a rights
// line with the current year and the light/dark toggle.
import { env } from 'cloudflare:workers';
import { localePath } from '../lib/locales';
import { t } from '../lib/i18n';
import { MODULE_KEYS, MODULES } from '../lib/modules';
import { getSiteIdentity } from '../lib/settings';
import ModeToggle from './ModeToggle.astro';

const locale = Astro.locals.locale;
const year = new Date().getFullYear();

// Identity comes from the admin-editable `site.*` settings (same source as
// Base.astro's <title>). Each field keeps its built-in i18n default until admin
// sets it; a DB hiccup falls back to the i18n defaults rather than blanking the
// footer. address/email/phone are locale-free settings — empty until configured.
let siteName = t(locale, 'site.name');
let addressLine = t(locale, 'footer.addressLine');
let email = '';
let phone = '';
try {
  const identity = await getSiteIdentity((env as { DB: D1Database }).DB, locale);
  if (identity.name) siteName = identity.name;
  if (identity.address) addressLine = identity.address;
  email = identity.email;
  phone = identity.phone;
} catch {
  /* keep the i18n defaults when settings are unavailable */
}

const quickLinks: { key: string; path: string }[] = [
  { key: 'nav.about', path: '/about' },
  { key: 'nav.sermons', path: '/sermons' },
  { key: 'nav.events', path: '/events' },
  { key: 'nav.give', path: '/give' },
];

// Hide a quick link when its owning module is off (sermons/events); about/give
// are core. Same navKey → module reverse map the header uses.
const navKeyModule = new Map<string, string>();
for (const key of MODULE_KEYS) for (const nk of MODULES[key].navKeys) navKeyModule.set(nk, key);
const modules = Astro.locals.modules;
const visibleQuickLinks = quickLinks.filter((link) => {
  const owner = navKeyModule.get(link.key);
  return !owner || modules.has(owner);
});
---

<footer class="bg-footer-bg text-footer-ink">
  <div class="container-wide py-12 grid gap-8 sm:grid-cols-3">
    <div>
      <p class="font-display font-bold text-lg">{siteName}</p>
      <p class="mt-2 text-sm">{t(locale, 'site.tagline')}</p>
      <p class="mt-4 text-sm font-semibold">{t(locale, 'footer.address')}</p>
      <p class="text-sm">{addressLine}</p>
      {phone && <p class="text-sm">{phone}</p>}
      {email && (
        <p class="text-sm">
          <a href={`mailto:${email}`} class="hover:underline">{email}</a>
        </p>
      )}
    </div>

    <div>
      <p class="font-semibold">{t(locale, 'footer.serviceTimes')}</p>
      <p class="mt-2 text-sm">{t(locale, 'footer.serviceLine1')}</p>
      <p class="text-sm">{t(locale, 'footer.serviceLine2')}</p>
    </div>

    <div>
      <p class="font-semibold">{t(locale, 'footer.quickLinks')}</p>
      <ul class="mt-2 flex flex-col gap-1 text-sm">
        {
          visibleQuickLinks.map((link) => (
            <li>
              <a href={localePath(locale, link.path)} class="hover:underline">
                {t(locale, link.key)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div
      class="container-wide py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm"
    >
      <p>© {year} {siteName} · {t(locale, 'footer.rights')}</p>
      <ModeToggle />
    </div>
  </div>
</footer>
