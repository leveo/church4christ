---
// Shared attendance sheet, rendered by both the token page (/attendance/[token])
// and the session page (/attendance/o/[id]). Pure presentation: the caller has
// already authorized the actor and loaded the roster + existing attendance, and
// owns the <Base> wrapper and the POST handling. Each member is a pre-checked
// checkbox (name="member" value=<member id>); the enclosing page's POST reads
// form.getAll('member') and calls saveAttendance. The optional hidden `token`
// carries the raw tracker token so the POST can re-verify it server-side.
import type { Locale } from '../lib/locales';
import { t } from '../lib/i18n';
import { formatDate } from '../lib/dates';
import type { OccurrenceWithEvent } from '../lib/groupEventDb';
import type { GroupMemberRow } from '../lib/groupDb';
import { card, btn, lab, noticeOk } from '../lib/adminUi';

interface Props {
  locale: Locale;
  occurrence: OccurrenceWithEvent;
  members: GroupMemberRow[];
  attendance: Record<number, number>;
  actionUrl: string;
  token?: string;
  saved?: boolean;
}

const { locale, occurrence, members, attendance, actionUrl, token, saved = false } = Astro.props;
---
<section class="container-narrow py-12">
  <h1 class="font-display text-heading-sm font-semibold">{occurrence.title}</h1>
  <p class="mt-1 text-ink-muted">{occurrence.group_name}</p>
  <p class="text-sm text-ink-subtle">{formatDate(occurrence.occurs_on, locale)}</p>
  {occurrence.location && <p class="text-sm text-ink-subtle">{occurrence.location}</p>}

  {saved && <p class={`mt-4 ${noticeOk}`}>{t(locale, 'attendance.saved')}</p>}

  <form method="post" action={actionUrl} class={`mt-6 ${card}`}>
    {token && <input type="hidden" name="token" value={token} />}
    <p class={lab}>{t(locale, 'attendance.instructions')}</p>
    {members.length === 0 ? (
      <p class="mt-2 text-sm text-ink-muted">{t(locale, 'attendance.noMembers')}</p>
    ) : (
      <ul class="mt-3 flex flex-col gap-1">
        {members.map((m) => (
          <li>
            <label class="flex items-center gap-3 rounded-md px-2 py-2 hover:bg-surface-sunken">
              <input type="checkbox" name="member" value={m.id} checked={attendance[m.id] === 1} class="h-5 w-5" />
              <span class="font-medium">{m.display_name}</span>
            </label>
          </li>
        ))}
      </ul>
    )}
    <button type="submit" class={`mt-6 ${btn}`}>{t(locale, 'attendance.save')}</button>
  </form>
</section>
