---
// Light/dark toggle. Writes localStorage 'c4c-mode', which the no-flash script
// in the layout head reads on the next load.
import { t } from '../lib/i18n';

const locale = Astro.locals.locale;
---

<button
  type="button"
  data-mode-toggle
  class="px-3 py-1.5 rounded-md border border-border hover:bg-surface-raised"
>
  {t(locale, 'footer.modeToggle')}
</button>

<script>
  const root = document.documentElement;
  for (const btn of document.querySelectorAll('[data-mode-toggle]')) {
    btn.addEventListener('click', () => {
      const next = root.dataset.mode === 'dark' ? 'light' : 'dark';
      root.dataset.mode = next;
      try {
        localStorage.setItem('c4c-mode', next);
      } catch {
        /* private mode / storage disabled — toggle still applies for this page */
      }
    });
  }
</script>
