---
// Compact ministry card for the home-page preview and the ministries/serve
// directory grids: emoji icon, localized name, and a two-line-clamped intro,
// linking to the ministry detail page. When `openSlots` > 0 it shows an
// open-roles badge (help-wanted). Token utilities only.
import { localePath, type Locale } from '../lib/locales';
import { t } from '../lib/i18n';
import { mediaPath } from '../lib/mediaRef';

interface Props {
  icon: string;
  name: string;
  intro: string;
  slug: string;
  locale: Locale;
  coverKey?: string | null;
  /** Open self-signup roles across this ministry's upcoming plans; 0 hides the badge. */
  openSlots?: number;
}
const { icon, name, intro, slug, locale, coverKey = null, openSlots = 0 } = Astro.props;
const coverSrc = mediaPath(coverKey);
---

<a
  href={localePath(locale, `/ministries/${slug}`)}
  class="relative block overflow-hidden rounded-lg border border-border bg-surface-raised transition-shadow hover:border-border-strong hover:shadow-md"
>
  {
    openSlots > 0 && (
      <span class="absolute right-3 top-3 rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-on-accent-soft">
        {t(locale, 'ministries.openBadge', { count: openSlots })}
      </span>
    )
  }
  {coverSrc && <img src={coverSrc} alt="" class="h-36 w-full object-cover" loading="lazy" />}
  <div class="p-5">
    <span class="text-3xl" aria-hidden="true">{icon}</span>
    <h3 class="mt-3 font-display text-lg font-semibold">{name}</h3>
    {intro && <p class="mt-1 line-clamp-2 text-sm text-ink-muted">{intro}</p>}
  </div>
</a>
