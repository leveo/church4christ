{
  "name": "church4christ",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run tokens && astro build",
    "preview": "astro build && astro preview",
    "check": "astro check",
    "tokens": "node scripts/build-tokens.mjs",
    "tokens:check": "node scripts/check-tokens.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute DB --local --file=./seed/dev-seed.sql",
    "cf-typegen": "wrangler types",
    "deploy": "astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "astro": "^7.0.5",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "opencc-data": "^1.4.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
